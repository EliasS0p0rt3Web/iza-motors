@model Negocio.Web.Models.ViewModels.CotizacionCortinaVm

@{
    bool esClienteLogueado = Context.Session.GetInt32("USER_ID") != null;

    ViewData["Title"] = "Cotización - Tubo para Cortinas";
    Layout = "_LayoutCotizacion";
}

<style>
    /* 1. NAVEGACIÓN Y HEADER */
    .main-title {
        font-size: clamp(1.2rem, 4vw, 1.8rem);
        letter-spacing: 2px;
        font-weight: 900 !important;
        background: linear-gradient(135deg, #ffffff 0%, #94a3b8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-transform: uppercase;
    }

    .back-button {
        border-radius: 12px;
        padding: 8px 16px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.05);
        transition: all 0.3s ease;
        font-size: 0.9rem;
        font-weight: 600;
    }

        .back-button:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: #2563eb;
            transform: translateX(-3px);
        }

    .material-badge {
        border-radius: 10px;
        font-size: 0.85rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: #0f172a;
    }

    /* 2. DISEÑO DEL TICKET DE RESULTADO */
    #resultadoHtml {
        max-width: 500px;
        margin: 2rem auto;
        /* 🔥 ESTO MATA LA CAPA EXTRA AZUL/GRIS 🔥 */
        background: transparent !important;
        border: none !important;
        padding: 0 !important;
        box-shadow: none !important;
    }

    .ticket-container {
        background: #171f2d; /* Azul oscuro premium de Pasamanos */
        border-radius: 28px;
        padding: 2.5rem;
        position: relative;
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.6);
    }

        /* Simulación de corte de ticket en la parte inferior */
        .ticket-container::after {
            content: "";
            position: absolute;
            bottom: -10px;
            left: 10%;
            right: 10%;
            height: 20px;
            background: #171f2d; /* 🔥 Azul oscuro premium de Pasamanos */
            filter: blur(10px);
            z-index: -1;
        }

    .separator-dots {
        border-top: 2px dotted rgba(255,255,255,0.15);
        margin: 1.5rem 0;
    }

    .item-img-wrapper {
        width: 85px;
        height: 85px;
        background: #ffffff; /* 🔥 Fondo blanco nieve */
        border-radius: 18px;
        padding: 8px; /* Menos padding interno para que el tubo se vea más grande */
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.3); /* Sombra elegante */
    }

        .item-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    .res-accesorios-list .acc-card {
        background: rgba(255,255,255,0.04);
        margin-bottom: 10px;
        padding: 14px 18px;
        border-radius: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: transform 0.2s ease;
    }

    .total-ribbon {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        padding: 1.5rem;
        border-radius: 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 1.1rem;
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);
    }

        .total-ribbon strong {
            font-size: 1.6rem;
            letter-spacing: -1px;
        }

    /* Estilos base para escritorio */
    .wizard-progress {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
    }

    /* --- COMPACTACIÓN EXTREMA PARA MÓVIL --- */
    @@media (max-width: 576px) {
        /* 🔥 WIZARD 🔥 */
        .wizard-progress {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0;
            padding: 0;
            margin-bottom: 25px !important;
        }

        .step-circle {
            width: 28px !important;
            height: 28px !important;
            font-size: 11px !important;
            flex-shrink: 0;
        }

        .wizard-line {
            width: 30px !important;
            min-width: 15px;
            flex: 0 0 auto;
            height: 2px;
            margin: 0 6px;
        }

        .step-label {
            font-size: 10px !important;
            margin-top: 4px;
            white-space: nowrap;
            letter-spacing: 0px;
        }

        .wizard-step {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: auto;
        }
        /* 🔥 RESCATE DEL TICKET EN MÓVIL 🔥 */
        /* Matamos el margen invisible lateral que chupaba el ticket */
        #resultadoHtml {
            margin: 1rem 0 !important;
            width: 100%;
        }
        /* Reducimos los márgenes laterales gigantes del ticket y forzamos el 100% */
        .ticket-container {
            padding: 1.2rem !important;
            border-radius: 20px;
            width: 100%;
        }
        /* Ajuste de imagen para que no ocupe tanto ancho */
        .item-img-wrapper {
            width: 70px;
            height: 70px;
            padding: 6px;
        }
        /* Ajuste del título principal para que no se parta en 3 líneas */
        #resTuboDesc {
            font-size: 1.1rem !important;
        }
        /* Ajuste de la caja de combos para que gane espacio */
        .ticket-body + div {
            padding: 1rem 0.8rem !important;
        }

            .ticket-body + div span.text-uppercase {
                letter-spacing: 0px !important;
                font-size: 0.65rem !important;
            }
        /* Rescate de la franja verde del Total a Pagar */
        .total-ribbon {
            padding: 1rem !important;
            font-size: 0.95rem !important;
        }

            .total-ribbon strong {
                font-size: 1.35rem !important;
            }
    }

    /* --- Estilo del Globo de Ayuda (Más alto y ancho total) --- */
    .hint-usuario {
        position: absolute;
        /* 🔥 Ocupa todo el ancho disponible */
        left: 0;
        right: 0;
        width: auto;
        background: #10b981;
        color: white;
        /* 🔥 Aumenta el primer número (40px) para hacerlo más alto (largo vertical) */
        padding: 40px 20px;
        border-radius: 15px;
        font-weight: 700;
        font-size: 1.2rem; /* Letra un poco más grande para que no se vea vacío */
        z-index: 100;
        text-align: center;
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.4);
        pointer-events: none;
    }

        /* La flechita apuntando hacia ARRIBA */
        .hint-usuario::after {
            content: "";
            position: absolute;
            top: -10px; /* Se queda pegada arriba */
            left: 50%;
            transform: translateX(-50%);
            border-width: 0 10px 10px 10px;
            border-style: solid;
            border-color: transparent transparent #10b981 transparent;
        }


    /* ==================================================================
               💥 PARCHE PREMIUM: TARJETAS IMPONENTES (MÁS GRANDES Y EN 3 COLUMNAS) 💥
               ================================================================== */

    /* 1. Forzamos a que salgan 3 productos por fila en PC (en vez de 4).
               Al haber menos columnas, ¡todo el bloque se estira hacia los lados! */
    @@media (min-width: 992px) {
        #contenedorAccesorios > div

    {
        flex: 0 0 33.3333% !important;
        max-width: 33.3333% !important;
    }

    }

    #contenedorAccesorios > div {
        max-width: 440px !important;
        margin-left: auto !important;
        margin-right: auto !important;
    }

    /* 3. TUBO CARD: Imagen gigante y presencia imponente */
    .tubo-card {
        min-height: 450px !important; /* Más alta para contener la imagen */
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.06) !important;
        padding: 2rem !important; /* Más espacio interno */
    }

        .tubo-card img {
            height: 260px !important; /* ¡Casi el doble de tamaño! */
            margin-bottom: 1.5rem !important;
        }

        .tubo-card b {
            font-size: 1.1rem !important; /* Texto un toque más maduro y grueso */
            font-weight: 800 !important;
        }

    /* 4. ACCESORIO CARD: Destacamos el producto al máximo */
    .accesorio-card {
        min-height: 390px !important;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.06) !important;
        padding: 1.8rem !important;
    }

        .accesorio-card img {
            height: 180px !important; /* De 70px saltamos a 180px de puro producto */
            margin-bottom: 1.2rem !important;
        }

        .accesorio-card b {
            font-size: 1rem !important;
            font-weight: 800 !important;
        }

        .accesorio-card .precio {
            font-size: 1.1rem !important;
            font-weight: 800 !important;
            color: #16a34a !important; /* Resaltamos el precio en verde marca */
        }

</style>

<div id="zonaCotizacion">

    <div id="headerCotizacion" class="container-fluid px-0 mb-4">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">

            <!-- PARTE IZQUIERDA: BOTÓN + TÍTULO (Se queda SIEMPRE visible) -->
            <div class="d-flex align-items-center gap-3">
                <a href="javascript:void(0);"
                   class="btn btn-outline-light d-flex align-items-center justify-content-center back-button"
                   onclick="UI.abrirModalSalir()">

                    @if (esClienteLogueado)
                    {
                        @* 👤 Si es cliente con cuenta en su intranet *@
                        <span class="d-none d-md-inline">⬅ Volver a mi Intranet</span>
                        <span class="d-inline d-md-none">⬅</span>
                    }
                    else
                    {
                        @* 🕵️‍♂️ Si es un usuario incógnito de la calle *@
                        <span class="d-none d-md-inline">⬅ Volver al inicio</span>
                        <span class="d-inline d-md-none">⬅</span>
                    }

                </a>
                <h2 class="m-0 fw-bold main-title">COTIZADOR</h2>
            </div>

            <!-- PARTE DERECHA: ESTADO (Este es el que desaparecerá) -->
            <div id="contenedorBotonMaterial">
                <button class="btn btn-outline-light fw-semibold material-badge"
                        id="btnMaterial"
                        onclick="abrirModalMaterial()">
                    <span class="d-none d-sm-inline">TIPO DE TUBO:</span> <span id="lblMaterial">ALUMINIO</span>
                </button>
            </div>
        </div>
    </div>
    <!-- ================= BARRA DE PROGRESO (4 PASOS) ================= -->
    <div class="wizard-progress mb-5">
        <div class="wizard-step active" data-step="1">
            <div class="step-circle">1</div>
            <div class="step-label">Tubo</div>
        </div>
        <div class="wizard-line"></div>
        <div class="wizard-step" data-step="2">
            <div class="step-circle">2</div>
            <div class="step-label">Medida</div>
        </div>
        <div class="wizard-line"></div>
        <div class="wizard-step" data-step="3">
            <div class="step-circle">3</div>
            <div class="step-label">Accesorios</div>
        </div>
        <div class="wizard-line"></div>
        <div class="wizard-step" data-step="4">
            <div class="step-circle">4</div>
            <div class="step-label">Resultado</div>
        </div>
    </div>

    <!-- ================= PASO 1: SELECCIÓN DE PRODUCTO ================= -->
    <!-- ================= PASO 1: SELECCIÓN DE PRODUCTO ================= -->
    <div id="paso1" class="card mb-4 p-4">
        <h5 class="mb-4">1️⃣ Elige el tubo y su dimensión</h5>

        <!-- Aquí nacen las tarjetas por JS -->
        <div class="row g-4 js-product-master-container align-items-center" id="contenedorTubos">
        </div>

        <!-- ⚓ BARRA FIJA INFERIOR EXCLUSIVA DEL PASO 1 -->
        <div id="barraStickyPaso1" class="sticky-action-container">
            <div class="row m-0 justify-content-end">
                <div class="col-12 col-md-4 p-0" id="columnaBotonConfirmarMaster">
                    <!-- JavaScript mudará el botón con sus superpoderes aquí adentro -->
                </div>
            </div>
        </div>
    </div>


    <div class="card mb-4 p-4 d-none" id="bloqueMedidas">

        <h5 class="mb-3">2️⃣ Define la medida total</h5>

        <div id="grupoLargo">

            <div class="row g-4 justify-content-center">

                <!-- CONTROLES DE METROS -->
                <div class="col-6 col-md-4">
                    <label class="d-block text-center small fw-bold text-muted text-uppercase mb-2" style="letter-spacing: 1px;">Metros</label>
                    <div class="d-flex align-items-center justify-content-center gap-3">
                        <button type="button" class="medida-control-btn btn-minus" onclick="window.iniciarCambioContinuo(event, window.cambiarMetro, -1)">
                            −
                        </button>

                        <input id="metrosInput" type="number" readonly class="medida-input-clean" value="1">

                        <button type="button" class="medida-control-btn btn-plus" onclick="window.iniciarCambioContinuo(event, window.cambiarMetro, 1)">
                            +
                        </button>
                    </div>
                </div>

                <!-- CONTROLES DE CENTÍMETROS -->
                <div class="col-6 col-md-4">
                    <label class="d-block text-center small fw-bold text-muted text-uppercase mb-2" style="letter-spacing: 1px;">Centímetros</label>
                    <div class="d-flex align-items-center justify-content-center gap-3">
                        <button type="button" class="medida-control-btn btn-minus" onclick="window.iniciarCambioContinuo(event, window.cambiarCm, -1)">
                            −
                        </button>

                        <input id="cmInput" type="number" readonly class="medida-input-clean" value="0">

                        <button type="button" class="medida-control-btn btn-plus" onclick="window.iniciarCambioContinuo(event, window.cambiarCm, 1)">
                            +
                        </button>
                    </div>
                </div>

            </div>

            <div class="mt-4" id="grupoVisual">
                <div class="tubo-visual-wrapper" id="progressBarContainer" style="cursor: pointer; position: relative;">
                    <div id="tuboVisual" class="tubo-visual" style="width: 20%;"></div>
                </div>

                <div class="text-center mt-3">
                    <span class="d-block small text-muted text-uppercase fw-bold" style="letter-spacing: 1px;">Medida seleccionada</span>
                    <div class="display-6 fw-bold text-dark">
                        <span id="lblMetros">1.00</span> <small class="text-muted">m</small>
                    </div>
                    <p class="text-muted small">Límite máximo de varilla: <strong>5.95 m</strong></p>
                </div>
            </div>

            <input id="largo" type="hidden" value="1">
        </div>

        <!-- ⚓ BARRA FIJA INFERIOR EXCLUSIVA DEL PASO 2 (MEDIDAS) -->
        <div id="barraStickyMedidas" class="sticky-action-container d-none">
            <div class="row m-0 justify-content-end">
                <div class="col-12 col-md-3 p-0">
                    <button id="btnPaso2" class="btn btn-success w-100 py-2.5 fw-bold text-uppercase shadow-sm" style="border-radius: 12px; font-size: 0.95rem; letter-spacing: 0.5px;">
                        Siguiente: Accesorios <i class="bi bi-arrow-right-short ms-1"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
<!-- ================= PASO 2 ================= -->
<div id="paso2" class="card mb-4 p-4 d-none">
        <h5>3️⃣ Elige los soportes del tubo</h5>

    <!-- ACCESORIOS -->
    <div class="row g-3 mb-4" id="contenedorAccesorios"></div>

        <button type="button" id="btnCarritoFlotante" class="btn-carrito-flotante d-none" onclick="Cotizacion.abrirModalCarritoAccesorios()">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16" style="margin-top: -2px;">
                <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
            </svg>
            <span id="badgeContadorAcc" class="badge bg-danger position-absolute top-0 start-100 translate-middle rounded-pill" style="font-size: 0.75rem; padding: 4px 7px;">0</span>
        </button>

        <div id="panelCarritoAccesorios" class="carrito-sheet-panel">
            <div class="carrito-sheet-container shadow-lg">
                <div class="d-flex align-items-center justify-content-between bg-dark text-white px-4 py-3" style="border-radius: 24px 24px 0 0;">
                    <h5 class="m-0 fw-bold text-white d-flex align-items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#10b981" class="bi bi-list-check me-2" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M5 11.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5m-3 1a1 1 0 1 0 0-2 1 1 0 0 0 0 2m0 4a1 1 0 1 0 0-2 1 1 0 0 0 0 2m0 4a1 1 0 1 0 0-2 1 1 0 0 0 0 2" />
                        </svg>
                        Accesorios Incluidos
                    </h5>
                    <button type="button" class="btn text-white-50 p-1 fs-5 fw-bold" onclick="Cotizacion.cerrarPanelCarritoAccesorios()" style="line-height: 1;">✕</button>
                </div>

                <div class="p-4 bg-light" style="max-height: 380px; overflow-y: auto;">
                    <div id="listaAccesoriosModal" class="small text-muted text-center py-3">
                        Ninguno
                    </div>
                </div>

                <div class="p-3 bg-light border-top text-center" style="border-radius: 0 0 24px 24px;">
                    <button type="button" class="btn btn-secondary w-100 fw-bold py-2.5" style="border-radius: 14px;" onclick="Cotizacion.cerrarPanelCarritoAccesorios()">
                        Continuar editando
                    </button>
                </div>
            </div>
        </div>


        <!-- BOTÓN -->
        <div id="barraStickyAccesorios" class="sticky-action-container d-none">
            <div class="row m-0 justify-content-end">
                <div class="col-12 col-md-3 p-0">
                    <button id="btnCalcular" class="btn btn-primary w-100 py-2.5 fw-bold text-uppercase shadow-sm" style="background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); border: none; border-radius: 12px; font-size: 0.95rem; letter-spacing: 0.5px;">
                        Ver Cotización Final <i class="bi bi-check-circle ms-1"></i>
                    </button>
                </div>
            </div>
        </div>
</div>
</div> <!-- FIN zonaCotizacion -->

<!-- ================= RESULTADO ================= -->
<div id="resultadoHtml" class="d-none">
    <div class="ticket-container">
        <!-- Encabezado del Ticket -->
        <div class="ticket-header text-center">
            <div class="ticket-icon">✅</div>
            <h4>Cotización Final</h4>
            <p class="text-muted small">E&E Aluminios - Detalle de pedido</p>
        </div>

        <!-- Cuerpo: Fila principal (Tubo + Accesorios) -->
        <div class="ticket-body">
            <div class="item-main d-flex align-items-center gap-3 mb-4">
                <div class="item-img-wrapper">
                    <img id="resTuboImg" src="">
                </div>
                <div class="item-info">
                    <h5 id="resTuboDesc" class="m-0 text-white"></h5>
                    <span id="resTuboDim" class="badge bg-primary-subtle text-primary"></span>
                    <div id="resResumenTubo" class="small text-white-50 mt-1"></div>
                </div>
            </div>

            <div class="separator-dots"></div>

            <!-- Lista de Accesorios -->
            <div class="section-title mt-3">Accesorios</div>
            <div id="resAccesorios" class="res-accesorios-list">
                <!-- Se inyectan aquí -->
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4 px-3 py-3 rounded-4" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);">
            <div>
                <span class="text-white-50 small text-uppercase fw-bold" style="letter-spacing: 1px; font-size: 0.7rem;">¿Cuántos combos iguales?</span>
                <div class="text-white-50 small" style="font-size: 0.65rem;">Se multiplicará todo el diseño.</div>
            </div>
            <div class="d-flex align-items-center gap-3 bg-dark rounded-pill px-2 py-1" style="border: 1px solid #334155;">
                <button type="button" class="btn btn-sm text-white fs-4 lh-1 p-0" style="width:30px;" onclick="window.iniciarCambioContinuo(event, window.cambiarPiezasTicket, -1)">
                    −
                </button>

                <input id="piezas" type="number" readonly value="1"
                       style="width: 35px; background: transparent; border: none; color: white; text-align: center; font-weight: 800; font-size: 1.2rem; outline: none;">

                <button type="button" class="btn btn-sm text-success fs-4 lh-1 p-0" style="width:30px;" onclick="window.iniciarCambioContinuo(event, window.cambiarPiezasTicket, 1)">
                    +
                </button>
            </div>
        </div>

        <!-- Total con diseño de cinta -->
        <div class="ticket-footer mt-4 mb-4">
            <div class="total-ribbon">
                <span>TOTAL A PAGAR</span>
                <strong id="resTotal"></strong>
            </div>
        </div>

        <div class="action-buttons">
            <button id="btnReservar" class="btn w-100 fw-bold mb-3 py-3 shadow-lg" style="background-color: #fbbf24; color: #000; font-size: 1.1rem; border-radius: 12px;">
                📌 RESERVAR PEDIDO
            </button>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-light flex-fill py-2 rounded-3 text-white-50" style="border-color: #334155;" onclick="nuevaCotizacion()">
                    <i class="bi bi-arrow-repeat me-1"></i> Nueva
                </button>

                @if (Context.Session.GetInt32("USER_ID") != null)
                {
                    @* 👤 Si es cliente logueado, lo regresa con estilo a su Suite Privada (Intranet) *@
                    <a asp-controller="Cliente" asp-action="WebPrincipal" class="btn btn-outline-light flex-fill py-2 rounded-3 text-white fw-bold" style="border-color: #0284c7 !important; background: rgba(2, 132, 199, 0.1);">
                        <i class="bi bi-sidebar-reversed me-1"></i> Mi Intranet
                    </a>
                }
                else
                {
                    @* 🕵️‍♂️ Si es usuario incógnito, lo manda al Home público tradicional (Inicio) *@
                    <a href="/" class="btn btn-outline-light flex-fill py-2 rounded-3 text-white-50" style="border-color: #334155;">
                        <i class="bi bi-arrow-left me-1"></i> Inicio
                    </a>
                }
            </div>
        </div>

