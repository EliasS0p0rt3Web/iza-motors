@using Microsoft.AspNetCore.Http

@{
    var nombreUsuario =
        Context.Session.GetString("USER_NAME")
        ?? Context.Session.GetString("USER")
        ?? "Cliente";

    var inicialUsuario = string.IsNullOrWhiteSpace(nombreUsuario)
        ? "C"
        : nombreUsuario.Substring(0, 1).ToUpper();
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Iza Motors</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />

    @RenderSection("Styles", required: false)

    <style>
        :root {
            --iza-red: #c8102e;
            --iza-red-dark: #980f24;
            --iza-red-soft: #fff1f3;
            --iza-white: #ffffff;
            --iza-background: #f7f8fa;
            --iza-border: #e5e7eb;
            --iza-text: #172033;
            --iza-muted: #64748b;
        }

        * {
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
            color: var(--iza-text);
            background: var(--iza-background);
            font-family: "Inter", "Segoe UI", system-ui, sans-serif;
        }

        /* =========================
                   MENÚ LATERAL
                ========================== */

        .sidebar {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 1040;
            width: 260px;
            display: flex;
            flex-direction: column;
            background: var(--iza-white);
            border-right: 1px solid var(--iza-border);
            box-shadow: 5px 0 25px rgba(23, 32, 51, 0.05);
            transition: all 0.3s ease;
        }

        .sidebar-brand {
            height: 76px;
            padding: 18px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid var(--iza-border);
        }

        .brand-content {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand-icon {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--iza-white);
            background: var(--iza-red);
            border-radius: 12px;
            font-size: 1.35rem;
        }

        .brand-name {
            color: var(--iza-text);
            font-size: 0.95rem;
            font-weight: 800;
            letter-spacing: 0.4px;
            text-transform: uppercase;
        }

        .brand-subtitle {
            color: var(--iza-muted);
            font-size: 0.7rem;
        }

        .menu-toggle-pc {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--iza-red);
            background: var(--iza-red-soft);
            border: none;
            border-radius: 9px;
            transition: 0.2s ease;
        }

            .menu-toggle-pc:hover {
                color: var(--iza-white);
                background: var(--iza-red);
            }

        .sidebar-menu {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 7px;
            padding: 20px 12px;
            margin: 0;
            list-style: none;
        }

        .menu-link {
            min-height: 46px;
            padding: 11px 14px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--iza-muted);
            border-radius: 12px;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 650;
            transition: all 0.2s ease;
        }

            .menu-link i {
                min-width: 22px;
                text-align: center;
                font-size: 1.15rem;
            }

            .menu-link:hover {
                color: var(--iza-red);
                background: var(--iza-red-soft);
            }

            .menu-link.active {
                color: var(--iza-white);
                background: var(--iza-red);
                box-shadow: 0 7px 18px rgba(200, 16, 46, 0.22);
            }

        /* Mi perfil todavía no disponible */
        .menu-link-disabled {
            cursor: not-allowed;
            opacity: 0.62;
        }

            .menu-link-disabled:hover {
                color: var(--iza-muted);
                background: #f8fafc;
            }

        .badge-proximamente {
            margin-left: auto;
            padding: 3px 7px;
            color: var(--iza-red);
            background: var(--iza-red-soft);
            border-radius: 20px;
            font-size: 0.58rem;
            font-weight: 800;
            text-transform: uppercase;
        }

        /* =========================
                   DATOS DEL CLIENTE
                ========================== */

        .sidebar-footer {
            padding: 14px 12px;
            border-top: 1px solid var(--iza-border);
        }

        .user-card {
            padding: 12px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            background: #fafafa;
            border: 1px solid var(--iza-border);
            border-radius: 14px;
        }

        .user-header {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 38px;
            height: 38px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--iza-white);
            background: var(--iza-red);
            border-radius: 50%;
            font-size: 0.9rem;
            font-weight: 800;
        }

        .user-details {
            min-width: 0;
            flex-grow: 1;
        }

        .user-name {
            overflow: hidden;
            color: var(--iza-text);
            font-size: 0.84rem;
            font-weight: 750;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .user-role {
            color: var(--iza-muted);
            font-size: 0.68rem;
        }

        .btn-logout {
            width: 100%;
            padding: 9px 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            color: var(--iza-red);
            background: var(--iza-white);
            border: 1px solid #fecdd3;
            border-radius: 10px;
            font-size: 0.8rem;
            font-weight: 700;
            transition: all 0.2s ease;
        }

            .btn-logout:hover {
                color: var(--iza-white);
                background: var(--iza-red);
                border-color: var(--iza-red);
            }

        /* =========================
                   CONTENIDO PRINCIPAL
                ========================== */

        .main-content {
            min-height: 100vh;
            margin-left: 260px;
            background: var(--iza-background);
            transition: margin-left 0.3s ease;
        }

        /* =========================
                   MENÚ REDUCIDO EN PC
                ========================== */

        @@media (min-width: 993px) {
            .sidebar.collapsed {
                width: 82px;
            }

                .sidebar.collapsed .sidebar-brand {
                    justify-content: center;
                    padding: 14px 8px;
                }

                .sidebar.collapsed .brand-text,
                .sidebar.collapsed .menu-link span,
                .sidebar.collapsed .badge-proximamente,
                .sidebar.collapsed .user-details,
                .sidebar.collapsed .btn-logout span {
                    display: none;
                }

                .sidebar.collapsed .menu-toggle-pc {
                    position: absolute;
                    top: 22px;
                    right: -14px;
                    border: 1px solid var(--iza-border);
                    background: var(--iza-white);
                }

                .sidebar.collapsed .sidebar-menu {
                    padding: 20px 9px;
                }

                .sidebar.collapsed .menu-link {
                    justify-content: center;
                    padding: 12px;
                    gap: 0;
                }

                    .sidebar.collapsed .menu-link i {
                        min-width: auto;
                    }

                .sidebar.collapsed .user-card {
                    align-items: center;
                    padding: 10px 7px;
                }

                .sidebar.collapsed .user-header {
                    justify-content: center;
                }

                .sidebar.collapsed .btn-logout {
                    width: 42px;
                    height: 40px;
                    padding: 0;
                }

                .sidebar.collapsed + .main-content {
                    margin-left: 82px;
                }
        }

        /* =========================
                   NAVEGACIÓN MÓVIL
                ========================== */

        .mobile-bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            z-index: 1050;
            width: 100%;
            height: 68px;
            display: flex;
            background: var(--iza-white);
            border-top: 1px solid var(--iza-border);
            box-shadow: 0 -5px 20px rgba(23, 32, 51, 0.08);
        }

        .nav-mobile-item {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 3px;
            color: var(--iza-muted);
            background: transparent;
            border: none;
            text-decoration: none;
            font-size: 0.66rem;
            font-weight: 650;
        }

            .nav-mobile-item i {
                font-size: 1.25rem;
            }

            .nav-mobile-item:hover,
            .nav-mobile-item.active {
                color: var(--iza-red);
            }

        .sidebar-overlay {
            position: fixed;
            inset: 0;
            z-index: 1035;
            display: none;
            background: rgba(15, 23, 42, 0.42);
        }

            .sidebar-overlay.show {
                display: block;
            }

        @@media (max-width: 992px) {
            body {
                padding-bottom: 68px;
            }

            .sidebar {
                transform: translateX(-100%);
            }

                .sidebar.open {
                    transform: translateX(0);
                }

            .main-content {
                margin-left: 0;
            }
        }

        /* =========================
                   MODAL
                ========================== */

        .logout-modal-content {
            background: var(--iza-white);
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 55px rgba(23, 32, 51, 0.18);
        }

        .logout-modal-icon {
            width: 58px;
            height: 58px;
            margin: 0 auto 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--iza-red);
            background: var(--iza-red-soft);
            border-radius: 50%;
            font-size: 1.55rem;
        }
    </style>
</head>

<body>

    <!-- MENÚ LATERAL -->
    <aside class="sidebar" id="sidebar">

        <div class="sidebar-brand">

            <div class="brand-content">

                <div class="brand-icon">
                    <i class="bi bi-car-front-fill"></i>
                </div>

                <div class="brand-text">
                    <div class="brand-name">Iza Motors</div>
                    <div class="brand-subtitle">Panel del cliente</div>
                </div>

            </div>

            <button type="button"
                    class="menu-toggle-pc d-none d-lg-flex"
                    id="menuTogglePc"
                    aria-label="Reducir menú">

                <i class="bi bi-chevron-left"></i>
            </button>

        </div>

        <ul class="sidebar-menu">

            <!-- INICIO -->
            <li>
                <a href="@Url.Action("WebPrincipal", "Cliente")"
                   class="menu-link"
                   id="linkInicio">

                    <i class="bi bi-house-door-fill"></i>
                    <span>Inicio</span>
                </a>
            </li>

            <!-- CATÁLOGO -->
            <li>
                <a href="@Url.Action("Index", "ProductoPublic")"
                   class="menu-link"
                   id="linkCatalogo">

                    <i class="bi bi-tools"></i>
                    <span>Catálogo de repuestos</span>
                </a>
            </li>

            <!-- SERVICIOS -->
            <li>
                <a href="@Url.Action("MisPedidos", "Cliente")"
                   class="menu-link"
                   id="linkServicios">

                    <i class="bi bi-wrench-adjustable-circle-fill"></i>
                    <span>Mis servicios</span>
                </a>
            </li>

            <!-- PERFIL NO DISPONIBLE -->
            <li>
                <div class="menu-link menu-link-disabled"
                     title="Funcionalidad próximamente disponible">

                    <i class="bi bi-person-gear"></i>

                    <span>Mi perfil</span>

                    <small class="badge-proximamente">
                        Próximamente
                    </small>
                </div>
            </li>

        </ul>

        <!-- USUARIO Y CIERRE DE SESIÓN -->
        <div class="sidebar-footer">

            <div class="user-card">

                <div class="user-header">

                    <div class="user-avatar">
                        @inicialUsuario
                    </div>

                    <div class="user-details">

                        <div class="user-name"
                             title="@nombreUsuario">
                            @nombreUsuario
                        </div>

                        <div class="user-role">
                            Cliente de Iza Motors
                        </div>

                    </div>
                </div>

                <button type="button"
                        class="btn-logout"
                        data-bs-toggle="modal"
                        data-bs-target="#logoutModal">

                    <i class="bi bi-box-arrow-left"></i>
                    <span>Cerrar sesión</span>
                </button>

            </div>
        </div>

    </aside>

    <div id="sidebarOverlay"
         class="sidebar-overlay">
    </div>

    <!-- CONTENIDO -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- NAVEGACIÓN INFERIOR MÓVIL -->
    <nav class="mobile-bottom-nav d-lg-none">

        <a href="@Url.Action("WebPrincipal", "Cliente")"
           class="nav-mobile-item"
           id="btnMovilInicio">

            <i class="bi bi-house-door-fill"></i>
            <span>Inicio</span>
        </a>

        <a href="@Url.Action("Index", "ProductoPublic")"
           class="nav-mobile-item"
           id="btnMovilCatalogo">

            <i class="bi bi-tools"></i>
            <span>Catálogo</span>
        </a>

        <a href="@Url.Action("MisPedidos", "Cliente")"
           class="nav-mobile-item"
           id="btnMovilServicios">

            <i class="bi bi-wrench-adjustable"></i>
            <span>Servicios</span>
        </a>

        <button type="button"
                class="nav-mobile-item"
                id="menuToggleMobile">

            <i class="bi bi-list"></i>
            <span>Menú</span>
        </button>

        <button type="button"
                class="nav-mobile-item"
                data-bs-toggle="modal"
                data-bs-target="#logoutModal">

            <i class="bi bi-box-arrow-right"></i>
            <span>Salir</span>
        </button>

    </nav>

    <!-- MODAL CERRAR SESIÓN -->
    <div class="modal fade"
         id="logoutModal"
         tabindex="-1"
         aria-labelledby="logoutModalLabel"
         aria-hidden="true">

        <div class="modal-dialog modal-dialog-centered"
             style="max-width: 390px;">

            <div class="modal-content logout-modal-content">

                <div class="modal-body text-center p-4">

                    <div class="logout-modal-icon">
                        <i class="bi bi-box-arrow-right"></i>
                    </div>

                    <h5 id="logoutModalLabel"
                        class="fw-bold mb-2"
                        style="color: var(--iza-text);">
                        ¿Cerrar sesión?
                    </h5>

                    <p class="mb-4"
                       style="color: var(--iza-muted);
                              font-size: 0.9rem;">
                        Tendrás que volver a ingresar tus datos para acceder al panel.
                    </p>

                    <div class="d-flex gap-2">

                        <button type="button"
                                class="btn btn-light w-50 py-2 fw-semibold"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>

                        <a href="@Url.Action("Logout", "Login")"
                           class="btn w-50 py-2 fw-semibold text-white"
                           style="background: var(--iza-red);
                                  border: none;">
                            Sí, salir
                        </a>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

    <script>
        const sidebar =
            document.getElementById("sidebar");

        const sidebarOverlay =
            document.getElementById("sidebarOverlay");

        const menuTogglePc =
            document.getElementById("menuTogglePc");

        const menuToggleMobile =
            document.getElementById("menuToggleMobile");

        const mobileMenuIcon =
            menuToggleMobile
                ? menuToggleMobile.querySelector("i")
                : null;

        // Reducir menú en escritorio
        if (menuTogglePc) {
            menuTogglePc.addEventListener("click", function () {
                sidebar.classList.toggle("collapsed");

                const icono =
                    menuTogglePc.querySelector("i");

                if (sidebar.classList.contains("collapsed")) {
                    icono.classList.replace(
                        "bi-chevron-left",
                        "bi-chevron-right"
                    );
                }
                else {
                    icono.classList.replace(
                        "bi-chevron-right",
                        "bi-chevron-left"
                    );
                }
            });
        }

        // Abrir menú en celular
        if (menuToggleMobile) {
            menuToggleMobile.addEventListener("click", function () {
                sidebar.classList.toggle("open");
                sidebarOverlay.classList.toggle("show");

                if (sidebar.classList.contains("open")) {
                    mobileMenuIcon.classList.replace(
                        "bi-list",
                        "bi-x-lg"
                    );
                }
                else {
                    mobileMenuIcon.classList.replace(
                        "bi-x-lg",
                        "bi-list"
                    );
                }
            });
        }

        // Cerrar menú móvil al tocar el fondo
        sidebarOverlay.addEventListener("click", function () {
            sidebar.classList.remove("open");
            sidebarOverlay.classList.remove("show");

            mobileMenuIcon?.classList.replace(
                "bi-x-lg",
                "bi-list"
            );
        });

        // Marcar ruta activa
        const currentUrl =
            window.location.pathname.toLowerCase();

        if (currentUrl.includes("webprincipal")) {
            document
                .getElementById("linkInicio")
                ?.classList.add("active");

            document
                .getElementById("btnMovilInicio")
                ?.classList.add("active");
        }
        else if (
            currentUrl.includes("productopublic")
        ) {
            document
                .getElementById("linkCatalogo")
                ?.classList.add("active");

            document
                .getElementById("btnMovilCatalogo")
                ?.classList.add("active");
        }
        else if (
            currentUrl.includes("mispedidos") ||
            currentUrl.includes("verpedido")
        ) {
            document
                .getElementById("linkServicios")
                ?.classList.add("active");

            document
                .getElementById("btnMovilServicios")
                ?.classList.add("active");
        }
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>