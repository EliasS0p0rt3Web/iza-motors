@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E&E Aluminios</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
        }

        body {
            background-color: #0f172a;
            color: #f1f5f9;
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* --- SIDEBAR (ESTRUCTURA PREMIUM ADAPTATIVA) --- */
        .sidebar {
            width: 260px;
            background-color: #1e293b;
            border-right: 1px solid rgba(255, 255, 255, 0.08);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 1040;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Cabecera del menú */
        .sidebar-brand {
            padding: 24px;
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 0.05em;
            color: #ffffff;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            text-transform: uppercase;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 73px;
        }

        /* Botón de control de tamaño en PC */
        .menu-toggle-pc {
            background: rgba(255, 255, 255, 0.05);
            color: #94a3b8;
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .menu-toggle-pc:hover {
                background: #3b82f6;
                color: white;
                border-color: #3b82f6;
            }

        /* Lista del menú */
        .sidebar-menu {
            list-style: none;
            padding: 20px 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex-grow: 1;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: #94a3b8;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            border-radius: 10px;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

            .menu-link i {
                font-size: 18px;
                min-width: 20px;
                text-align: center;
            }

            .menu-link:hover {
                color: #ffffff;
                background: rgba(255, 255, 255, 0.05);
            }

            .menu-link.active {
                background: #3b82f6;
                color: #ffffff;
            }

        /* 📦 NUEVA CAJA DE USUARIO UNIFICADA CON LOGOUT CONTEXTUAL (PC) */
        .sidebar-footer {
            padding: 16px 12px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            background: rgba(15, 23, 42, 0.2);
        }

        .user-logout-card {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 12px;
            padding: 12px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .user-details {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .user-name {
            font-size: 13.5px;
            font-weight: 600;
            color: #ffffff;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-role {
            font-size: 11px;
            color: #38bdf8;
            font-weight: 500;
            margin-top: 2px;
        }

        /* ===== ESTILOS DEL AVATAR MINI PREMIUM ===== */
        .user-avatar-mini {
            width: 34px;
            height: 34px;
            background: #3b82f6;
            color: #ffffff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 14px;
            flex-shrink: 0; /* Evita que se deforme si el texto es largo */
            box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);
        }

        /* Lógica para cuando el Sidebar se reduce en PC */
        @@media (min-width: 993px) {
            .sidebar.collapsed .user-card-header {
                justify-content: center;
                width: 100%;
            }

            .sidebar.collapsed .user-avatar-mini {
                width: 38px; /* Crece un pelín para verse imponente solo como icono */
                height: 38px;
                font-size: 15px;
            }
        }

        .btn-sidebar-logout {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 8px 12px;
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.15);
            color: #f87171;
            font-size: 13px;
            font-weight: 600;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .btn-sidebar-logout:hover {
                background: #ef4444;
                color: #ffffff;
                border-color: #ef4444;
            }

        /* --- CONTENIDO PRINCIPAL --- */
        .main-content {
            margin-left: 260px;
            flex-grow: 1;
            padding: 0;
            min-height: 100vh;
            background-image: radial-gradient(at 0% 0%, rgba(30, 58, 138, 0.15) 0px, transparent 50%);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* ========================================================================= */
        /* 🔥 LÓGICA DE INTERFAZ MINI-SIDEBAR (CUANDO SE COLAXA EN PC)               */
        /* ========================================================================= */
        @@media (min-width: 993px) {
            .sidebar.collapsed {
                width: 80px;
            }
                /* Esconde el texto de la marca, dejando espacio para centrar el botón */
                .sidebar.collapsed .sidebar-brand {
                    justify-content: center;
                    padding: 16px;
                }

                    .sidebar.collapsed .sidebar-brand span {
                        display: none;
                    }
                /* Esconde los textos del menú, dejando solo los logotipos */
                .sidebar.collapsed .sidebar-menu {
                    padding: 20px 8px;
                }

                .sidebar.collapsed .menu-link {
                    justify-content: center;
                    padding: 12px;
                    gap: 0;
                }

                    .sidebar.collapsed .menu-link span {
                        display: none;
                    }
                /* Compactación radical de la tarjeta de usuario al modo icono */
                .sidebar.collapsed .user-details {
                    display: none;
                }

                .sidebar.collapsed .btn-sidebar-logout span {
                    display: none;
                }

                .sidebar.collapsed .btn-sidebar-logout {
                    padding: 10px;
                }
                /* El contenido se auto-ajusta al tamaño del mini menú */
                .sidebar.collapsed + .main-content {
                    margin-left: 80px;
                }
        }

        /* --- BOTOM NAV RESPONSIVE FIJO PARA CELULARES --- */
        .mobile-bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 68px;
            background: #0f172a;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            z-index: 1050;
            box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.5);
        }

        .nav-item-btn {
            flex: 1;
            background: transparent;
            border: none;
            color: #94a3b8;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 2px;
            font-size: 11px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s ease;
        }

            .nav-item-btn i {
                font-size: 22px;
                line-height: 1;
            }

            .nav-item-btn:hover, .nav-item-btn.active {
                color: #3b82f6;
            }

            .nav-item-btn.text-danger:hover {
                color: #ef4444 !important;
            }

        /* --- CONFIGURACIONES MÓVILES (DISPOSITIVOS MEDIANOS Y CHICOS) --- */
        @@media (max-width: 992px) {
            body {
                padding-bottom: 68px; /* Evita que el bottom-nav tape información útil */
            }

            .sidebar {
                transform: translateX(-100%); /* Arranca escondido en móviles */
            }

                .sidebar.open {
                    transform: translateX(0); /* Despliega flotando en celulares */
                }

            .main-content {
                margin-left: 0 !important;
            }
        }
    </style>
</head>
<body>

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <span>E&E Aluminios</span>
            <button class="menu-toggle-pc d-none d-lg-block" id="menuTogglePc">
                <i class="bi bi-chevron-left"></i>
            </button>
        </div>

        <ul class="sidebar-menu">
            <li>
                <a href="@Url.Action("WebPrincipal", "Cliente")" class="menu-link" id="linkWeb">
                    <i class="bi bi-house"></i>
                    <span>Panel principal</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("MiPerfil", "Cliente")" class="menu-link" id="linkPerfil">
                    <i class="bi bi-person-gear"></i>
                    <span>Mi Perfil</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("MisPedidos", "Cliente")" class="menu-link" id="linkPedidos">
                    <i class="bi bi-box-seam"></i>
                    <span>Mis Pedidos</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">
            <div class="user-logout-card">
                <div class="d-flex align-items-center gap-2 user-card-header">
                    <div class="user-avatar-mini">
                        @(Context.Session.GetString("USER_NAME")?.Substring(0, 1).ToUpper() ?? "U")
                    </div>
                    <div class="user-details">
                        <div class="user-name" title="@Context.Session.GetString("USER_NAME")">
                            @Context.Session.GetString("USER_NAME")
                        </div>
                        <div class="user-role">Panel de Cliente</div>
                    </div>
                </div>

                <button type="button" class="btn-sidebar-logout" data-bs-toggle="modal" data-bs-target="#logoutModal">
                    <i class="bi bi-box-arrow-left"></i>
                    <span>Cerrar Sesión</span>
                </button>
            </div>
        </div>
    </aside>

    <main class="main-content">
        @RenderBody()
    </main>

    <div class="mobile-bottom-nav d-flex d-lg-none">
        <a href="@Url.Action("MisPedidos", "Cliente")" class="nav-item-btn" id="btnMovilPedidos">
            <i class="bi bi-box-seam"></i>
            <span>Pedidos</span>
        </a>

        <button type="button" class="nav-item-btn" id="menuToggleMobile">
            <i class="bi bi-list"></i>
            <span>Menú</span>
        </button>

        <button type="button" class="nav-item-btn text-danger" data-bs-toggle="modal" data-bs-target="#logoutModal">
            <i class="bi bi-box-arrow-right"></i>
            <span>Salir</span>
        </button>
    </div>

    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 380px;">
            <div class="modal-content" style="background-color: #1e293b; border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px;">
                <div class="modal-body text-center p-4">
                    <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width: 56px; height: 56px; background: rgba(239, 68, 68, 0.1); border-radius: 50%; color: #ef4444; font-size: 24px;">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <h5 class="modal-title text-white fw-bold mb-2" id="logoutModalLabel">¿Cerrar Sesión?</h5>
                    <p style="color: #94a3b8; font-size: 14px; margin-bottom: 24px;">¿Estás seguro de que deseas salir del sistema? Tendrás que volver a ingresar tus credenciales.</p>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn w-50 p-2.5 fw-semibold text-white" data-bs-dismiss="modal" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 10px; font-size: 14px;">
                            Cancelar
                        </button>
                        <a href="@Url.Action("Logout", "Login")" class="btn w-50 p-2.5 fw-semibold text-white" style="background: #ef4444; border: none; border-radius: 10px; font-size: 14px; text-decoration: none; display: flex; align-items: center; justify-content: center;">
                            Sí, Salir
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.querySelector('.main-content');

        const menuTogglePc = document.getElementById('menuTogglePc');
        const menuToggleMobile = document.getElementById('menuToggleMobile');
        const mobileMenuIcon = menuToggleMobile ? menuToggleMobile.querySelector('i') : null;

        // 💻 INTERACCIÓN PC: Colapso a modo Mini-Iconos
        if (menuTogglePc) {
            menuTogglePc.addEventListener('click', () => {
                sidebar.classList.toggle('collapsed');

                const pcIcon = menuTogglePc.querySelector('i');
                if (sidebar.classList.contains('collapsed')) {
                    pcIcon.classList.replace('bi-chevron-left', 'bi-chevron-right');
                } else {
                    pcIcon.classList.replace('bi-chevron-right', 'bi-chevron-left');
                }
            });
        }

        // 📱 INTERACCIÓN MÓVIL: Control de despliegue desde abajo
        if (menuToggleMobile) {
            menuToggleMobile.addEventListener('click', () => {
                sidebar.classList.toggle('open');
                if (sidebar.classList.contains('open')) {
                    mobileMenuIcon.classList.replace('bi-list', 'bi-x-lg');
                    menuToggleMobile.classList.add('active');
                } else {
                    mobileMenuIcon.classList.replace('bi-x-lg', 'bi-list');
                    menuToggleMobile.classList.remove('active');
                }
            });
        }

        // 🗺️ DETECTOR DE URL AUTOMÁTICO PARA FOCOS DE BOTONES
        const currentUrl = window.location.pathname.toLowerCase();

        document.querySelectorAll('.menu-link').forEach(link => link.classList.remove('active'));
        document.querySelectorAll('.nav-item-btn').forEach(btn => btn.classList.remove('active'));

        if (currentUrl.includes("webprincipal")) {
            document.getElementById("linkWeb")?.classList.add("active");
        } else if (currentUrl.includes("miperfil")) {
            document.getElementById("linkPerfil")?.classList.add("active");
        } else if (currentUrl.includes("mispedidos") || currentUrl.includes("verpedido")) {
            document.getElementById("linkPedidos")?.classList.add("active");
            document.getElementById("btnMovilPedidos")?.classList.add("active");
        } else if (currentUrl.includes("miscotizaciones")) {
            document.getElementById("linkCotizaciones")?.classList.add("active");
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>