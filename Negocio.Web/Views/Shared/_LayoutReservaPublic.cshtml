@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E&E Aluminios</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        /* 🚀 RESET TOTAL DE ESPACIOS */
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            display: flex;
            flex-direction: column;
            background-color: #f8fafc;
            color: #111827;
            font-family: "Inter", "Segoe UI", sans-serif;
        }

        /* NAVBAR PREMIUM */
        .navbar-reserva {
            background: rgba(255, 255, 255, 0.96);
            border-bottom: 1px solid #e5e7eb;
            box-shadow: 0 2px 12px rgba(0,0,0,0.05);
            backdrop-filter: blur(10px);
            padding: 0.7rem 0;
            z-index: 1000;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: .55rem;
            text-decoration: none;
            color: #111827;
            font-weight: 700;
            padding: .6rem 1.2rem;
            border-radius: 999px;
            background: #f3f4f6;
            transition: all .25s ease;
            font-size: 0.9rem;
        }

            .btn-back:hover {
                background: #e5e7eb;
                color: #0284c7; /* Azul corporativo pro */
                transform: translateY(-1px);
            }

        /* 🚀 MAIN: SIN MÁRGENES RAROS */
        .main-content {
            flex: 1 0 auto;
            display: flex;
            flex-direction: column;
            padding: 0;
        }

        .footer-reserva {
            flex-shrink: 0;
            background: #ffffff;
            border-top: 1px solid #e5e7eb;
            padding: 1.5rem 0;
            color: #6b7280;
            font-size: .9rem;
            text-align: center;
        }

        .container-fluid-full {
            width: 100%;
            padding: 0;
            margin: 0;
        }
    </style>
</head>
<body>

    @* 🧠 EVALUACIÓN DE SESIÓN DIRECTAMENTE EN EL LAYOUT *@
    @{
        bool esClienteLogueado = Context.Session.GetInt32("USER_ID") != null;
    }

    <header>
        <nav class="navbar navbar-reserva">
            <div class="container-fluid px-4">

                @if (esClienteLogueado)
                {
                    @* 👤 ENRUTAMIENTO SI ES CLIENTE: Lo regresa de forma segura a su suite de intranet *@
                    <a asp-controller="Cliente" asp-action="WebPrincipal" class="btn-back" style="border: 1px solid #bae6fd; background: #f0f9ff; color: #0369a1;">
                        <i class="bi bi-sidebar-reversed"></i>
                        <span>Volver a mi Intranet</span>
                    </a>
                }
                else
                {
                    @* 🕵️‍♂️ ENRUTAMIENTO SI ES INCÓGNITO: Mantiene la ruta pública clásica *@
                    <a href="/" class="btn-back">
                        <i class="bi bi-arrow-left"></i>
                        <span>Volver a Inicio</span>
                    </a>
                }

                @* Badge dinámico adaptable para la marca *@
                <span class="badge rounded-pill bg-light text-dark border px-3 py-2 fw-bold d-none d-md-inline-block" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                    @(esClienteLogueado ? "💼 PANEL PRIVADO" : "SISTEMA DE SEGUIMIENTO")
                </span>
            </div>
        </nav>
    </header>

    <main class="main-content">
        <div class="container-fluid p-0">
            @RenderBody()
        </div>
    </main>

    <footer class="footer-reserva">
        <div class="container">
            &copy; @DateTime.Now.Year - <strong>E&E Aluminios</strong> | Gestión de Reservas
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>