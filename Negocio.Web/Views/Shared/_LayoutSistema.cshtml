@{
    var rol = Context.Session.GetString("ROL");
    var usuario = Context.Session.GetString("USER");

    var inicialUsuario = string.IsNullOrWhiteSpace(usuario)
        ? "A"
        : usuario.Substring(0, 1).ToUpper();
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />

    <!-- Diseño adaptable para celulares -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Iza Motors</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/layouts/layout-admin.css"
          asp-append-version="true" />
</head>

<body>

    <!-- =========================
         MENÚ LATERAL
    ========================== -->
    <div id="sidebar" class="sidebar">

        <button type="button"
                class="toggle-btn"
                onclick="toggleSidebar()">
            ☰
        </button>

        <h4>IZA MOTORS</h4>

        <!-- =========================
             ADMINISTRADOR
        ========================== -->
        @if (rol == "ADMINISTRADOR")
        {
            <!-- INICIO -->
            <a asp-controller="Home"
               asp-action="Admin"
               class="menu-btn">
                <i class="bi bi-house"></i>
                <span>Inicio</span>
            </a>

            <!-- VENTAS -->
            <div class="menu-group">
                <button type="button"
                        class="menu-group-btn"
                        onclick="toggleMenu(this)">

                    <div class="menu-left">
                        <i class="bi bi-cart-check"></i>
                        <span>VENTAS</span>
                    </div>

                    <i class="bi bi-chevron-down chevron"></i>
                </button>

                <div class="menu-group-content">

                    <a asp-controller="Venta"
                       asp-action="Index"
                       class="menu-btn">
                        <i class="bi bi-receipt"></i>
                        Ventas de Repuestos
                    </a>
                </div>
            </div>

            <!-- INVENTARIO -->
            <div class="menu-group">
                <button type="button"
                        class="menu-group-btn"
                        onclick="toggleMenu(this)">

                    <div class="menu-left">
                        <i class="bi bi-box-seam"></i>
                        <span>INVENTARIO</span>
                    </div>

                    <i class="bi bi-chevron-down chevron"></i>
                </button>

                <div class="menu-group-content">

                    <a asp-controller="Producto"
                       asp-action="Index"
                       class="menu-btn">
                        <i class="bi bi-tools"></i>
                        Catálogo de Repuestos
                    </a>

                    <a asp-controller="Stock"
                       asp-action="Index"
                       class="menu-btn">
                        <i class="bi bi-boxes"></i>
                        Stock de Repuestos
                    </a>

                    <a asp-controller="Ingreso"
                       asp-action="Index"
                       class="menu-btn">
                        <i class="bi bi-box-arrow-in-down"></i>
                        Entradas de Repuestos
                    </a>

                    <a asp-controller="CatalogoAdmin"
                       asp-action="ConfigurarImagen"
                       class="menu-btn">
                        <i class="bi bi-image"></i>
                        Imágenes del Catálogo
                    </a>

                </div>
            </div>

            <!-- CITAS Y SERVICIOS -->
            <div class="menu-group">
                <button type="button"
                        class="menu-group-btn"
                        onclick="toggleMenu(this)">

                    <div class="menu-left">
                        <i class="bi bi-calendar-check"></i>
                        <span>CITAS Y SERVICIOS</span>
                    </div>

                    <i class="bi bi-chevron-down chevron"></i>
                </button>

                <div class="menu-group-content">

                    <a asp-controller="Reserva"
                       asp-action="Admin"
                       class="menu-btn">
                        <i class="bi bi-calendar3"></i>
                        Panel de Citas
                    </a>

                </div>
            </div>

            <!-- CLIENTES -->
            <div class="menu-group">
                <button type="button"
                        class="menu-group-btn"
                        onclick="toggleMenu(this)">

                    <div class="menu-left">
                        <i class="bi bi-people-fill"></i>
                        <span>CLIENTES</span>
                    </div>

                    <i class="bi bi-chevron-down chevron"></i>
                </button>

                <div class="menu-group-content">

                    <a asp-controller="Cliente"
                       asp-action="Index"
                       class="menu-btn">
                        <i class="bi bi-person-lines-fill"></i>
                        Listado de Clientes
                    </a>

                </div>
            </div>

            <!-- REPORTES -->
            <div class="menu-group">
                <button type="button"
                        class="menu-group-btn"
                        onclick="toggleMenu(this)">

                    <div class="menu-left">
                        <i class="bi bi-bar-chart-line"></i>
                        <span>REPORTES</span>
                    </div>

                    <i class="bi bi-chevron-down chevron"></i>
                </button>

                <div class="menu-group-content">

                    <a asp-controller="Reporte"
                       asp-action="PorDia"
                       class="menu-btn">
                        <i class="bi bi-calendar-day"></i>
                        Ventas por Día
                    </a>

                    <a asp-controller="Reporte"
                       asp-action="VentasPorProducto"
                       class="menu-btn">
                        <i class="bi bi-graph-up-arrow"></i>
                        Ventas por Repuesto
                    </a>

                </div>
            </div>
        }

        <!-- =========================
             JEFE DE TALLER
        ========================== -->
        @if (rol == "JEFE")
        {
            <!-- INICIO -->
            <a asp-controller="Home"
               asp-action="Jefe"
               class="menu-btn">
                <i class="bi bi-house"></i>
                <span>Inicio</span>
            </a>

            <!-- CITAS Y TALLER -->
            <div class="menu-group">
                <button type="button"
                        class="menu-group-btn"
                        onclick="toggleMenu(this)">

                    <div class="menu-left">
                        <i class="bi bi-wrench-adjustable"></i>
                        <span>CITAS Y TALLER</span>
                    </div>

                    <i class="bi bi-chevron-down chevron"></i>
                </button>

                <div class="menu-group-content">

                    <a asp-controller="Reserva"
                       asp-action="Admin"
                       class="menu-btn">
                        <i class="bi bi-calendar-check"></i>
                        Citas Programadas
                    </a>

                </div>
            </div>

            <!-- REPUESTOS -->
            <div class="menu-group">
                <button type="button"
                        class="menu-group-btn"
                        onclick="toggleMenu(this)">

                    <div class="menu-left">
                        <i class="bi bi-box-seam"></i>
                        <span>REPUESTOS</span>
                    </div>

                    <i class="bi bi-chevron-down chevron"></i>
                </button>

                <div class="menu-group-content">

                    <a asp-controller="Producto"
                       asp-action="Index"
                       class="menu-btn">
                        <i class="bi bi-tools"></i>
                        Catálogo de Repuestos
                    </a>

                    <a asp-controller="Stock"
                       asp-action="Index"
                       class="menu-btn">
                        <i class="bi bi-boxes"></i>
                        Consultar Stock
                    </a>

                </div>
            </div>
        }

        <!-- =========================
             INFORMACIÓN DEL USUARIO
        ========================== -->
        <div class="sidebar-bottom">

            <div class="user-box">
                <div class="user-box-header">

                    <div class="user-avatar-admin">
                        @inicialUsuario
                    </div>

                    <div class="user-details-admin">
                        <div class="user-name"
                             title="@usuario">
                            @usuario
                        </div>

                        <div class="user-role">
                            ROL: @rol
                        </div>
                    </div>

                </div>
            </div>

            <button type="button"
                    class="logout-btn d-flex align-items-center justify-content-center gap-2"
                    data-bs-toggle="modal"
                    data-bs-target="#logoutModal">

                <i class="bi bi-box-arrow-left"></i>
                <span>Cerrar sesión</span>
            </button>

        </div>
    </div>

    <!-- Fondo móvil del sidebar -->
    <div id="sidebarOverlay"
         class="sidebar-overlay"
         onclick="closeSidebar()">
    </div>

    <!-- =========================
         CONTENIDO PRINCIPAL
    ========================== -->
    <div id="content" class="content">
        @RenderBody()
    </div>

    <!-- =========================
         MODAL CERRAR SESIÓN
    ========================== -->
    <div class="modal fade"
         id="logoutModal"
         tabindex="-1"
         aria-labelledby="logoutModalLabel"
         aria-hidden="true">

        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title"
                        id="logoutModalLabel">
                        Cerrar sesión
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Cerrar">
                    </button>
                </div>

                <div class="modal-body">
                    ¿Deseas cerrar la sesión actual?
                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <a asp-controller="Login"
                       asp-action="Logout"
                       class="btn btn-danger">
                        Sí, cerrar sesión
                    </a>

                </div>
            </div>
        </div>
    </div>

    <!-- Bienvenida para el jefe de taller -->
    @if (rol == "JEFE")
    {
        <div id="welcomeOverlay"
             class="welcome-overlay">

            <div class="welcome-card welcome-elegant">
                <div class="welcome-icon">👋</div>
                <h2>Bienvenido, @usuario</h2>
                <p>Todo listo para comenzar</p>
            </div>

        </div>
    }

    <!-- =========================
         NAVEGACIÓN INFERIOR MÓVIL
    ========================== -->
    <div class="mobile-bottom-nav">

        @if (rol == "JEFE")
        {
            <a asp-controller="Home"
               asp-action="Jefe"
               class="nav-item">

                <div class="icon">
                    <i class="bi bi-house"></i>
                </div>

                <span>Inicio</span>
            </a>
        }
        else
        {
            <a asp-controller="Home"
               asp-action="Admin"
               class="nav-item">

                <div class="icon">
                    <i class="bi bi-house"></i>
                </div>

                <span>Inicio</span>
            </a>
        }

        @if (rol == "ADMINISTRADOR")
        {
            <a asp-controller="Venta"
               asp-action="Registrar"
               class="nav-item">

                <div class="icon">
                    <i class="bi bi-plus-circle"></i>
                </div>

                <span>Venta</span>
            </a>
        }

        <a asp-controller="Reserva"
           asp-action="Admin"
           class="nav-item">

            <div class="icon">
                <i class="bi bi-calendar-check"></i>
            </div>

            <span>Citas</span>
        </a>

        <a asp-controller="Stock"
           asp-action="Index"
           class="nav-item">

            <div class="icon">
                <i class="bi bi-boxes"></i>
            </div>

            <span>Stock</span>
        </a>

        <button type="button"
                class="nav-item"
                data-bs-toggle="modal"
                data-bs-target="#logoutModal">

            <div class="icon">
                <i class="bi bi-box-arrow-right"></i>
            </div>

            <span>Salir</span>
        </button>

    </div>

    <!-- =========================
         SCRIPTS
    ========================== -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const overlay = document.getElementById("sidebarOverlay");
            const content = document.getElementById("content");

            if (window.innerWidth <= 768) {
                sidebar.classList.toggle("show");
                overlay.classList.toggle("show");
            } else {
                sidebar.classList.toggle("collapsed");
                content.classList.toggle("collapsed");
            }
        }

        function closeSidebar() {
            const sidebar = document.getElementById("sidebar");
            const overlay = document.getElementById("sidebarOverlay");

            sidebar.classList.remove("show");
            overlay.classList.remove("show");
        }

        function toggleMenu(button) {
            const group = button.closest(".menu-group");

            document.querySelectorAll(".menu-group").forEach(otherGroup => {
                if (otherGroup !== group) {
                    otherGroup.classList.remove("open");
                }
            });

            group.classList.toggle("open");
        }

        document.addEventListener("DOMContentLoaded", function () {
            const currentUrl = window.location.pathname.toLowerCase();

            // Activar enlace correspondiente a la ruta actual
            document.querySelectorAll(".menu-btn").forEach(link => {
                const href = link.getAttribute("href");

                if (!href) {
                    return;
                }

                const normalizedHref = href.toLowerCase();

                if (
                    currentUrl === normalizedHref ||
                    currentUrl.startsWith(normalizedHref + "/")
                ) {
                    link.classList.add("active");

                    const group = link.closest(".menu-group");

                    if (group) {
                        group.classList.add("open");
                        group.classList.add("active");
                    }
                }
            });

            // Activar navegación móvil
            document.querySelectorAll(".mobile-bottom-nav .nav-item")
                .forEach(item => {
                    const href = item.getAttribute("href");

                    if (!href) {
                        return;
                    }

                    if (currentUrl.includes(href.toLowerCase())) {
                        item.classList.add("active");
                    }
                });

            // Mostrar bienvenida una sola vez por sesión
            const welcomeOverlay =
                document.getElementById("welcomeOverlay");

            if (!welcomeOverlay) {
                return;
            }

            if (sessionStorage.getItem("welcomeShown") === "true") {
                welcomeOverlay.remove();
                return;
            }

            sessionStorage.setItem("welcomeShown", "true");

            setTimeout(() => {
                welcomeOverlay.style.animation =
                    "fadeOut 0.5s ease forwards";

                setTimeout(() => welcomeOverlay.remove(), 500);
            }, 3000);
        });
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>