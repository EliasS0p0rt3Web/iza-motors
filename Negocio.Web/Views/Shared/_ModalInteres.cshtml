<div class="modal fade"
     id="modalInteres"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 p-4">

            <div class="modal-body text-center">

                <div class="mb-3">
                    <i class="bi bi-car-front-fill text-danger"
                       style="font-size: 3rem;">
                    </i>
                </div>

                <h3 id="modalTitulo"
                    class="fw-bold mb-3">
                </h3>

                <p class="text-muted mb-4">
                    ¿Deseas solicitar información sobre este servicio para tu vehículo?
                </p>

                <div class="d-grid gap-2">

                    <a id="btnWhatsapp"
                       href="#"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="btn btn-success py-3 rounded-pill fw-bold">

                        <i class="bi bi-whatsapp me-1"></i>
                        Consultar por WhatsApp
                    </a>

                    <button type="button"
                            class="btn btn-light py-3 rounded-pill text-secondary"
                            data-bs-dismiss="modal">

                        Seguir viendo
                    </button>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function abrirModalInteres(titulo) {

        document.getElementById("modalTitulo").innerText = titulo;

        const mensaje = encodeURIComponent(
            "Hola, quisiera recibir información sobre el servicio: " + titulo
        );

        document.getElementById("btnWhatsapp").href =
            "https://wa.me/51921726629?text=" + mensaje;

        const modal = new bootstrap.Modal(
            document.getElementById("modalInteres")
        );

        modal.show();
    }
</script>