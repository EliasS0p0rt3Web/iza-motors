<div class="modal fade" id="modalInteres" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 p-4">
            <div class="modal-body text-center">
                <h3 id="modalTitulo" class="fw-bold mb-3"></h3>

                <p class="text-muted mb-4">¿Te gustaría cotizar un trabajo similar para tu negocio o domicilio?</p>

                <div class="d-grid gap-2">
                    <a id="btnWhatsapp" href="#" target="_blank"
                       class="btn btn-success py-3 rounded-pill fw-bold">
                        <i class="bi bi-whatsapp"></i>  ¡Sí, me interesa!
                    </a>
                    <button type="button" class="btn btn-light py-3 rounded-pill text-secondary"
                            data-bs-dismiss="modal">
                        Solo estoy viendo
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function abrirModalInteres(titulo, imagenUrl) {
        // Actualizamos los textos
        document.getElementById('modalTitulo').innerText = titulo;

        // Configuramos el enlace de WhatsApp (con codificación para que llegue bien)
        const mensaje = encodeURIComponent("Hola, me interesa el trabajo: " + titulo);
        document.getElementById('btnWhatsapp').href = "https://wa.me/51921726629?text=" + mensaje;

        // Abrimos el modal
        new bootstrap.Modal(document.getElementById('modalInteres')).show();
    }
</script>