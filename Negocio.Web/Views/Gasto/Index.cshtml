@using Microsoft.AspNetCore.Mvc.Rendering
@model List<Negocio.Web.Models.Entities.Gasto>

@{
    Layout = "_LayoutSistema";
    ViewData["Title"] = "Listado de Gastos";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

<style>
    /* --- VARIABLES Y BASE --- */
    .gasto-list-container {
        font-family: 'Inter', sans-serif;
        max-width: 98%;
        margin: 0 auto;
    }

    /* --- TARJETAS PREMIUM --- */
    .form-premium-card {
        background: #ffffff;
        border-radius: 24px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 10px 40px rgba(15, 23, 42, 0.03);
        padding: 1.5rem;
    }

    .form-label-pro {
        font-size: 0.85rem;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 0.4rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .input-pro {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 0.6rem 1rem;
        font-size: 0.95rem;
        color: #0f172a;
        font-weight: 600;
        transition: all 0.3s ease;
        background: #f8fafc;
    }

        .input-pro:focus {
            border-color: #0071e3;
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.1);
            outline: none;
        }

    /* --- BOTÓN NUEVO (Estilo Tech) --- */
    .btn-new-pro {
        background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
        color: white !important;
        border: none;
        padding: 10px 24px;
        font-size: 0.95rem;
        font-weight: 800;
        border-radius: 12px;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px rgba(34, 197, 94, 0.25);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-new-pro:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 25px rgba(34, 197, 94, 0.35);
        }

    /* --- TABLA PRO --- */
    .table-pro {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .table-pro thead th {
            background: #f8fafc;
            color: #64748b;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 1rem;
            border-bottom: 2px solid #e2e8f0;
            border-top: none;
        }

        .table-pro tbody td {
            padding: 1rem;
            vertical-align: middle;
            color: #334155;
            font-weight: 500;
            border-bottom: 1px solid #f1f5f9;
            transition: background 0.2s ease;
        }

        .table-pro tbody tr:hover td {
            background: #f8fafc;
        }

    .total-badge {
        background: #dcfce3;
        color: #16a34a;
        padding: 4px 10px;
        border-radius: 8px;
        font-weight: 800;
        font-size: 0.95rem;
    }

    /* --- BOTONES DE ACCIÓN (Tabla) --- */
    .btn-action {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .btn-edit {
        background: #fef3c7;
        color: #d97706;
    }

        .btn-edit:hover {
            background: #fde68a;
            transform: scale(1.05);
            color: #d97706;
        }

    .btn-delete {
        background: #fee2e2;
        color: #dc2626;
    }

        .btn-delete:hover {
            background: #fecaca;
            transform: scale(1.05);
            color: #dc2626;
        }

    /* Modal Premium */
    .modal-pro .modal-content {
        border-radius: 24px;
        border: none;
        overflow: hidden;
    }

    .modal-pro .modal-header {
        border-bottom: none;
    }

    .modal-pro .modal-footer {
        border-top: none;
        padding-bottom: 1.5rem;
    }

    /* --- FILTRO DESPLEGABLE MÓVIL --- */
    .btn-filter-trigger {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 0.75rem 1.2rem;
        font-size: 0.9rem;
        font-weight: 700;
        color: #334155;
        box-shadow: 0 4px 15px rgba(15, 23, 42, 0.02);
        transition: all 0.3s ease;
        text-align: left;
    }

        .btn-filter-trigger[aria-expanded="true"] .chevron-icon {
            transform: rotate(180deg);
        }

    .chevron-icon {
        transition: transform 0.3s ease;
        font-size: 0.8rem;
        color: #64748b;
    }

    @@media (min-width: 768px) {
        #filtrosGastosCollapse.collapse:not(.show)

    {
        display: block !important;
    }

    }

    /* =========================================
           ⚡ NUEVOS ESTILOS INTERACTIVOS (BURBUJA DE TOTALES)
        ========================================= */
    .wrapper-calculador-flotante {
        position: fixed;
        bottom: 85px; /* Alineado perfecto arriba de tu menú inferior */
        right: 25px;
        z-index: 1040;
    }

    /* Botón redondo principal */
    .btn-calculador-float {
        background: #0f172a;
        color: white !important;
        border: none;
        padding: 12px 24px;
        font-size: 0.9rem;
        font-weight: 800;
        border-radius: 50px; /* Redondo perfecto estilo píldora */
        box-shadow: 0 8px 25px rgba(15, 23, 42, 0.25);
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .btn-calculador-float:hover {
            transform: scale(1.05) translateY(-2px);
            background: #1e293b;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.35);
        }

    /* El panel de desglose (Escondido por defecto) */
    .summary-floating-card {
        position: absolute;
        bottom: 65px; /* Abre justo arriba del botón */
        right: 0;
        width: 320px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 24px;
        box-shadow: 0 15px 40px rgba(15, 23, 42, 0.15);
        padding: 1.25rem;
        display: none; /* Se activa con la clase .active via JS */
        overflow: hidden;
        animation: slideUpGasto 0.3s ease-out;
    }

        /* Clase activadora */
        .summary-floating-card.active {
            display: block;
        }

    .floating-title {
        font-size: 0.8rem;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .category-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85rem;
        font-weight: 600;
        color: #475569;
        margin-bottom: 0.4rem;
    }

        .category-row span.badge-value {
            font-family: monospace;
            font-size: 0.9rem;
            color: #0f172a;
            font-weight: 700;
        }

    .final-total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 2px dashed #e2e8f0;
        margin-top: 0.75rem;
        padding-top: 0.75rem;
    }

        .final-total-row span.label {
            font-weight: 800;
            font-size: 0.9rem;
            color: #0f172a;
        }

        .final-total-row span.value {
            font-size: 1.2rem;
            font-weight: 800;
            color: #dc2626;
        }

    @@keyframes slideUpGasto {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 576px) {
        .summary-floating-card

    {
        width: calc(100vw - 50px); /* Ajuste responsive exacto en celular */
        right: 0;
    }

    }
</style>

<div class="gasto-list-container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0" style="font-weight: 800;">Listado de Gastos</h3>
        </div>
        <a asp-controller="Gasto" asp-action="Registrar" class="btn-new-pro">
            <i class="bi bi-plus-lg"></i> Nuevo Gasto
        </a>
    </div>

    <div class="mb-4">
        <button type="button" class="btn btn-filter-trigger d-md-none w-100 d-flex align-items-center mb-2"
                data-bs-toggle="collapse" data-bs-target="#filtrosGastosCollapse" aria-expanded="false">
            <span><i class="bi bi-calendar3-range text-primary me-2"></i> Personalizar rango de fechas</span>
            <i class="bi bi-chevron-down ms-auto chevron-icon"></i>
        </button>

        <div class="collapse" id="filtrosGastosCollapse">
            <form onsubmit="return false;" class="form-premium-card">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label-pro">Desde</label>
                        <input type="date" id="desde" class="form-control input-pro"
                               value="@(((DateTime)ViewBag.Desde).ToString("yyyy-MM-dd"))" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-pro">Hasta</label>
                        <input type="date" id="hasta" class="form-control input-pro"
                               value="@(((DateTime)ViewBag.Hasta).ToString("yyyy-MM-dd"))" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-pro">Categoría</label>
                        <select id="categoria" class="form-select input-pro">
                            @foreach (var c in (List<SelectListItem>)ViewBag.Categorias)
                            {
                                if (c.Value == (string?)ViewBag.Categoria)
                                {
                                    <option value="@c.Value" selected>@c.Text</option>
                                }
                                else
                                {
                                    <option value="@c.Value">@c.Text</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-pro">Descripción</label>
                        <div class="position-relative">
                            <input type="text" id="descripcion" class="form-control input-pro"
                                   value="@ViewBag.Descripcion" placeholder="Buscar gasto..." />
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="form-premium-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table-pro text-nowrap">
                <thead class="text-center">
                    <tr>
                        <th>Fecha</th>
                        <th class="text-start">Categoría</th>
                        <th class="text-start">Descripción</th>
                        <th class="text-end">Total</th>
                        <th style="width:120px;">Acciones</th>
                    </tr>
                </thead>
                <tbody id="resultado">
                    @if (Model.Any())
                    {
                        foreach (var g in Model)
                        {
                            <tr class="gasto-fila" data-categoria="@g.Categoria" data-total="@g.Total">
                                <td class="text-center">@g.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                <td class="text-start fw-bold">@g.Categoria</td>
                                <td class="text-start">@g.Descripcion</td>
                                <td class="text-end"><span class="total-badge">@g.Total.ToString("C2")</span></td>
                                <td class="text-center">
                                    <a asp-action="Editar" asp-route-id="@g.IdGasto" class="btn-action btn-edit" title="Editar">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <button type="button" class="btn-action btn-delete ms-1" title="Eliminar"
                                            data-bs-toggle="modal" data-bs-target="#modalEliminar" onclick="setIdEliminar(@g.IdGasto)">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-2 d-block mb-2 text-light"></i>
                                No hay gastos en este rango de fechas
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="wrapper-calculador-flotante">

    <div id="cardCalculadorFlotante" class="summary-floating-card">
        <div class="floating-title d-flex align-items-center gap-1">
            <i class="bi bi-calculator text-primary"></i> Acumulado en Pantalla
        </div>
        <div id="desgloseCategorias">
        </div>
        <div class="final-total-row">
            <span class="label">TOTAL FINAL</span>
            <span class="value" id="totalFinalFlotante">S/ 0.00</span>
        </div>
    </div>

    <button type="button" id="btnCalculadorToggle" class="btn-calculador-float">
        <i class="bi bi-calculator-fill"></i> Calculador
    </button>
</div>

<div class="modal fade modal-pro" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content shadow-lg">
            <div class="modal-body text-center pt-5 pb-4 px-4">
                <div class="mb-3 text-danger">
                    <i class="bi bi-exclamation-octagon-fill" style="font-size: 3.5rem;"></i>
                </div>
                <h5 class="fw-bold mb-2">¿Eliminar Gasto?</h5>
                <p class="text-muted small mb-0">Esta acción es irreversible.</p>
            </div>
            <div class="modal-footer justify-content-center pb-4 pt-0">
                <form asp-action="Eliminar" method="post" class="d-flex gap-2 w-100 px-3">
                    <input type="hidden" id="idEliminar" name="id" />
                    <button type="button" class="btn btn-light fw-bold flex-fill" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger fw-bold flex-fill shadow-sm">Sí, eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const desde = document.getElementById("desde");
    const hasta = document.getElementById("hasta");
    const categoria = document.getElementById("categoria");
    const descripcion = document.getElementById("descripcion");
    const resultado = document.getElementById("resultado");
    const desgloseCategorias = document.getElementById("desgloseCategorias");
    const totalFinalFlotante = document.getElementById("totalFinalFlotante");

    // Elementos del botón interactivo
    const btnCalculador = document.getElementById("btnCalculadorToggle");
    const cardCalculador = document.getElementById("cardCalculadorFlotante");

    function setIdEliminar(id) {
        document.getElementById("idEliminar").value = id;
    }

    // ⚡ LÓGICA DE APERTURA Y CIERRE (Idéntica a la burbuja de video)
    if (btnCalculador && cardCalculador) {
        btnCalculador.addEventListener("click", (e) => {
            e.stopPropagation();
            cardCalculador.classList.toggle("active");
        });

        // Cerrar de forma inteligente al hacer clic fuera del panel
        document.addEventListener("click", (e) => {
            if (!cardCalculador.contains(e.target) && e.target !== btnCalculador) {
                cardCalculador.classList.remove("active");
            }
        });
    }

    // ⚡ CALCULO DE TOTALES EN VIVO
    function calcularTotalesFlotantes(gastosArray) {
        let totales = {};
        let totalGeneral = 0;

        gastosArray.forEach(g => {
            let cat = g.categoria || g.Categoria;
            let monto = parseFloat(g.total || g.Total);

            if (!totales[cat]) {
                totales[cat] = 0;
            }
            totales[cat] += monto;
            totalGeneral += monto;
        });

        let htmlDesglose = "";
        for (const [catName, totalCat] of Object.entries(totales)) {
            htmlDesglose += `
                <div class="category-row">
                    <span>• EN ${catName}:</span>
                    <span class="badge-value">S/ ${totalCat.toFixed(2)}</span>
                </div>
            `;
        }

        if(htmlDesglose === "") {
            htmlDesglose = `<div class="text-muted small text-center py-2">Sin gastos en lista</div>`;
        }

        desgloseCategorias.innerHTML = htmlDesglose;
        totalFinalFlotante.innerText = `S/ ${totalGeneral.toFixed(2)}`;
    }

    function cargarTotalesIniciales() {
        let listaInicial = [];
        document.querySelectorAll(".gasto-fila").forEach(tr => {
            listaInicial.push({
                Categoria: tr.dataset.categoria,
                Total: tr.dataset.total
            });
        });
        calcularTotalesFlotantes(listaInicial);
    }

    function buscarGastos() {
        const url = `/Gasto/BuscarGastos?desde=${encodeURIComponent(desde.value)}&hasta=${encodeURIComponent(hasta.value)}&categoria=${encodeURIComponent(categoria.value)}&descripcion=${encodeURIComponent(descripcion.value)}`;

        fetch(url)
            .then(response => response.json())
            .then(data => {
                if (data.length === 0) {
                    resultado.innerHTML = `
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="bi bi-search fs-2 d-block mb-2 text-light"></i> No se encontraron gastos
                            </td>
                        </tr>`;
                    calcularTotalesFlotantes([]);
                    return;
                }

                let filas = "";
                data.forEach(g => {
                    filas += `
                        <tr class="gasto-fila" data-categoria="${g.categoria}" data-total="${g.total}">
                            <td class="text-center">${g.fecha}</td>
                            <td class="text-start fw-bold">${g.categoria}</td>
                            <td class="text-start">${g.descripcion}</td>
                            <td class="text-end"><span class="total-badge">S/ ${Number(g.total).toFixed(2)}</span></td>
                            <td class="text-center">
                                <a href="/Gasto/Editar/${g.idGasto}" class="btn-action btn-edit" title="Editar"><i class="bi bi-pencil-fill"></i></a>
                                <button type="button" class="btn-action btn-delete ms-1" title="Eliminar" data-bs-toggle="modal" data-bs-target="#modalEliminar" onclick="setIdEliminar(${g.idGasto})"><i class="bi bi-trash3-fill"></i></button>
                            </td>
                        </tr>`;
                });

                resultado.innerHTML = filas;
                calcularTotalesFlotantes(data);
            });
    }

    let debounceTimer;
    descripcion.addEventListener("keyup", () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(buscarGastos, 400);
    });

    categoria.addEventListener("change", buscarGastos);
    desde.addEventListener("change", buscarGastos);
    hasta.addEventListener("change", buscarGastos);

    document.addEventListener("DOMContentLoaded", cargarTotalesIniciales);
</script>