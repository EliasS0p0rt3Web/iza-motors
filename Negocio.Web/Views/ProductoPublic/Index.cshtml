@using Microsoft.EntityFrameworkCore
@inject Negocio.Web.Data.NegocioDbContext _context

@{
    ViewData["Title"] = "Categorías de Repuestos";
    Layout = "_LayoutProductos";

    var areasRegistradas = await _context.Productos
        .AsNoTracking()
        .Where(p => p.Activo && p.Area != null)
        .Select(p => p.Area)
        .ToListAsync();

    var categorias = areasRegistradas
        .Where(area => !string.IsNullOrWhiteSpace(area))
        .Select(area => area.Trim().ToUpperInvariant())
        .Distinct()
        .OrderBy(area => area)
        .ToList();
}

<style>
    :root {
        --iza-rojo: #c8102e;
        --iza-rojo-oscuro: #990f24;
        --iza-rojo-claro: #fff1f3;
        --iza-blanco: #ffffff;
        --iza-fondo: #f8fafc;
        --iza-borde: #e2e8f0;
        --iza-texto: #172033;
        --iza-gris: #64748b;
    }

    body {
        background: var(--iza-fondo);
    }

    .categorias-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 1rem 5rem;
    }

    .categorias-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .categorias-title {
        color: var(--iza-texto);
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

        .categorias-title span {
            color: var(--iza-rojo);
        }

    .categorias-subtitle {
        color: var(--iza-gris);
        margin-bottom: 1.8rem;
    }

    .buscador-categorias {
        display: flex;
        align-items: center;
        max-width: 520px;
        margin: 0 auto;
        padding: 0 1rem;
        background: var(--iza-blanco);
        border: 2px solid var(--iza-borde);
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(23, 32, 51, 0.05);
        transition: 0.25s ease;
    }

        .buscador-categorias:focus-within {
            border-color: var(--iza-rojo);
            box-shadow: 0 8px 26px rgba(200, 16, 46, 0.13);
        }

        .buscador-categorias i {
            color: var(--iza-rojo);
            font-size: 1.2rem;
        }

    .buscador-input {
        width: 100%;
        padding: 1rem;
        border: none;
        outline: none;
        background: transparent;
        color: var(--iza-texto);
    }

    .categoria-card {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        height: 100%;
        padding: 1.5rem;
        color: inherit;
        text-decoration: none;
        background: var(--iza-blanco);
        border: 1px solid var(--iza-borde);
        border-radius: 18px;
        box-shadow: 0 7px 22px rgba(23, 32, 51, 0.05);
        transition: 0.25s ease;
    }

        .categoria-card:hover {
            color: inherit;
            border-color: var(--iza-rojo);
            transform: translateY(-4px);
            box-shadow: 0 14px 30px rgba(200, 16, 46, 0.12);
        }

    .categoria-icono {
        width: 65px;
        height: 65px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--iza-blanco);
        background: var(--iza-rojo);
        border-radius: 18px;
        font-size: 1.8rem;
    }

    .categoria-info {
        flex-grow: 1;
    }

    .categoria-nombre {
        color: var(--iza-texto);
        font-size: 1.15rem;
        font-weight: 800;
        margin-bottom: 0.25rem;
    }

    .categoria-descripcion {
        color: var(--iza-gris);
        font-size: 0.88rem;
        margin: 0;
    }

    .categoria-flecha {
        width: 38px;
        height: 38px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--iza-rojo);
        background: var(--iza-rojo-claro);
        border-radius: 50%;
        transition: 0.25s ease;
    }

    .categoria-card:hover .categoria-flecha {
        color: var(--iza-blanco);
        background: var(--iza-rojo);
    }

    .mensaje-vacio {
        padding: 2rem;
        color: var(--iza-gris);
        background: var(--iza-blanco);
        border: 1px dashed var(--iza-borde);
        border-radius: 18px;
        text-align: center;
    }

    @@media (max-width: 576px) {
        .categorias-container {
            padding-top: 2rem;
        }

        .categoria-card {
            padding: 1.2rem;
        }

        .categoria-icono {
            width: 55px;
            height: 55px;
        }
    }
</style>

<div class="categorias-container">

    <header class="categorias-header">

        <h1 class="categorias-title">
            Categorías de <span>Repuestos</span>
        </h1>

        <p class="categorias-subtitle">
            Selecciona una categoría para consultar sus repuestos disponibles.
        </p>

        <div class="buscador-categorias">
            <i class="bi bi-search"></i>

            <input type="text"
                   id="filtroCategorias"
                   class="buscador-input"
                   placeholder="Buscar categoría..."
                   autocomplete="off" />
        </div>

    </header>

    <div class="row g-3" id="contenedorCategorias">

        @if (!categorias.Any())
        {
            <div class="col-12">
                <div class="mensaje-vacio">
                    <i class="bi bi-tools fs-2 d-block mb-2"></i>
                    No existen categorías con repuestos activos.
                </div>
            </div>
        }
        else
        {
            foreach (var categoria in categorias)
            {
                <div class="col-12 col-md-6 categoria-item"
                     data-categoria="@categoria">

                    <a asp-action="Categoria"
                       asp-route-area="@categoria"
                       class="categoria-card">

                        <div class="categoria-icono">
                            <i class="bi bi-tools"></i>
                        </div>

                        <div class="categoria-info">
                            <h2 class="categoria-nombre">
                                @categoria
                            </h2>

                            <p class="categoria-descripcion">
                                Ver repuestos de esta categoría.
                            </p>
                        </div>

                        <div class="categoria-flecha">
                            <i class="bi bi-arrow-right"></i>
                        </div>

                    </a>

                </div>
            }
        }

        <div id="mensajeSinResultados"
             class="col-12 d-none">

            <div class="mensaje-vacio">
                <i class="bi bi-search fs-2 d-block mb-2"></i>
                No se encontró esa categoría.
            </div>

        </div>

    </div>
</div>

<script>
    const filtroCategorias =
        document.getElementById("filtroCategorias");

    const elementosCategorias =
        document.querySelectorAll(".categoria-item");

    const mensajeSinResultados =
        document.getElementById("mensajeSinResultados");

    filtroCategorias.addEventListener("input", function () {
        const textoBuscado =
            this.value.trim().toUpperCase();

        let categoriasVisibles = 0;

        elementosCategorias.forEach(elemento => {
            const categoria =
                elemento.dataset.categoria.toUpperCase();

            const coincide =
                categoria.includes(textoBuscado);

            elemento.classList.toggle(
                "d-none",
                !coincide
            );

            if (coincide) {
                categoriasVisibles++;
            }
        });

        mensajeSinResultados.classList.toggle(
            "d-none",
            categoriasVisibles > 0
        );
    });
</script>