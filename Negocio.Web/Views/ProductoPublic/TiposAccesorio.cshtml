@model List<string>

@{
    ViewData["Title"] = "Accesorios";
    Layout = "_LayoutProductos";
}

<a asp-action="Index" class="btn btn-outline-secondary mb-3">
    ⬅ Volver a categorías
</a>

<h3 class="fw-bold mb-4">🔩 Accesorios</h3>

<div class="row g-4">
    @foreach (var tipo in Model)
    {
        <div class="col-md-3 col-sm-6">
            <a asp-action="AccesorioDetalle"
               asp-route-nombre="@tipo"
               class="card h-100 text-decoration-none product-card text-center p-4">

                <div class="product-image-placeholder mb-3">
                    Imagen
                </div>

                <h6 class="fw-bold text-dark">@tipo</h6>
            </a>
        </div>
    }
</div>
