@model IEnumerable<Negocio.Web.Models.Entities.Reserva>

@{
    Layout = "_LayoutCliente";
    ViewData["Title"] = "Mis Cotizaciones";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

<div class="py-4 px-3 py-md-5 w-100 style-container" style="min-height: 100vh; background-color: #0f172a; overflow-x: hidden;">
    <div class="container-fluid px-0 mx-auto" style="max-width: 1200px;">

        @* ENCABEZADO *@
        <div class="row mb-4 gy-2 mx-0">
            <div class="col-12 px-0">
                <h2 class="fw-bold text-white m-0 d-flex align-items-center flex-wrap" style="font-size: clamp(20px, 4vw, 24px); letter-spacing: -0.02em;">
                    <i class="bi bi-file-earmark-text text-info me-2"></i> Mis Cotizaciones y Proyectos
                </h2>
                <p class="text-muted small m-0 mt-2" style="color: #94a3b8 !important; font-size: 14px; line-height: 1.4;">
                    Revisa los presupuestos de tus diseños personalizados de cortinas, rieles y estructuras calculadas a medida.
                </p>
            </div>
        </div>

        @* TABLA DE COTIZACIONES *@
        <div class="card shadow-lg border-0 rounded-4 w-100" style="background-color: #ffffff; overflow: hidden;">
            <div class="card-body p-0">
                <div class="table-responsive w-100 m-0 p-0" style="max-width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch;">
                    <table class="table table-hover align-middle mb-0 w-100" style="color: #1e293b; border-collapse: collapse; table-layout: fixed;">

                        <thead style="background-color: #f8fafc; border-bottom: 1px solid rgba(0,0,0,0.08);">
                            <tr>
                                <th class="ps-3 ps-sm-4 py-3 text-nowrap" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #475569; font-weight: 700; width: 25%;">Código</th>
                                <th class="py-3 text-nowrap" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #475569; font-weight: 700; width: 27%;">Fecha Cotizada</th>
                                <th class="py-3 d-none d-sm-table-cell text-nowrap" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #475569; font-weight: 700; width: 20%;">Presupuesto</th>
                                <th class="py-3 text-nowrap" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #475569; font-weight: 700; width: 28%;">Estado</th>
                                <th class="text-center py-3 pe-3 pe-sm-4 text-nowrap" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #475569; font-weight: 700; width: 20%;">Acciones</th>
                            </tr>
                        </thead>

                        <tbody class="border-0">
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr style="border-bottom: 1px solid rgba(0, 0, 0, 0.04); transition: background-color 0.2s ease;">
                                        <td class="ps-3 ps-sm-4 fw-bold text-dark py-3 text-truncate" style="font-size: 13px;">
                                            <span class="text-info">#</span>@item.CodigoReserva
                                        </td>

                                        <td class="py-3" style="color: #334155; font-weight: 500; font-size: 13px;">
                                            <span class="d-block text-nowrap">@item.FechaRegistro.ToString("dd/MM/yyyy")</span>
                                            <span class="d-block text-muted small" style="font-size: 11px;">@item.FechaRegistro.ToString("hh:mm tt")</span>
                                            <div class="d-sm-none text-dark fw-bold mt-1" style="font-size: 13px;">
                                                S/ @item.Total.ToString("N2")
                                            </div>
                                        </td>

                                        <td class="fw-bold text-dark d-none d-sm-table-cell py-3 text-nowrap" style="font-size: 14px;">
                                            S/ @item.Total.ToString("N2")
                                        </td>

                                        <td class="py-3">
                                            @* Sincronizado con tus badges originales de estados *@
                                            <span class="badge px-2 py-1 rounded-pill" style="background-color: rgba(14, 165, 233, 0.1); color: #0369a1; border: 1px solid rgba(14, 165, 233, 0.15); font-weight: 600; font-size: 11px;">
                                                @item.Estado
                                            </span>
                                        </td>

                                        <td class="text-center py-3 pe-3 pe-sm-4">
                                            @* Reutiliza tu acción VerPedido ya que su motor lee el JSON de cortinas perfectamente *@
                                            <a asp-controller="Cliente" asp-action="VerPedido" asp-route-id="@item.ReservaId"
                                               class="btn btn-sm btn-outline-info px-3 py-1 fw-semibold d-inline-flex align-items-center justify-content-center"
                                               style="border-radius: 6px; font-size: 12px; transition: all 0.2s;">
                                                <i class="bi bi-eye-fill"></i>
                                                <span class="d-none d-md-inline ms-1.5" style="margin-left: 4px;">Ver Estructura</span>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 px-3 custom-colspan">
                                        <div class="py-4 mx-auto" style="max-width: 100%;">
                                            <i class="bi bi-file-earmark-x d-block mb-3 text-muted" style="font-size: 40px; opacity: 0.6;"></i>
                                            <h6 class="fw-bold text-secondary mb-1" style="font-size: 15px;">Sin presupuestos</h6>
                                            <p class="text-muted small m-0" style="font-size: 13px; line-height: 1.4;">No tienes proyectos o diseños cotizados en este momento.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .table tbody tr {
        background-color: transparent !important;
    }

        .table tbody tr:hover {
            background-color: rgba(15, 23, 42, 0.02) !important;
        }

    .table th, .table td {
        border-style: none !important;
    }

    @@media (max-width: 576px) {
        .table {
            table-layout: auto !important;
        }

        .custom-colspan {
            display: table-cell !important;
            width: 100% !important;
        }
    }
</style>