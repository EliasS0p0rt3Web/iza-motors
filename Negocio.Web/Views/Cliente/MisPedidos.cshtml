@model IEnumerable<Negocio.Web.Models.Entities.Reserva>

@{
    Layout = "_LayoutCliente";
    ViewData["Title"] = "Mis Servicios";
}

@section Styles {
    <style>
        :root {
            --iza-red: #c8102e;
            --iza-red-dark: #980f24;
            --iza-red-soft: #fff1f3;
            --iza-white: #ffffff;
            --iza-background: #f7f8fa;
            --iza-border: #e5e7eb;
            --iza-text: #172033;
            --iza-muted: #64748b;
        }

        .servicios-container {
            min-height: 100vh;
            padding: 2.5rem 1rem 5rem;
            background: var(--iza-background);
        }

        .servicios-content {
            max-width: 1150px;
            margin: 0 auto;
        }

        .servicios-header {
            margin-bottom: 1.8rem;
        }

        .servicios-title {
            color: var(--iza-text);
            font-size: clamp(1.7rem, 4vw, 2.25rem);
            font-weight: 800;
            margin-bottom: 0.4rem;
        }

            .servicios-title i {
                color: var(--iza-red);
            }

        .servicios-subtitle {
            color: var(--iza-muted);
            font-size: 0.95rem;
            margin: 0;
        }

        .servicios-card {
            overflow: hidden;
            background: var(--iza-white);
            border: 1px solid var(--iza-border);
            border-radius: 18px;
            box-shadow: 0 8px 25px rgba(23, 32, 51, 0.06);
        }

        .servicios-table {
            width: 100%;
            margin: 0;
        }

            .servicios-table thead th {
                padding: 1rem;
                color: var(--iza-muted);
                background: #fafafa;
                border-bottom: 1px solid var(--iza-border);
                font-size: 0.72rem;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                white-space: nowrap;
            }

            .servicios-table tbody td {
                padding: 1rem;
                color: var(--iza-text);
                border-bottom: 1px solid #f1f5f9;
                vertical-align: middle;
                font-size: 0.88rem;
            }

            .servicios-table tbody tr:last-child td {
                border-bottom: none;
            }

            .servicios-table tbody tr:hover {
                background: #fffafa;
            }

        .codigo-servicio {
            color: var(--iza-red);
            font-weight: 800;
        }

        .fecha-principal {
            color: var(--iza-text);
            font-weight: 650;
        }

        .fecha-hora {
            color: var(--iza-muted);
            font-size: 0.75rem;
        }

        .importe-servicio {
            font-weight: 800;
            white-space: nowrap;
        }

        .estado-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 10px;
            border-radius: 30px;
            font-size: 0.72rem;
            font-weight: 750;
            white-space: nowrap;
        }

        .estado-pendiente {
            color: #a16207;
            background: #fef9c3;
        }

        .estado-confirmado {
            color: #1d4ed8;
            background: #dbeafe;
        }

        .estado-proceso {
            color: #7c3aed;
            background: #ede9fe;
        }

        .estado-listo {
            color: #15803d;
            background: #dcfce7;
        }

        .estado-entregado {
            color: #334155;
            background: #e2e8f0;
        }

        .estado-cancelado {
            color: #b91c1c;
            background: #fee2e2;
        }

        .estado-default {
            color: #475569;
            background: #f1f5f9;
        }

        .btn-detalle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 7px 12px;
            color: var(--iza-red);
            background: var(--iza-white);
            border: 1px solid var(--iza-red);
            border-radius: 9px;
            font-size: 0.78rem;
            font-weight: 750;
            text-decoration: none;
            transition: all 0.2s ease;
        }

            .btn-detalle:hover {
                color: var(--iza-white);
                background: var(--iza-red);
            }

        .sin-servicios {
            padding: 4rem 1.5rem;
            text-align: center;
        }

        .sin-servicios-icon {
            width: 70px;
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            color: var(--iza-red);
            background: var(--iza-red-soft);
            border-radius: 50%;
            font-size: 2rem;
        }

        .sin-servicios h3 {
            color: var(--iza-text);
            font-size: 1.05rem;
            font-weight: 800;
        }

        .sin-servicios p {
            color: var(--iza-muted);
            font-size: 0.88rem;
            margin-bottom: 1.3rem;
        }

        .btn-catalogo {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 10px 16px;
            color: var(--iza-white);
            background: var(--iza-red);
            border-radius: 10px;
            font-size: 0.85rem;
            font-weight: 750;
            text-decoration: none;
        }

            .btn-catalogo:hover {
                color: var(--iza-white);
                background: var(--iza-red-dark);
            }

        @@media (max-width: 767px) {
            .servicios-container {
                padding-top: 1.5rem;
            }

            .servicios-table,
            .servicios-table tbody,
            .servicios-table tr,
            .servicios-table td {
                display: block;
                width: 100%;
            }

                .servicios-table thead {
                    display: none;
                }

                .servicios-table tbody {
                    padding: 0.8rem;
                }

                    .servicios-table tbody tr {
                        margin-bottom: 0.9rem;
                        padding: 0.8rem;
                        background: var(--iza-white);
                        border: 1px solid var(--iza-border);
                        border-radius: 14px;
                    }

                        .servicios-table tbody tr:last-child {
                            margin-bottom: 0;
                        }

                    .servicios-table tbody td {
                        position: relative;
                        min-height: 42px;
                        padding: 0.55rem 0.5rem 0.55rem 42%;
                        border-bottom: 1px dashed var(--iza-border);
                        display: flex;
                        align-items: center;
                    }

                        .servicios-table tbody td::before {
                            position: absolute;
                            left: 0.5rem;
                            width: 36%;
                            color: var(--iza-muted);
                            font-size: 0.68rem;
                            font-weight: 800;
                            text-transform: uppercase;
                        }

                        .servicios-table tbody td:nth-of-type(1)::before {
                            content: "Código";
                        }

                        .servicios-table tbody td:nth-of-type(2)::before {
                            content: "Fecha";
                        }

                        .servicios-table tbody td:nth-of-type(3)::before {
                            content: "Importe";
                        }

                        .servicios-table tbody td:nth-of-type(4)::before {
                            content: "Estado";
                        }

                        .servicios-table tbody td:last-child {
                            display: block;
                            padding: 0.85rem 0 0;
                            border-bottom: none;
                            text-align: center;
                        }

                            .servicios-table tbody td:last-child::before {
                                display: none;
                            }

            .btn-detalle {
                width: 100%;
            }

            .sin-servicios {
                padding: 3rem 1rem;
            }
        }
    </style>
}

<div class="servicios-container">
    <div class="servicios-content">

        <!-- ENCABEZADO -->
        <header class="servicios-header">
            <h1 class="servicios-title">
                <i class="bi bi-wrench-adjustable-circle-fill me-2"></i>
                Mis servicios
            </h1>

            <p class="servicios-subtitle">
                Consulta tus solicitudes y revisa el estado actual de cada atención.
            </p>
        </header>

        <!-- LISTADO -->
        <div class="servicios-card">

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="servicios-table">

                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Fecha de solicitud</th>
                                <th>Importe</th>
                                <th>Estado actual</th>
                                <th class="text-center">Acción</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                var estado = item.Estado?.Trim().ToUpperInvariant();

                                <tr>
                                    <!-- CÓDIGO -->
                                    <td>
                                        <span class="codigo-servicio">
                                            #@item.CodigoReserva
                                        </span>
                                    </td>

                                    <!-- FECHA -->
                                    <td>
                                        <div>
                                            <div class="fecha-principal">
                                                @item.FechaRegistro.ToString("dd/MM/yyyy")
                                            </div>

                                            <div class="fecha-hora">
                                                @item.FechaRegistro.ToString("hh:mm tt")
                                            </div>
                                        </div>
                                    </td>

                                    <!-- IMPORTE -->
                                    <td>
                                        <span class="importe-servicio">
                                            S/ @item.Total.ToString("N2")
                                        </span>
                                    </td>

                                    <!-- ESTADO -->
                                    <td>
                                        @switch (estado)
                                        {
                                            case "PENDIENTE":
                                                <span class="estado-badge estado-pendiente">
                                                    <i class="bi bi-clock-fill"></i>
                                                    Pendiente
                                                </span>
                                                break;

                                            case "CONFIRMADO":
                                            case "CONFIRMADA":
                                                <span class="estado-badge estado-confirmado">
                                                    <i class="bi bi-check-circle-fill"></i>
                                                    Confirmado
                                                </span>
                                                break;

                                            case "EN_PRODUCCION":
                                            case "PRODUCCION":
                                            case "EN_PROCESO":
                                            case "EN_REPARACION":
                                                <span class="estado-badge estado-proceso">
                                                    <i class="bi bi-tools"></i>
                                                    En atención
                                                </span>
                                                break;

                                            case "LISTO":
                                            case "LISTO_PARA_ENTREGA":
                                                <span class="estado-badge estado-listo">
                                                    <i class="bi bi-car-front-fill"></i>
                                                    Listo para entrega
                                                </span>
                                                break;

                                            case "ENTREGADO":
                                            case "CERRADO":
                                                <span class="estado-badge estado-entregado">
                                                    <i class="bi bi-check2-all"></i>
                                                    Entregado
                                                </span>
                                                break;

                                            case "CANCELADO":
                                            case "CANCELADA":
                                                <span class="estado-badge estado-cancelado">
                                                    <i class="bi bi-x-circle-fill"></i>
                                                    Cancelado
                                                </span>
                                                break;

                                            default:
                                                <span class="estado-badge estado-default">
                                                    <i class="bi bi-info-circle-fill"></i>
                                                    @(string.IsNullOrWhiteSpace(item.Estado)
                                                                                        ? "Sin estado"
                                                                                        : item.Estado)
                                </span>
                                                                break;
                                        }
                                    </td>

                                    <!-- ACCIÓN -->
                                    <td class="text-center">
                                        <a asp-controller="Cliente"
                                           asp-action="VerPedido"
                                           asp-route-id="@item.ReservaId"
                                           class="btn-detalle">

                                            <i class="bi bi-eye-fill"></i>
                                            Ver detalle
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            }
            else
            {
                <div class="sin-servicios">

                    <div class="sin-servicios-icon">
                        <i class="bi bi-calendar-x"></i>
                    </div>

                    <h3>No tienes servicios registrados</h3>

                    <p>
                        Tus próximas solicitudes y atenciones aparecerán en esta sección.
                    </p>

                    <a asp-controller="ProductoPublic"
                       asp-action="Index"
                       class="btn-catalogo">

                        <i class="bi bi-tools"></i>
                        Ver catálogo de repuestos
                    </a>

                </div>
            }

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const loadingOverlay =
            document.getElementById("loadingOverlay");

        if (loadingOverlay) {
            loadingOverlay.style.display = "none";
        }
    });
</script>