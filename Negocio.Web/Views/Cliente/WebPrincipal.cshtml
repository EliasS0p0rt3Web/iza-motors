@model List<Negocio.Web.Models.Entities.TrabajoMarketing>

@{
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    ViewData["Title"] = "Inicio Comercial";
}

@if (TempData["Bienvenida"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var myModal = new bootstrap.Modal(document.getElementById('modalBienvenida'));
            myModal.show();

            // 🔥 Se cierra solo después de 2 segundos
            setTimeout(function() {
                myModal.hide();
            }, 2000);
        });
    </script>
}

<!-- Enlazamos Bootstrap 5 y Swiper para garantizar que todo cargue impecable -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<!-- Estilos integrados exclusivos para el Dashboard -->
<style>
    .dashboard-wrapper {
        padding: 40px;
        width: 100%;
        min-height: 100vh;
        background-color: #0f172a;
    }

    /* 🔥 EFECTO HOVER ESMERALDA IMPONENTE */
    .cotizador-pro-card {
        background-color: #1e293b;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 15px;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
        height: 100%;
    }

        .cotizador-pro-card:hover {
            transform: translateY(-5px);
            background-color: #24324d;
            border-color: #10b981;
            box-shadow: 0 12px 24px -10px rgba(16, 185, 129, 0.35);
        }

    /* Modificamos el contenedor para que sea una caja superior grande */
    .img-tech-container {
        width: 100%;
        height: 140px; /* ¡Más del doble de alto! */
        background: rgba(255, 255, 255, 0.02);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background 0.2s;
        overflow: hidden;
        margin-bottom: 12px; /* Espacio con el texto de abajo */
    }

        /* Forzamos a que la imagen se adapte con calidad cubriendo el espacio */
        .img-tech-container img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* Cambiamos a cover para que se vea lleno y pro, o contain si son siluetas con fondo */
        }

    /* Modificamos la tarjeta para que ordene los elementos hacia abajo (Vertical) */
    .cotizador-pro-card {
        background-color: #1e293b;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 20px;
        display: flex;
        flex-direction: column; /* 🔥 LA CLAVE: Todo va hacia abajo */
        align-items: stretch;
        gap: 8px;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
        height: 100%;
    }

    .card-tech-info h5 {
        color: #ffffff;
        font-size: 16px;
        font-weight: 700;
        margin: 0 0 4px 0;
    }

    .card-tech-info p {
        color: #ffffff !important; /* 🔥 Forzamos el color blanco puro */
        font-size: 12.5px;
        margin: 0;
        line-height: 1.3;
    }

    .btn-tech-start {
        margin-left: auto;
        color: #10b981;
        font-weight: 600;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    /* Estilos de la sección Cómo Trabajamos */
    .flow-step-card {
        background: rgba(30, 41, 59, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-radius: 16px;
        padding: 24px;
        position: relative;
        height: 100%;
    }

    .step-badge {
        font-size: 11px;
        font-weight: 800;
        color: #10b981;
        background: rgba(16, 185, 129, 0.1);
        padding: 4px 10px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 16px;
    }

    .step-icon-box {
        font-size: 24px;
        color: #3b82f6;
        margin-bottom: 12px;
    }

        .step-icon-box.success {
            color: #10b981;
        }

    /* Estilos del Carrusel de Proyectos */
    .trabajo-item-card {
        background: #1e293b;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.05);
        height: 100%;
    }

    .trabajo-img-wrapper {
        position: relative;
        width: 100%;
        height: 200px;
        overflow: hidden;
        background: #0f172a;
    }

        .trabajo-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .trabajo-overlay {
        position: absolute;
        top: 12px;
        left: 12px;
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(4px);
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 600;
        color: #38bdf8;
    }

    .swiper-pagination-bullet {
        background: #94a3b8 !important;
    }

    .swiper-pagination-bullet-active {
        background: #3b82f6 !important;
    }

    /* Lista de videos tutoriales */
    .video-item-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        background: #0f172a;
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.2s;
    }

        .video-item-link:hover {
            background: rgba(239, 68, 68, 0.05);
            border-color: rgba(239, 68, 68, 0.2);
        }


    /* 🛠️ CONTENEDOR FLOTANTE PREMIUM */
    .panel-flotante-derecho {
        position: fixed;
        bottom: 25px;
        right: 25px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        z-index: 9999; /* Asegura que flote por encima de todo */
    }

    .btn-flotante-pro {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 20px;
        border-radius: 50px; /* Estilo píldora moderno */
        font-weight: 700;
        font-size: 13.5px;
        text-decoration: none;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

        .btn-flotante-pro:hover {
            transform: translateY(-4px) scale(1.03);
            box-shadow: 0 15px 30px -5px rgba(0, 0, 0, 0.7);
            color: #ffffff !important;
        }

    /* Colores específicos de marca */
    .flotante-catalogo {
        background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
        color: #ffffff;
    }

        .flotante-catalogo:hover {
            box-shadow: 0 12px 24px -5px rgba(14, 165, 233, 0.4);
        }

    .flotante-exhibidoras {
        background: linear-gradient(135deg, #eab308 0%, #ca8a04 100%);
        color: #1e293b;
    }

        .flotante-exhibidoras:hover {
            box-shadow: 0 12px 24px -5px rgba(234, 179, 8, 0.4);
        }


    /* ========================================================================= */
    /* 🔥 SECCIÓN EXCLUSIVA: OPTIMIZACIÓN RESPONSIVA PARA SMARTPHONES (CELULAR)   */
    /* ========================================================================= */
    @@media (max-width: 575.98px) {
        /* 1. Reducimos el colchón de los bordes para ganar espacio útil horizontal */
        .dashboard-wrapper

    {
        padding: 16px !important;
    }

    /* 2. Re-ordenamos el Cotizador Core: de tarjeta vertical pasa a lista horizontal */
    .cotizador-pro-card {
        flex-direction: row !important;
        align-items: center !important;
        padding: 12px 16px !important;
        gap: 15px !important;
    }

    /* 3. Convertimos la imagen gigante en un icono de app compacto a la izquierda */
    .img-tech-container {
        width: 65px !important;
        height: 65px !important;
        margin-bottom: 0 !important;
        border-radius: 10px !important;
    }

    /* 4. Corregimos el bloque de información al lado de la imagen */
    .card-tech-info {
        text-align: left !important;
        margin-top: 0 !important;
    }

        .card-tech-info h5 {
            font-size: 15px !important;
            margin-bottom: 2px !important;
        }

        .card-tech-info p {
            font-size: 11.5px !important;
            display: -webkit-box;
            -webkit-line-clamp: 1; /* Forzamos recorte de texto largo para que no haga bulto */
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

    /* 5. Quitamos la línea de borde superior y mandamos el chevron directo a la derecha */
    .btn-tech-start {
        margin-left: auto !important;
        border-top: none !important;
        padding-top: 0 !important;
        margin-top: 0 !important;
    }

        .btn-tech-start span {
            display: none !important; /* Oculta la palabra "Cotizar" en móvil para ahorrar espacio */
        }

    /* 6. REDISEÑO TOTAL DE BOTONES FLOTANTES: burbujas minimalistas circulares */
    .panel-flotante-derecho {
        bottom: 16px !important;
        right: 16px !important;
        gap: 8px !important;
    }

    .btn-flotante-pro {
        padding: 0 !important;
        width: 48px !important; /* Círculo perfecto */
        height: 48px !important;
        border-radius: 50% !important;
        justify-content: center !important;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.5) !important;
    }

        .btn-flotante-pro span {
            display: none !important; /* Oculta el texto completo en móviles */
        }

        .btn-flotante-pro i {
            font-size: 20px !important; /* Icono centrado y nítido */
        }

    }
</style>

<div class="dashboard-wrapper">
    <div class="container-fluid p-0">

        <!-- HEADER DEL PANEL COMERCIAL -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h2 class="fw-bold text-white m-0" style="font-size: 26px; letter-spacing: -0.02em;">
                    <i class="bi bi-grid-1x2-fill text-primary me-2"></i> Hola, @Context.Session.GetString("USER_NAME")
                </h2>
            </div>
            <div class="text-end">
                <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 fw-semibold" style="border: 1px solid rgba(34, 197, 94, 0.2); border-radius: 8px; font-size: 13px;">
                    <i class="bi bi-circle-fill me-1" style="font-size: 8px;"></i> Servidor Online
                </span>
            </div>
        </div>

        <!-- 1️⃣ SECCIÓN: COTIZADOR INTELIGENTE INDUSTRIAL (6 MÓDULOS COMPLETOS) -->
        <!-- 1️⃣ SECCIÓN: COTIZADOR INTELIGENTE INDUSTRIAL (6 MÓDULOS CON TUS RUTAS REALES) -->
        <div class="card border-0 rounded-4 p-4 mb-4" style="background-color: #1e293b; border: 1px solid rgba(255,255,255,0.05) !important;">
            <div class="mb-4">
                <h4 class="fw-bold text-white m-0" style="font-size: 18px;"><i class="bi bi-sliders text-success me-2"></i> Cotizadores Automáticos</h4>
            </div>

            <div class="row g-3">
                <!-- Set de Cortina -->
                <div class="col-12 col-sm-6 col-lg-3">
                    <a asp-controller="Cotizacion" asp-action="TuboCortinas" style="text-decoration: none;">
                        <div class="cotizador-pro-card">
                            <div class="img-tech-container">
                                <img src="/img/home/icon-tub.webp" alt="Set de Cortina">
                            </div>
                            <div class="card-tech-info text-center mt-1">
                                <h5>Set de Cortina</h5>
                                <p class="text-muted small">Tubo + Soportes completos</p>
                            </div>
                            <div class="btn-tech-start justify-content-center mt-2 pt-2 border-top border-secondary border-opacity-10">
                                <span>Cotizar</span> <i class="bi bi-chevron-right"></i>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Pasamanos -->
                <div class="col-12 col-sm-6 col-lg-3">
                    <a asp-controller="CotizacionPasamanos" asp-action="Index" style="text-decoration: none;">
                        <div class="cotizador-pro-card">
                            <div class="img-tech-container">
                                <img src="/img/home/icon-pasamanos.webp" alt="Sistema de Pasamanos">
                            </div>
                            <div class="card-tech-info text-center mt-1">
                                <h5>Pasamanos</h5>
                                <p class="text-muted small">Kit de seguridad reforzado</p>
                            </div>
                            <div class="btn-tech-start justify-content-center mt-2 pt-2 border-top border-secondary border-opacity-10">
                                <span>Cotizar</span> <i class="bi bi-chevron-right"></i>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Riel Hotelero -->
                <div class="col-12 col-sm-6 col-lg-3">
                    <a asp-controller="CotizacionRiel" asp-action="Index" style="text-decoration: none;">
                        <div class="cotizador-pro-card">
                            <div class="img-tech-container">
                                <img src="/img/home/icon-riel.webp" alt="Riel Hotelero">
                            </div>
                            <div class="card-tech-info text-center mt-1">
                                <h5>Riel Hotelero</h5>
                                <p class="text-muted small">Armado listo para instalar</p>
                            </div>
                            <div class="btn-tech-start justify-content-center mt-2 pt-2 border-top border-secondary border-opacity-10">
                                <span>Cotizar</span> <i class="bi bi-chevron-right"></i>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Barra de Ducha -->
                <div class="col-12 col-sm-6 col-lg-3">
                    <a asp-controller="CotizacionDucha" asp-action="Index" style="text-decoration: none;">
                        <div class="cotizador-pro-card">
                            <div class="img-tech-container">
                                <img src="/img/home/icon-ducha.webp" alt="Barra de Ducha">
                            </div>
                            <div class="card-tech-info text-center mt-1">
                                <h5>Barra de Ducha</h5>
                                <p class="text-muted small">Set inoxidable de alta resistencia</p>
                            </div>
                            <div class="btn-tech-start justify-content-center mt-2 pt-2 border-top border-secondary border-opacity-10">
                                <span>Cotizar</span> <i class="bi bi-chevron-right"></i>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="card border-0 rounded-4 p-4 h-100" style="background-color: #1e293b; border: 1px solid rgba(255,255,255,0.05) !important;">
                    <div class="mb-4">
                        <h4 class="fw-bold text-white m-0" style="font-size: 18px;"><i class="bi bi-images text-primary me-2"></i> Mejoras actuales de el panel Cliente</h4>

                    </div>

                    <div class="w-100 mt-2">
                        <div class="ratio ratio-21x9 rounded-4 overflow-hidden shadow-lg" style="border: 1px solid rgba(255,255,255,0.05); max-height: 400px;">
                            <iframe src="https://www.youtube.com/embed/n6YDSwKCUt4?rel=0&modestbranding=1"
                                    title="Modelos Ejecutados E&E Aluminios"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                    allowfullscreen>
                            </iframe>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="card border-0 rounded-4 p-4 h-100" style="background-color: #1e293b; border: 1px solid rgba(255,255,255,0.05) !important;">
                    <!-- CABECERA DE LA SECCIÓN -->
                    <div class="mb-3">
                        <h4 class="fw-bold text-white m-0" style="font-size: 18px;">
                            <i class="bi bi-youtube text-danger me-2"></i> Guías y Soporte Visual
                        </h4>
                       
                    </div>

                    <!-- LISTA DE VIDEOS TUTORIALES -->
                    <div class="d-flex flex-column gap-2">
                        <!-- Video 1 -->
                        <a href="https://youtu.be/n6YDSwKCUt4" target="_blank" class="video-item-link">
                            <div class="text-danger fs-3 d-flex align-items-center">
                                <i class="bi bi-play-btn-fill"></i>
                            </div>
                            <div>
                                <h6 class="text-white small m-0 fw-bold">¿Cómo reservar desde el cotizador inteligente?</h6>
                          
                            </div>
                            <i class="bi bi-arrow-up-right-short text-muted ms-auto"></i>
                        </a>

                        <!-- Video 2 -->
                        <a href="https://youtu.be/n6YDSwKCUt4" target="_blank" class="video-item-link">
                            <div class="text-danger fs-3 d-flex align-items-center">
                                <i class="bi bi-play-btn-fill"></i>
                            </div>
                            <div>
                                <h6 class="text-white small m-0 fw-bold">¿Cómo Reservar desde catalogo de productos?</h6>
                    
                            </div>
                            <i class="bi bi-arrow-up-right-short text-muted ms-auto"></i>
                        </a>

                        <!-- Video 3 -->
                        <a href="https://youtu.be/n6YDSwKCUt4" target="_blank" class="video-item-link">
                            <div class="text-danger fs-3 d-flex align-items-center">
                                <i class="bi bi-play-btn-fill"></i>
                            </div>
                            <div>
                                <h6 class="text-white small m-0 fw-bold">Proceso completo explicado de mi compra</h6>
                    
                            </div>
                            <i class="bi bi-arrow-up-right-short text-muted ms-auto"></i>
                        </a>
                    </div>

                    <!-- SEPARADOR Y ACCIÓN PRINCIPAL -->
                    <hr class="my-3" style="border-color: rgba(255,255,255,0.08);">

                    <a href="https://wa.me/51921726629?text=Hola%20E%26E%20Aluminios,%20necesito%20soporte%20técnico." target="_blank" class="btn btn-success btn-sm w-100 py-2.5 fw-bold text-white d-flex align-items-center justify-content-center gap-2" style="background-color: #10b981; border: none; border-radius: 12px; font-size: 13.5px; transition: background-color 0.2s;">
                        <i class="bi bi-whatsapp"></i> Chat Directo con Taller
                    </a>
                </div>
            </div>
        </div>

        <!-- 4️⃣ SECCIÓN: CÓMO TRABAJAMOS -->
        <div class="card border-0 rounded-4 p-4" style="background-color: #1e293b; border: 1px solid rgba(255,255,255,0.05) !important;">
            <div class="mb-4">
                <span class="badge rounded-pill px-3 py-1.5 mb-2" style="background-color: rgba(34, 197, 94, 0.15); color: #4ade80; font-weight: 600; font-size: 11px;">FLUJO OPERATIVO</span>
                <h4 class="fw-bold text-white m-0" style="font-size: 18px;">¿Cómo es el proceso de tus órdenes?</h4>
            </div>

            <div class="row g-3">
                <!-- PASO 1 -->
                <div class="col-md-3">
                    <div class="flow-step-card">
                        <div class="step-badge">PASO 01</div>
                        <div class="step-icon-box"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                        <h6 class="fw-bold text-white mb-2">Configura tu modelo</h6>
                        <p class="small m-0" style="font-size: 13px; line-height: 1.4; color: #cbd5e1;">Elige cualquiera de nuestros módulos interactivos de cotización rápida o solicita tus barras de aluminio a medida.</p>
                    </div>
                </div>

                <!-- PASO 2 -->
                <div class="col-md-3">
                    <div class="flow-step-card">
                        <div class="step-badge">PASO 02</div>
                        <div class="step-icon-box"><i class="bi bi-cash-stack"></i></div>
                        <h6 class="fw-bold text-white mb-2">Acuerdo y Adelanto</h6>
                        <p class="small m-0" style="font-size: 13px; line-height: 1.4; color: #cbd5e1;">Validamos tu presupuesto por llamada. Al abonar tu adelanto, podrás monitorear el progreso del lote desde este panel.</p>
                    </div>
                </div>

                <!-- PASO 3 -->
                <div class="col-md-3">
                    <div class="flow-step-card">
                        <div class="step-badge">PASO 03</div>
                        <div class="step-icon-box"><i class="bi bi-tools"></i></div>
                        <h6 class="fw-bold text-white mb-2">Producción en Marcha</h6>
                        <p class="small m-0" style="font-size: 13px; line-height: 1.4; color: #cbd5e1;">Cortamos perfiles y ensamblamos accesorios al milímetro en maestranza, asegurando un control estricto de calidad.</p>
                    </div>
                </div>

                <!-- PASO 4 -->
                <div class="col-md-3">
                    <div class="flow-step-card" style="border-color: rgba(16, 185, 129, 0.2); background: rgba(16, 185, 129, 0.02);">
                        <div class="step-badge" style="background-color: rgba(34, 197, 94, 0.15); color: #4ade80;">LISTO</div>
                        <div class="step-icon-box success"><i class="bi bi-megaphone-fill"></i></div>
                        <h6 class="fw-bold text-white mb-2">Aviso y Despacho</h6>
                        <p class="small m-0" style="font-size: 13px; line-height: 1.4; color: #cbd5e1;">Te notificamos al instante. Retira en tienda o gestionamos tu despacho directo a obra en Lima o agencias.</p>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>


<div class="panel-flotante-derecho">
    <a asp-controller="ProductoPublic" asp-action="Index" class="btn-flotante-pro flotante-catalogo">
        <i class="bi bi-box-seam-fill fs-5"></i>
        <span>Catálogo Catálogo</span>
    </a>

    <a asp-controller="HomePublic" asp-action="Galeria" asp-route-categoria="Exhibidora" class="btn-flotante-pro flotante-exhibidoras">
        <i class="bi bi-window-sidebar fs-5"></i>
        <span>Vitrinas LED</span>
    </a>
</div>

<!-- Scripts de control para inicializar el Swiper dinámico -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const swiper = new Swiper('.swiper', {
            loop: true,
            autoplay: { delay: 2800, disableOnInteraction: false },
            slidesPerView: 1,
            spaceBetween: 16,
            pagination: { el: '.swiper-pagination', clickable: true },
            breakpoints: {
                576: { slidesPerView: 2 },
                992: { slidesPerView: 3 }
            }
        });
    });
</script>