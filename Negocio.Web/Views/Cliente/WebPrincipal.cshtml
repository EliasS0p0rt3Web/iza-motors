@model List<Negocio.Web.Models.Entities.TrabajoMarketing>

@using Microsoft.AspNetCore.Http

@{
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    ViewData["Title"] = "Panel del Cliente";

    var nombreUsuario =
        Context.Session.GetString("USER_NAME")
        ?? Context.Session.GetString("USER")
        ?? "Cliente";
}

<style>
    :root {
        --iza-rojo: #c8102e;
        --iza-rojo-oscuro: #99152a;
        --iza-rojo-claro: #fff1f3;
        --iza-blanco: #ffffff;
        --iza-fondo: #f8fafc;
        --iza-borde: #e2e8f0;
        --iza-texto: #172033;
        --iza-gris: #64748b;
    }

    body {
        background: var(--iza-fondo);
    }

    .cliente-container {
        max-width: 1100px;
        min-height: 100vh;
        margin: 0 auto;
        padding: 3rem 1rem 6rem;
    }

    .cliente-header {
        padding: 2rem;
        margin-bottom: 2rem;
        color: var(--iza-blanco);
        background: linear-gradient( 135deg, var(--iza-rojo-oscuro), var(--iza-rojo) );
        border-radius: 22px;
        box-shadow: 0 12px 30px rgba(200, 16, 46, 0.18);
    }

        .cliente-header h1 {
            font-size: clamp(1.8rem, 5vw, 2.5rem);
            font-weight: 800;
            margin-bottom: 0.5rem;
        }

        .cliente-header p {
            margin: 0;
            color: rgba(255, 255, 255, 0.85);
        }

    .section-title {
        color: var(--iza-texto);
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-bottom: 1rem;
    }

    .cliente-card {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 1.5rem;
        color: inherit;
        background: var(--iza-blanco);
        border: 1px solid var(--iza-borde);
        border-radius: 18px;
        text-decoration: none;
        box-shadow: 0 7px 22px rgba(23, 32, 51, 0.05);
        transition: all 0.25s ease;
    }

        .cliente-card:hover {
            color: inherit;
            border-color: var(--iza-rojo);
            transform: translateY(-5px);
            box-shadow: 0 15px 32px rgba(200, 16, 46, 0.12);
        }

    .card-icon {
        width: 62px;
        height: 62px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.2rem;
        color: var(--iza-blanco);
        background: var(--iza-rojo);
        border-radius: 17px;
        font-size: 1.7rem;
    }

    .cliente-card h2 {
        color: var(--iza-texto);
        font-size: 1.1rem;
        font-weight: 800;
        margin-bottom: 0.4rem;
    }

    .cliente-card p {
        color: var(--iza-gris);
        font-size: 0.9rem;
        line-height: 1.5;
        flex-grow: 1;
        margin-bottom: 1.2rem;
    }

    .card-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 1rem;
        color: var(--iza-rojo);
        border-top: 1px solid var(--iza-borde);
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
    }

    .card-arrow {
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--iza-rojo);
        background: var(--iza-rojo-claro);
        border-radius: 50%;
        transition: all 0.25s ease;
    }

    .cliente-card:hover .card-arrow {
        color: var(--iza-blanco);
        background: var(--iza-rojo);
    }

    .mensaje-bienvenida {
        color: #166534;
        background: #dcfce7;
        border: 1px solid #bbf7d0;
        border-radius: 14px;
        padding: 1rem;
        margin-bottom: 1.5rem;
    }

    .whatsapp-button {
        position: fixed;
        right: 22px;
        bottom: 22px;
        width: 54px;
        height: 54px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        background: #25d366;
        border-radius: 50%;
        font-size: 1.5rem;
        text-decoration: none;
        box-shadow: 0 8px 22px rgba(0, 0, 0, 0.2);
        transition: all 0.25s ease;
        z-index: 1000;
    }

        .whatsapp-button:hover {
            color: white;
            transform: translateY(-3px);
            background: #1ebe5d;
        }

    @@media (max-width: 576px) {
        .cliente-container {
            padding-top: 1.5rem;
        }

        .cliente-header {
            padding: 1.5rem;
        }
    }
</style>

<div class="cliente-container">

    @if (TempData["Bienvenida"] != null)
    {
        <div class="mensaje-bienvenida">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["Bienvenida"]
        </div>
    }

    <!-- ENCABEZADO -->
    <header class="cliente-header">
        <h1>Hola, @nombreUsuario</h1>

        <p>
            Bienvenido al panel de atención de Iza Motors.
        </p>
    </header>

    <!-- ACCESOS -->
    <h2 class="section-title">
        <i class="bi bi-grid-fill me-2 text-danger"></i>
        Accesos principales
    </h2>

    <div class="row g-4">

        <!-- CATÁLOGO -->
        <div class="col-12 col-md-4">
            <a asp-controller="ProductoPublic"
               asp-action="Index"
               class="cliente-card">

                <div class="card-icon">
                    <i class="bi bi-tools"></i>
                </div>

                <h2>Catálogo de repuestos</h2>

                <p>
                    Consulta las categorías, precios y repuestos disponibles.
                </p>

                <div class="card-link">
                    <span>Ver catálogo</span>

                    <span class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </span>
                </div>
            </a>
        </div>

        <!-- SERVICIOS -->
        <div class="col-12 col-md-4">
            <a asp-controller="Cliente"
               asp-action="MisPedidos"
               class="cliente-card">

                <div class="card-icon">
                    <i class="bi bi-wrench-adjustable-circle"></i>
                </div>

                <h2>Mis servicios</h2>

                <p>
                    Consulta tus solicitudes y el estado de las atenciones realizadas.
                </p>

                <div class="card-link">
                    <span>Consultar servicios</span>

                    <span class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </span>
                </div>
            </a>
        </div>

        <!-- PERFIL -->
        <div class="col-12 col-md-4">
            <a asp-controller="Cliente"
               asp-action="MiPerfil"
               class="cliente-card">

                <div class="card-icon">
                    <i class="bi bi-person-fill-gear"></i>
                </div>

                <h2>Mi perfil</h2>

                <p>
                    Revisa y actualiza tu información personal.
                </p>

                <div class="card-link">
                    <span>Ver perfil</span>

                    <span class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </span>
                </div>
            </a>
        </div>

    </div>
</div>

<!-- WHATSAPP -->
<a href="https://wa.me/51921726629?text=Hola%20Iza%20Motors,%20necesito%20información."
   target="_blank"
   rel="noopener noreferrer"
   class="whatsapp-button"
   title="Contactar a Iza Motors">

    <i class="bi bi-whatsapp"></i>
</a>