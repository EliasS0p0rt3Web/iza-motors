@model Negocio.Web.Models.Entities.PerfilCliente

@{
    Layout = "_LayoutCliente";
    ViewData["Title"] = "Mi Perfil";
    // Recuperamos el usuario que inyectamos desde el controlador
    var usuario = ViewBag.Usuario as Negocio.Web.Models.Entities.Usuario;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
        font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
    }

    .profile-bg-wrapper {
        padding: 40px 20px;
        width: 100%;
        min-height: 100vh;
        background-color: #0f172a;
        background-image: radial-gradient(at 0% 100%, rgba(16, 185, 129, 0.1) 0px, transparent 50%), radial-gradient(at 100% 0%, rgba(30, 58, 138, 0.25) 0px, transparent 50%);
        display: flex;
        align-items: center;
    }

    .profile-card {
        background: rgba(30, 41, 59, 0.7) !important;
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08) !important;
        border-radius: 24px !important;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5) !important;
        color: #f1f5f9 !important;
    }

    /* --- ESTILOS DE INPUTS MODERNOS --- */
    .custom-input-group {
        margin-bottom: 20px;
        position: relative;
    }

    .custom-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        width: 100%;
    }

    .custom-input-group label {
        font-size: 13px;
        font-weight: 500;
        color: #64748b;
        margin-bottom: 6px;
        display: block;
        transition: color 0.2s ease;
    }

    .custom-input-group:focus-within label {
        color: #10b981;
    }

    .form-control-custom {
        width: 100%;
        padding: 12px 16px;
        background: rgba(15, 23, 42, 0.6) !important;
        border: 1px solid #334155 !important;
        border-radius: 12px !important;
        font-size: 14px;
        color: #fff !important;
        transition: all 0.2s ease;
    }

        .form-control-custom:focus {
            outline: none;
            border-color: #10b981 !important;
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15) !important;
            background: rgba(15, 23, 42, 0.8) !important;
        }

        /* Inputs de solo lectura o bloqueados */
        .form-control-custom[readonly] {
            background: rgba(15, 23, 42, 0.3) !important;
            border: 1px solid rgba(51, 65, 85, 0.5) !important;
            color: #94a3b8 !important;
            cursor: not-allowed !important;
        }

    /* --- MÁSCARA CELULAR PERÚ --- */
    .phone-prefix-box {
        position: absolute;
        left: 16px;
        color: #64748b;
        font-size: 14px;
        font-weight: 500;
        pointer-events: none;
    }

    .phone-input-padding {
        padding-left: 48px !important;
    }

    /* --- BOTÓN OJO PARA CONTRASEÑAS --- */
    .password-toggle-btn {
        position: absolute;
        right: 16px;
        background: none;
        border: none;
        color: #64748b;
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        transition: color 0.2s ease;
        z-index: 10;
    }

        .password-toggle-btn:hover {
            color: #10b981;
        }

    .password-input-padding {
        padding-right: 48px !important;
    }

    /* --- ALERTAS Y NOTIFICACIONES Y ERRORES --- */
    .custom-alert {
        padding: 14px;
        background: rgba(34, 197, 94, 0.12) !important;
        border: 1px solid rgba(34, 197, 94, 0.25) !important;
        color: #4ade80 !important;
        font-size: 14px;
        border-radius: 12px;
        animation: fadeIn 0.4s ease;
    }

    .error-toast {
        margin-bottom: 20px;
        padding: 12px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #f87171;
        font-size: 13px;
        text-align: center;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        animation: fadeIn 0.3s ease;
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(-6px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* --- BOTONES DE ACCIÓN --- */
    .btn-submit-profile {
        background: #10b981 !important;
        border: none !important;
        border-radius: 12px !important;
        padding: 14px !important;
        font-size: 15px !important;
        font-weight: 600 !important;
        color: #fff !important;
        transition: all 0.2s ease !important;
    }

        .btn-submit-profile:hover {
            background: #059669 !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        }

    /* ========================================================
       📱 RESPONSIVE DESIGN (OPTIMIZADO PARA MÓVILES)
       ======================================================== */
    @@media (max-width: 576px) {
        /* 1. Bloqueamos el viewport del body y wrapper para que nada se mueva */
        html, body

    {
        overflow-x: hidden !important;
        width: 100% !important;
        position: relative;
    }

    .profile-bg-wrapper {
        padding: 0px !important;
        background-image: none;
        background-color: #0f172a;
        overflow-x: hidden !important;
        width: 100% !important;
    }

    /* 2. Eliminamos los paddings heredados del container de Bootstrap */
    .container {
        padding-right: 0px !important;
        padding-left: 0px !important;
        width: 100% !important;
        max-width: 100vw !important;
    }

    /* 3. Forzamos a la tarjeta a ocupar el 100% real sin bordes fantasmas */
    .profile-card {
        border: none !important;
        border-radius: 0px !important;
        background: #0f172a !important;
        box-shadow: none !important;
        padding: 30px 16px !important;
        min-height: 100vh;
        width: 100% !important;
        max-width: 100vw !important;
        margin: 0px !important; /* Elimina cualquier margen residual */
    }

    /* 4. Reseteo absoluto para las filas */
    .row {
        margin-right: 0px !important;
        margin-left: 0px !important;
        width: 100% !important;
    }

    .btn-submit-profile {
        padding: 16px !important;
    }

    #vistaNombre span {
        font-size: 1.1rem !important;
    }

    .custom-input-group label {
        font-size: 12px;
    }

    #btnAbrirModalPassword, #btnModoEditar, #btnCancelarEditar {
        padding: 12px !important;
        font-size: 14px !important;
    }

    }

    /* --- AJUSTES DE TEXTO PARA MODO LECTURA --- */
    #vistaNombre span {
        display: block;
        word-break: break-word;
    }

    #vistaTelefono span, #vistaDocVacio span {
        font-size: 14px;
    }
</style>

<div class="profile-bg-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-10 col-lg-8">

                <div class="card profile-card p-4">

                    <div class="text-center mb-4">
                        <div class="d-inline-block p-3 rounded-circle mb-3" style="background-color: rgba(16, 185, 129, 0.1) !important;">
                            <i class="bi bi-person-badge fs-1" style="color: #10b981;"></i>
                        </div>
                        <h3 class="fw-bold text-white mb-1">Mi Perfil</h3>
                        <p style="color: #94a3b8; font-size: 14px; margin: 0;">Gestiona tu información personal para agilizar tus cotizaciones y despachos.</p>

                        <div class="mt-3 p-2 rounded-3 d-inline-flex align-items-center gap-2" style="background: rgba(245, 158, 11, 0.08); border: 1px solid rgba(245, 158, 11, 0.2); color: #fbbf24; font-size: 13px; font-weight: 500;">
                            <i class="bi bi-shield-exclamation"></i>
                            <span>Límite diario de actualizaciones: @(3 - Model.ActualizacionesHoy) de 3 intentos disponibles hoy</span>
                        </div>
                    </div>

                    @if (TempData["Exito"] != null)
                    {
                        <div class="alert custom-alert d-flex align-items-center gap-2 mb-4" id="serverSuccessAlert">
                            <i class="bi bi-check-circle-fill"></i>
                            <span>@TempData["Exito"]</span>
                        </div>
                    }

                    <div id="profileError" class="error-toast" style="display: none;">
                        <i class="bi bi-exclamation-circle"></i>
                        <span id="profileErrorText"></span>
                    </div>

                    <form asp-action="GuardarPerfil" method="post" id="profileForm">

                        <div class="row mb-3 g-2">
                            <div class="col-12 col-md-10 mx-auto">
                                <div class="row g-2">
                                    <div class="col-12 col-sm-6">
                                        @if (usuario?.PasswordHash != "OAUTH_GOOGLE_EXTERNAL_ACCOUNT")
                                        {
                                            <button type="button" id="btnAbrirModalPassword" data-bs-toggle="modal" data-bs-target="#modalCambiarPassword" class="btn btn-sm btn-outline-light fw-semibold py-2.5 w-100" style="border-radius: 12px; font-size: 13px; border-color: rgba(255,255,255,0.15);">
                                                <i class="bi bi-key me-1"></i> Cambiar Clave
                                            </button>
                                        }
                                    </div>

                                    <div class="col-12 col-sm-6 text-sm-end">
                                        <button type="button" id="btnModoEditar" class="btn btn-outline-success btn-sm py-2.5 w-100 rounded-3 fw-semibold">
                                            <i class="bi bi-pencil-square me-1"></i> Editar Credenciales
                                        </button>
                                        <button type="button" id="btnCancelarEditar" class="btn btn-outline-secondary btn-sm py-2.5 w-100 rounded-3 fw-semibold d-none">
                                            Cancelar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12 col-md-10 mx-auto">
                                <div class="custom-input-group">
                                    <label>Nombre Completo / Razón Social</label>
                                    <div class="py-2" id="vistaNombre">
                                        <span class="fw-semibold text-white fs-5">@Model.NombreCompleto</span>
                                    </div>
                                    <div class="custom-input-wrapper d-none" id="inputNombreWrapper">
                                        <input type="text" name="nombreCompleto" id="inputNombre" class="form-control-custom" value="@Model.NombreCompleto" required />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row justify-content-center g-3">
                            <div class="col-12 col-sm-5">
                                <div class="custom-input-group">
                                    <label>Correo Electrónico</label>
                                    <div class="py-2 text-white-50 small" style="font-size: 14px;">
                                        <i class="bi bi-envelope-check me-2 text-success"></i>@(usuario?.Username ?? "No disponible")
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-sm-5">
                                <div class="custom-input-group">
                                    <label>Teléfono / Celular</label>
                                    <div class="py-2 d-flex align-items-center justify-content-between" id="vistaTelefono">
                                        @if (string.IsNullOrWhiteSpace(Model.Telefono) || Model.Telefono == "No especificado")
                                        {
                                            <span class="text-warning small italic"><i class="bi bi-exclamation-circle me-1"></i>Sin registrar</span>
                                            <button type="button" class="btn text-success p-0 btn-sm fw-bold border-0 bg-transparent btn-agregar-interno" onclick="activarEdiciónRapida()"><i class="bi bi-plus-circle me-1"></i>Agregar</button>
                                        }
                                        else
                                        {
                                            <span class="fw-semibold text-white">+51 @Model.Telefono</span>
                                        }
                                    </div>
                                    <div class="custom-input-wrapper d-none" id="inputTelefonoWrapper">
                                        <span class="phone-prefix-box">+51</span>
                                        <input type="text" name="telefono" id="clientPhoneInput" class="form-control-custom phone-input-padding" value="@Model.Telefono" placeholder="Ej. 987 654 321" autocomplete="off" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row justify-content-center g-3">
                            <div class="col-12 col-sm-5">
                                <div class="custom-input-group">
                                    <label>Documento de Identidad</label>
                                    <div class="py-2 d-flex align-items-center justify-content-between">
                                        @if (string.IsNullOrEmpty(Model.Documento))
                                        {
                                            <div id="vistaDocVacio" class="w-100 d-flex align-items-center justify-content-between">
                                                <span class="text-danger small"><i class="bi bi-shield-exclamation me-1"></i>Falta registrar</span>
                                                <button type="button" class="btn text-success p-0 btn-sm fw-bold border-0 bg-transparent btn-agregar-interno" onclick="activarEdiciónRapida()"><i class="bi bi-plus-circle me-1"></i>Agregar</button>
                                            </div>
                                            <div class="custom-input-wrapper d-none w-100" id="inputDocWrapper" style="display: flex; gap: 8px;">
                                                <select id="tipoDocSelect" style="background: rgba(15, 23, 42, 0.8); border: 1px solid #334155; color: #fff; border-radius: 12px; padding: 0 10px; font-size: 14px; outline: none; cursor: pointer;">
                                                    <option value="DNI">DNI</option>
                                                    <option value="RUC">RUC</option>
                                                </select>
                                                <input type="text" name="documento" id="docInput" class="form-control-custom flex-grow-1" placeholder="Ingresa tu DNI" inputmode="numeric" autocomplete="off" />
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="fw-semibold text-white"><i class="bi bi-vcard me-2 text-success"></i>@Model.Documento</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-sm-5">
                                <div class="custom-input-group">
                                    <label>Tipo de Cliente</label>
                                    <div class="py-2 text-white-50 small">
                                        <span class="badge bg-dark bg-opacity-40 text-success border border-success border-opacity-20 px-2.5 py-1.5 rounded-3 fw-bold" style="font-size: 12px; letter-spacing: 0.3px;">
                                            @Model.TipoCliente
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" style="border-color: rgba(255, 255, 255, 0.08);">

                        <div class="col-12 col-md-10 mx-auto d-none" id="seccionSubmitGuardar">
                            <button type="submit" id="btnGuardarConfig" class="btn btn-submit-profile w-100 shadow-sm" disabled style="background: #334155 !important; opacity: 0.5; cursor: not-allowed;">
                                <i class="bi bi-floppy me-2"></i> Guardar Cambios
                            </button>
                        </div>
                    </form>

                    @await Html.PartialAsync("_DireccionesPerfil")

                </div>
            </div>
        </div>
    </div>
</div>

<div id="loadingOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(4px); z-index: 9999; align-items: center; justify-content: center; flex-direction: column; gap: 15px;">
    <div class="spinner-border text-success" role="status" style="width: 3.5rem; height: 3.5rem; border-width: 5px; color: #10b981 !important;">
        <span class="visually-hidden">Cargando...</span>
    </div>
    <h5 class="text-white fw-semibold m-0" style="letter-spacing: 0.5px;">Actualizando datos...</h5>
    <p style="color: #94a3b8; font-size: 13px; margin: 0;">Espera un momento, mi king.</p>
</div>

<div class="modal fade" id="modalCambiarPassword" data-bs-backdrop="static" tabindex="-1" aria-labelledby="modalCambiarPasswordLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content profile-card p-2" style="background: rgba(15, 23, 42, 0.95) !important;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-white" id="modalCambiarPasswordLabel">
                    <i class="bi bi-shield-lock-fill text-success me-2" style="color: #10b981 !important;"></i>Actualizar Contraseña
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form asp-action="CambiarPassword" method="post" id="passwordForm">
                <div class="modal-body">

                    <div class="mb-3 p-2 rounded-3 d-flex align-items-center gap-2" style="background: rgba(245, 158, 11, 0.08); border: 1px solid rgba(245, 158, 11, 0.2); color: #fbbf24; font-size: 13px; font-weight: 500;">
                        <i class="bi bi-shield-exclamation"></i>
                        <span>Esta acción consume 1 intento diario (@(3 - Model.ActualizacionesHoy) disponibles)</span>
                    </div>

                    <div id="passwordErrorFront" class="error-toast mb-3" style="display: none;">
                        <i class="bi bi-exclamation-circle"></i>
                        <span id="passwordErrorFrontText"></span>
                    </div>

                    @if (TempData["ErrorPassword"] != null)
                    {
                        <div class="error-toast mb-3">
                            <i class="bi bi-exclamation-circle"></i>
                            <span>@TempData["ErrorPassword"]</span>
                        </div>
                    }

                    <div class="custom-input-group">
                        <label>Contraseña Actual</label>
                        <div class="custom-input-wrapper">
                            <input type="password" name="passwordActual" id="txtPasswordActual" class="form-control-custom password-input-padding" required />
                            <button type="button" class="password-toggle-btn" onclick="togglePasswordVisibility('txtPasswordActual', this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="custom-input-group">
                        <label>Nueva Contraseña</label>
                        <div class="custom-input-wrapper">
                            <input type="password" name="passwordNueva" id="txtPasswordNueva" class="form-control-custom password-input-padding" required />
                            <button type="button" class="password-toggle-btn" onclick="togglePasswordVisibility('txtPasswordNueva', this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="custom-input-group mb-2">
                        <label>Confirmar Nueva Contraseña</label>
                        <div class="custom-input-wrapper">
                            <input type="password" name="passwordConfirmar" id="txtPasswordConfirmar" class="form-control-custom password-input-padding" required />
                            <button type="button" class="password-toggle-btn" onclick="togglePasswordVisibility('txtPasswordConfirmar', this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-sm text-white-50" data-bs-dismiss="modal" style="font-size: 14px;">Cancelar</button>
                    <button type="submit" class="btn btn-submit-profile px-4 py-2" style="font-size: 14px !important;">
                        Actualizar Clave
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // =================================================================
    // 🌐 EXTRACCIÓN DE RAZOR AL ARRANQUE (Evita rotura total de color)
    // =================================================================
    @{
            double segundosRestantes = 0;
            if (Model.UltimaActualizacion.HasValue)
            {
                    var transcurrido = (DateTime.Now - Model.UltimaActualizacion.Value).TotalSeconds;
                    if (transcurrido < 300)
                    {
                            segundosRestantes = 300 - transcurrido;
                    }
            }
            bool sinIntentos = Model.ActualizacionesHoy >= 3;
    }

    let tiempoCooldown = Math.floor(@segundosRestantes);
    let limiteAlcanzado = @(sinIntentos ? "true" : "false");

    // --- ELEMENTOS DEL DOM MAESTROS ---
    const profileForm = document.getElementById("profileForm");
    const overlay = document.getElementById("loadingOverlay");
    const inputCelular = document.getElementById("clientPhoneInput");
    const tipoDocSelect = document.getElementById("tipoDocSelect");
    const docInput = document.getElementById("docInput");
    const submitPasswordBtn = document.querySelector("#passwordForm button[type='submit']");

    // --- ELEMENTOS DEL FLUJO INTELIGENTE (LECTURA/EDICIÓN) ---
    const btnModoEditar = document.getElementById("btnModoEditar");
    const btnCancelarEditar = document.getElementById("btnCancelarEditar");
    const seccionSubmitGuardar = document.getElementById("seccionSubmitGuardar");
    const btnGuardarConfig = document.getElementById("btnGuardarConfig");

    const inputNombre = document.getElementById("inputNombre");
    const vistaNombre = document.getElementById("vistaNombre");
    const inputNombreWrapper = document.getElementById("inputNombreWrapper");
    const vistaTelefono = document.getElementById("vistaTelefono");
    const inputTelefonoWrapper = document.getElementById("inputTelefonoWrapper");
    const vistaDocVacio = document.getElementById("vistaDocVacio");
    const inputDocWrapper = document.getElementById("inputDocWrapper");

    // 🧠 Respaldamos los valores que vienen limpios del servidor
    const valoresOriginales = {
        nombre: inputNombre ? inputNombre.value.trim() : "",
        telefono: inputCelular ? inputCelular.value.replace(/\s/g, "") : "",
        documento: docInput ? docInput.value.trim() : ""
    };

    // 🔥 EVALUADOR DE CAMBIOS EN VIVO
    function evaluarCambiosFormulario() {
        if (!btnGuardarConfig) return;

        const nombreActual = inputNombre ? inputNombre.value.trim() : "";
        const telefonoActual = inputCelular ? inputCelular.value.replace(/\s/g, "") : "";
        const docActual = docInput ? docInput.value.trim() : "";

        // Comparamos contra el objeto original
        const hayModificaciones =
            nombreActual !== valoresOriginales.nombre ||
            telefonoActual !== valoresOriginales.telefono ||
            docActual !== valoresOriginales.documento;

        if (hayModificaciones) {
            btnGuardarConfig.disabled = false;
            btnGuardarConfig.style.background = "#10b981"; // Verde esmeralda premium
            btnGuardarConfig.style.opacity = "1";
            btnGuardarConfig.style.cursor = "pointer";
        } else {
            btnGuardarConfig.disabled = true;
            btnGuardarConfig.style.background = "#334155"; // Gris oscuro bloqueado
            btnGuardarConfig.style.opacity = "0.5";
            btnGuardarConfig.style.cursor = "not-allowed";
        }
    }

    // Escuchadores de eventos en tiempo real
    if (inputNombre) inputNombre.addEventListener("input", evaluarCambiosFormulario);
    if (inputCelular) inputCelular.addEventListener("input", evaluarCambiosFormulario);
    if (docInput) docInput.addEventListener("input", evaluarCambiosFormulario);

    // Conmutador de pantallas
    function cambiarModoVisual(enModoEdicion) {
        if (enModoEdicion) {
            if (vistaNombre) vistaNombre.classList.add("d-none");
            if (vistaTelefono) vistaTelefono.classList.add("d-none");
            if (vistaDocVacio) vistaDocVacio.classList.add("d-none");

            if (inputNombreWrapper) inputNombreWrapper.classList.remove("d-none");
            if (inputTelefonoWrapper) inputTelefonoWrapper.classList.remove("d-none");
            if (inputDocWrapper) inputDocWrapper.classList.remove("d-none");

            if (seccionSubmitGuardar) seccionSubmitGuardar.classList.remove("d-none");
            if (btnCancelarEditar) btnCancelarEditar.classList.remove("d-none");
            if (btnModoEditar) btnModoEditar.classList.add("d-none");

            evaluarCambiosFormulario();
        } else {
            // Si cancela, restauramos los valores iniciales de la BD
            if (inputNombre) inputNombre.value = valoresOriginales.nombre;
            if (inputCelular) inputCelular.value = valoresOriginales.telefono;
            if (docInput) docInput.value = valoresOriginales.documento;

            if (vistaNombre) vistaNombre.classList.remove("d-none");
            if (vistaTelefono) vistaTelefono.classList.remove("d-none");
            if (vistaDocVacio) vistaDocVacio.classList.remove("d-none");

            if (inputNombreWrapper) inputNombreWrapper.classList.add("d-none");
            if (inputTelefonoWrapper) inputTelefonoWrapper.classList.add("d-none");
            if (inputDocWrapper) inputDocWrapper.classList.add("d-none");

            if (seccionSubmitGuardar) seccionSubmitGuardar.classList.add("d-none");
            if (btnCancelarEditar) btnCancelarEditar.classList.add("d-none");
            if (btnModoEditar) btnModoEditar.classList.remove("d-none");
        }
    }

    if (btnModoEditar) btnModoEditar.addEventListener("click", () => cambiarModoVisual(true));
    if (btnCancelarEditar) btnCancelarEditar.addEventListener("click", () => cambiarModoVisual(false));

    window.activarEdiciónRapida = function() {
        if (btnModoEditar && !btnModoEditar.disabled) cambiarModoVisual(true);
    };

    // --- FUNCIÓN SÚPER PRESTIGIO: INTERRUPTOR OJITO DE CONTRASEÑA ---
    function togglePasswordVisibility(inputId, buttonEl) {
        const inputField = document.getElementById(inputId);
        const icon = buttonEl.querySelector("i");

        if (inputField && icon) {
            if (inputField.type === "password") {
                inputField.type = "text";
                icon.className = "bi bi-eye-slash";
            } else {
                inputField.type = "password";
                icon.className = "bi bi-eye";
            }
        }
    }

    // --- MANEJO DE ALERTA DE ÉXITO ---
    const successAlert = document.getElementById("serverSuccessAlert");
    if (successAlert) {
        setTimeout(() => {
            successAlert.style.transition = "opacity 0.5s ease, transform 0.5s ease";
            successAlert.style.opacity = "0";
            successAlert.style.transform = "translateY(-8px)";
            setTimeout(() => successAlert.remove(), 500);
        }, 4000);
    }

    // --- ALERTA DINÁMICA DE ERRORES ---
    function lanzarErrorFront(msg) {
        const errBox = document.getElementById("profileError");
        const errText = document.getElementById("profileErrorText");
        if (errBox && errText) {
            errText.innerText = msg;
            errBox.style.display = "flex";

            setTimeout(() => {
                errBox.style.transition = "opacity 0.5s ease";
                errBox.style.opacity = "0";
                setTimeout(() => {
                    errBox.style.display = "none";
                    errBox.style.opacity = "1";
                }, 500);
            }, 4000);
        }
    }

    // --- MÁSCARA INTELIGENTE PARA EL TELÉFONO CELULAR (MÓDULO PERÚ) ---
    function limpiarYFormatearCelular(valor) {
        let digitos = valor.replace(/\D/g, "");

        if (digitos.length > 9 && digitos.startsWith("51")) {
            digitos = digitos.substring(2);
        }

        if (digitos.length > 0 && digitos[0] !== '9') {
            lanzarErrorFront("El número celular en el Perú debe empezar con el dígito 9");
            return "";
        }

        digitos = digitos.substring(0, 9);

        let formateado = "";
        if (digitos.length > 0) formateado += digitos.substring(0, 3);
        if (digitos.length > 3) formateado += " " + digitos.substring(3, 6);
        if (digitos.length > 6) formateado += " " + digitos.substring(6, 9);

        return formateado;
    }

    if (inputCelular) {
        inputCelular.addEventListener("input", () => {
            inputCelular.value = limpiarYFormatearCelular(inputCelular.value);
        });

        inputCelular.addEventListener("paste", (e) => {
            e.preventDefault();
            const portapapeles = (e.clipboardData || window.clipboardData).getData("text");
            inputCelular.value = limpiarYFormatearCelular(portapapeles);
        });

        if(inputCelular.value) {
            inputCelular.value = limpiarYFormatearCelular(inputCelular.value);
        }
    }

    // =================================================================
    // 🛡️ REUBICACIÓN DEL CANDADO DE SEGURIDAD (TEMPORIZADOR EXTERNO)
    // =================================================================
    if (limiteAlcanzado) {
        congelarControlesPorLimite();
    } else if (tiempoCooldown > 0) {
        activarContadorRegresivoMaestro(tiempoCooldown);
    }

    function congelarControlesPorLimite() {
        const msgLimite = '<i class="bi bi-x-circle me-1"></i> Intentos agotados hoy';
        if (btnModoEditar) {
            btnModoEditar.disabled = true;
            btnModoEditar.innerHTML = msgLimite;
            btnModoEditar.style.borderColor = "rgba(239, 68, 68, 0.4)";
            btnModoEditar.style.color = "#f87171";
        }
        document.querySelectorAll(".btn-agregar-interno").forEach(btn => btn.remove());

        if (submitPasswordBtn) {
            submitPasswordBtn.disabled = true;
            submitPasswordBtn.style.backgroundColor = "#64748b";
            submitPasswordBtn.innerHTML = '<i class="bi bi-x-circle me-2"></i> Límite agotado';
        }
    }

    function activarContadorRegresivoMaestro(segundos) {
        if (!btnModoEditar) return;

        btnModoEditar.disabled = true;
        if (submitPasswordBtn) submitPasswordBtn.disabled = true;
        document.querySelectorAll(".btn-agregar-interno").forEach(btn => btn.classList.add("d-none"));

        const intervalo = setInterval(() => {
            let minutos = Math.floor(segundos / 60);
            let segs = segundos % 60;
            let tiempoTexto = `${minutos}:${segs < 10 ? '0' : ''}${segs}`;

            btnModoEditar.innerHTML = `<i class="bi bi-hourglass-split me-1"></i> Espera ${tiempoTexto}`;
            if (submitPasswordBtn) submitPasswordBtn.innerHTML = `<i class="bi bi-hourglass-split me-2"></i> Espera ${tiempoTexto}`;

            segundos--;

            if (segundos < 0) {
                clearInterval(intervalo);
                btnModoEditar.disabled = false;
                btnModoEditar.innerHTML = '<i class="bi bi-pencil-square me-1"></i> Editar Credenciales';
                document.querySelectorAll(".btn-agregar-interno").forEach(btn => btn.classList.remove("d-none"));

                if (submitPasswordBtn) {
                    submitPasswordBtn.disabled = false;
                    submitPasswordBtn.innerHTML = 'Actualizar Clave';
                }
            }
        }, 1000);
    }

    // --- CONTROL DE DNI / RUC (SUNAT/RENIEC) ---
    if (docInput && tipoDocSelect) {
        tipoDocSelect.addEventListener("change", () => {
            docInput.value = "";
            docInput.placeholder = tipoDocSelect.value === "DNI" ? "Ingresa tu DNI" : "Ingresa tu RUC";
        });

        docInput.addEventListener("input", () => {
            let limpio = docInput.value.replace(/\D/g, "");
            const maxDigitos = tipoDocSelect.value === "DNI" ? 8 : 11;
            docInput.value = limpio.substring(0, maxDigitos);
        });

        docInput.addEventListener("paste", (e) => {
            e.preventDefault();
            const portapapeles = (e.clipboardData || window.clipboardData).getData("text");
            let soloNumeros = portapapeles.replace(/\D/g, "");
            const maxDigitos = tipoDocSelect.value === "DNI" ? 8 : 11;
            docInput.value = soloNumeros.substring(0, maxDigitos);
        });
    }

    // --- CONTROL FINAL DE SUBMIT CON RETRASO DE UX ---
    if (profileForm) {
        profileForm.addEventListener("submit", (e) => {
            e.preventDefault();

            if (inputCelular) {
                const telefonoLimpio = inputCelular.value.replace(/\s/g, "");
                if (telefonoLimpio.length > 0 && telefonoLimpio.length !== 9) {
                    lanzarErrorFront("Asegúrate de ingresar los 9 dígitos completos de tu celular.");
                    return;
                }
            }

            if (docInput && tipoDocSelect) {
                const valorDoc = docInput.value.trim();
                const tipoSelected = tipoDocSelect.value;

                if (tipoSelected === "DNI" && valorDoc.length !== 8) {
                    lanzarErrorFront("El DNI debe tener exactamente 8 dígitos numéricos.");
                    return;
                }

                if (tipoSelected === "RUC") {
                    if (valorDoc.length !== 11) {
                        lanzarErrorFront("El RUC debe tener exactamente 11 dígitos numéricos.");
                        return;
                    }
                    if (!valorDoc.startsWith("10") && !valorDoc.startsWith("20") && !valorDoc.startsWith("15")) {
                        lanzarErrorFront("RUC inválido. En Perú deben comenzar con 10, 15 o 20.");
                        return;
                    }
                }
            }

            if (btnGuardarConfig) btnGuardarConfig.disabled = true;
            if (overlay) overlay.style.display = "flex";

            setTimeout(() => {
                e.target.submit();
            }, 1500);
        });
    }

    // --- CONTROL DE VALIDACIONES PARA EL MODAL DE CONTRASEÑA ---
    const passwordForm = document.getElementById("passwordForm");
    const txtPasswordActual = document.getElementById("txtPasswordActual");
    const txtPasswordNueva = document.getElementById("txtPasswordNueva");
    const txtPasswordConfirmar = document.getElementById("txtPasswordConfirmar");

    @if (TempData["ErrorPassword"] != null)
    {
            <text>
                window.addEventListener("load", () => {
                    const modalElement = document.getElementById('modalCambiarPassword');
                    if (modalElement && typeof bootstrap !== 'undefined') {
                        const passwordModalInstance = new bootstrap.Modal(modalElement);
                        passwordModalInstance.show();
                    }
                });
            </text>
    }

    function lanzarErrorPassword(msg) {
        const errBox = document.getElementById("passwordErrorFront");
        const errText = document.getElementById("passwordErrorFrontText");
        if (errBox && errText) {
            errText.innerText = msg;
            errBox.style.display = "flex";
            errBox.style.opacity = "1";
        }
    }

    if (passwordForm) {
        passwordForm.addEventListener("submit", (e) => {
            e.preventDefault();

            const actual = txtPasswordActual.value.trim();
            const nueva = txtPasswordNueva.value.trim();
            const confirmar = txtPasswordConfirmar.value.trim();

            if (!actual || !nueva || !confirmar) {
                lanzarErrorPassword("Todos los campos son obligatorios.");
                return;
            }

            if (nueva.length < 6) {
                lanzarErrorPassword("La nueva contraseña debe poseer mínimo 6 caracteres.");
                return;
            }

            if (nueva !== confirmar) {
                lanzarErrorPassword("La nueva contraseña y su confirmación no coinciden.");
                return;
            }

            if (overlay) overlay.style.display = "flex";

            setTimeout(() => {
                e.target.submit();
            }, 1500);
        });
    }
</script>
