@using Microsoft.AspNetCore.Http
@using Microsoft.EntityFrameworkCore

@inject IHttpContextAccessor HttpContextAccessor
@inject Negocio.Web.Data.NegocioDbContext _context

@{
    bool abierto = ViewData["Abierto"] as bool? ?? true;

    var sessionRol =
        HttpContextAccessor.HttpContext?.Session.GetString("ROL");

    var sessionUser =
        HttpContextAccessor.HttpContext?.Session.GetString("USER");

    /*
     * Obtener las categorías que realmente existen
     * en la tabla Producto.
     */
    var categoriasRegistradas = await _context.Productos
        .AsNoTracking()
        .Where(producto => producto.Activo)
        .Select(producto => producto.Area)
        .ToListAsync();

    var categorias = categoriasRegistradas
        .Where(area => !string.IsNullOrWhiteSpace(area))
        .Select(area => area.Trim().ToUpperInvariant())
        .Distinct()
        .OrderBy(area => area)
        .ToList();
}

<!-- TOP BAR -->
<div class="topbar-sticky py-2 px-2 px-sm-3 px-md-4 shadow-sm w-100">

    <div class="d-flex justify-content-between align-items-center w-100">

        <!-- MARCA -->
        <div class="d-flex align-items-center">

            <a href="#inicio"
               class="d-flex align-items-center text-decoration-none transition-transform"
               style="margin: 0;"
               title="Iza Motors">

                <img src="/img/iza.ico"
                     alt="Logo de Iza Motors"
                     class="d-none d-md-inline"
                     style="height: 28px;
                            width: auto;
                            object-fit: contain;" />

                <div class="d-flex flex-column ms-0 ms-md-2"
                     style="line-height: 1.1;">

                    <span class="text-white fw-bold"
                          style="font-size: clamp(0.85rem, 2vw, 0.95rem);
                                 letter-spacing: 0.5px;
                                 white-space: nowrap;
                                 font-family: 'Inter', sans-serif;">
                        Iza Motors
                    </span>

                    <span class="d-flex align-items-center mt-1"
                          style="font-size: 0.58rem;
                                 font-weight: 700;
                                 text-transform: uppercase;
                                 letter-spacing: 0.5px;
                                 color: rgba(255,255,255,0.55);">

                        <span class="dot @(abierto ? "bg-success" : "bg-danger")"
                              style="width: 6px;
                                     height: 6px;
                                     margin-right: 5px;
                                     box-shadow: none;">
                        </span>

                        @(abierto ? "Taller abierto" : "Taller cerrado")
                    </span>

                </div>
            </a>
        </div>

        <!-- MENÚ DE ESCRITORIO -->
        <div class="d-none d-xl-flex justify-content-center gap-2 central-nav-tabs flex-grow-1 mx-3">

            <!-- PRODUCTOS -->
            <div class="dropdown h-100 d-flex align-items-center">

                <a href="#"
                   class="nav-link-tab d-flex align-items-center justify-content-center px-3 text-decoration-none dropdown-toggle"
                   id="dropdownProductosPC"
                   data-bs-toggle="dropdown"
                   aria-expanded="false">

                    <span>Productos</span>
                </a>

                <ul class="dropdown-menu shadow mt-0"
                    aria-labelledby="dropdownProductosPC"
                    style="background-color: #0b1d33;
                           border: 1px solid rgba(255,255,255,0.1);
                           padding: 0.5rem 0;">

                    @if (categorias.Any())
                    {
                        foreach (var categoria in categorias)
                        {
                            <li>
                                <a asp-controller="ProductoPublic"
                                   asp-action="Categoria"
                                   asp-route-area="@categoria"
                                   class="dropdown-item text-light py-2">

                                    <i class="bi bi-gear-wide-connected me-2 text-danger"
                                       style="font-size: 0.85rem;">
                                    </i>

                                    @categoria
                                </a>
                            </li>
                        }
                    }
                    else
                    {
                        <li>
                            <span class="dropdown-item text-white-50 py-2">
                                No hay categorías disponibles
                            </span>
                        </li>
                    }

                </ul>
            </div>

            <a href="#trabajos-reales"
               class="nav-link-tab d-flex align-items-center justify-content-center px-3 text-decoration-none">
                <span>Proyectos</span>
            </a>

            <a href="#como-trabajamos"
               class="nav-link-tab d-flex align-items-center justify-content-center px-3 text-decoration-none">
                <span>¿Cómo pedir?</span>
            </a>

            <a href="#envios"
               class="nav-link-tab d-flex align-items-center justify-content-center px-3 text-decoration-none">
                <span>Modalidades de atención</span>
            </a>

            <a href="#preguntas"
               class="nav-link-tab d-flex align-items-center justify-content-center px-3 text-decoration-none">
                <span>Dudas</span>
            </a>

            <a href="#contacto"
               class="nav-link-tab d-flex align-items-center justify-content-center px-3 text-decoration-none">
                <span>Contacto</span>
            </a>

        </div>

        <!-- BUSCADOR, CUENTA Y MENÚ MÓVIL -->
        <div class="d-flex align-items-center gap-2 gap-sm-3">

            <!-- BUSCADOR -->
            <div class="search-mockup position-relative">

                <i class="bi bi-search text-white-50"
                   style="font-size: 0.8rem;">
                </i>

                <input type="text"
                       id="buscadorTop"
                       class="ms-1 ms-sm-2"
                       placeholder="Buscar..."
                       autocomplete="off" />

                <div id="listaResultadosTop"
                     class="position-absolute shadow-lg rounded-3 mt-2">
                </div>

            </div>

            <!-- CUENTA -->
            @if (string.IsNullOrEmpty(sessionRol) || sessionRol != "CLIENTE")
            {
                <a href="/Login/Index"
                   class="btn-login-lock d-flex align-items-center justify-content-center"
                   title="Ingresar a mi cuenta"
                   style="height: 32px;
                              width: 32px;
                              margin: 0;">

                    <i class="bi bi-person m-0"
                       style="font-size: 1.1rem;">
                    </i>
                </a>
            }
            else
            {
                <div class="dropdown">

                    <button class="btn-login-lock d-flex align-items-center justify-content-center border-0 dropdown-toggle"
                            type="button"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            title="Mi cuenta"
                            style="height: 32px;
                                       width: 32px;
                                       margin: 0;
                                       background: #10b981;">

                        <i class="bi bi-person-fill m-0 text-white"></i>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end shadow"
                        style="background-color: #0b1d33;
                                   border: 1px solid rgba(255,255,255,0.1);">

                        <li class="px-3 py-1">
                            <span class="text-white-50 small">
                                Hola, <strong>@sessionUser</strong>
                            </span>
                        </li>

                        <li>
                            <hr class="dropdown-divider"
                                style="border-color: rgba(255,255,255,0.1);" />
                        </li>

                        <li>
                            <a class="dropdown-item text-light"
                               href="/Cliente/MisPedidos">

                                <i class="bi bi-box-seam me-2 text-success"></i>
                                Mis Pedidos
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item text-light"
                               href="/Cliente/MiPerfil">

                                <i class="bi bi-gear me-2 text-info"></i>
                                Mi Perfil
                            </a>
                        </li>

                        <li>
                            <hr class="dropdown-divider"
                                style="border-color: rgba(255,255,255,0.1);" />
                        </li>

                        <li>
                            <a class="dropdown-item text-danger fw-bold"
                               href="/Login/Logout">

                                <i class="bi bi-box-arrow-right me-2"></i>
                                Cerrar Sesión
                            </a>
                        </li>

                    </ul>
                </div>
            }

            <!-- HAMBURGUESA -->
            <button class="btn-menu-burger d-xl-none"
                    type="button"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#menuMovilLateral"
                    aria-controls="menuMovilLateral"
                    style="height: 32px;
                           width: 38px;
                           margin: 0;">

                <i class="bi bi-list"></i>
            </button>

        </div>
    </div>
</div>

<!-- MENÚ LATERAL PARA MÓVILES -->
<div class="offcanvas offcanvas-start menu-movil-dark"
     tabindex="-1"
     id="menuMovilLateral"
     aria-labelledby="menuMovilLateralLabel">

    <div class="offcanvas-header border-bottom border-secondary border-opacity-20">

        <h5 class="offcanvas-title fw-bold text-white"
            id="menuMovilLateralLabel">

            <i class="bi bi-grid-fill text-danger me-2"></i>
            Menú Iza Motors
        </h5>

        <button type="button"
                class="btn-close btn-close-white"
                data-bs-dismiss="offcanvas"
                aria-label="Cerrar">
        </button>

    </div>

    <div class="offcanvas-body p-0">

        <div class="list-group list-group-flush">

            <!-- PRODUCTOS -->
            <a href="#subcatProductos"
               class="list-group-item list-group-item-action menu-movil-item d-flex align-items-center justify-content-between w-100"
               data-bs-toggle="collapse"
               role="button"
               aria-expanded="false"
               aria-controls="subcatProductos">

                <span>
                    <i class="bi bi-box-seam me-3 text-danger"></i>
                    Productos
                </span>

                <i class="bi bi-chevron-down small opacity-50"></i>
            </a>

            <div class="collapse bg-dark bg-opacity-25"
                 id="subcatProductos">

                <div class="list-group list-group-flush">

                    @if (categorias.Any())
                    {
                        foreach (var categoria in categorias)
                        {
                            <a asp-controller="ProductoPublic"
                               asp-action="Categoria"
                               asp-route-area="@categoria"
                               class="list-group-item list-group-item-action menu-movil-subitem">

                                <i class="bi bi-gear-wide-connected me-2 text-danger"></i>
                                @categoria
                            </a>
                        }
                    }
                    else
                    {
                        <span class="list-group-item menu-movil-subitem text-white-50">
                            No hay categorías disponibles
                        </span>
                    }

                </div>
            </div>

            <!-- PROYECTOS -->
            <a href="#trabajos-reales"
               class="list-group-item list-group-item-action menu-movil-item btn-scroll-movil">

                <div class="d-flex align-items-center justify-content-between w-100">

                    <span>
                        <i class="bi bi-images me-3 text-danger"></i>
                        Nuestros Proyectos
                    </span>

                    <i class="bi bi-chevron-right small opacity-50"></i>
                </div>
            </a>

            <!-- CÓMO COMPRAR -->
            <a href="#como-trabajamos"
               class="list-group-item list-group-item-action menu-movil-item btn-scroll-movil">

                <div class="d-flex align-items-center justify-content-between w-100">

                    <span>
                        <i class="bi bi-patch-check me-3 text-danger"></i>
                        ¿Como funciona?
                    </span>

                    <i class="bi bi-chevron-right small opacity-50"></i>
                </div>
            </a>

            <!-- MODALIDADES DE ATENCIÓN -->
            <a href="#envios"
               class="list-group-item list-group-item-action menu-movil-item btn-scroll-movil">

                <div class="d-flex align-items-center justify-content-between w-100">

                    <span>
                        <i class="bi bi-shop me-3 text-danger"></i>
                        Modalidades de atención
                    </span>

                    <i class="bi bi-chevron-right small opacity-50"></i>
                </div>
            </a>

            <!-- PREGUNTAS -->
            <a href="#preguntas"
               class="list-group-item list-group-item-action menu-movil-item btn-scroll-movil">

                <div class="d-flex align-items-center justify-content-between w-100">

                    <span>
                        <i class="bi bi-question-circle me-3 text-danger"></i>
                        Preguntas Frecuentes
                    </span>

                    <i class="bi bi-chevron-right small opacity-50"></i>
                </div>
            </a>

            <!-- CONTACTO -->
            <a href="#contacto"
               class="list-group-item list-group-item-action menu-movil-item btn-scroll-movil">

                <div class="d-flex align-items-center justify-content-between w-100">

                    <span>
                        <i class="bi bi-telephone me-3 text-danger"></i>
                        Contacto
                    </span>

                    <i class="bi bi-chevron-right small opacity-50"></i>
                </div>
            </a>

        </div>
    </div>
</div>