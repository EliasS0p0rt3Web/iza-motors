@{
    Layout = null;
    ViewData["Title"] = "IZA MOTORS";
}
@model List<Negocio.Web.Models.Entities.TrabajoMarketing>


@using Microsoft.EntityFrameworkCore
@inject Negocio.Web.Data.NegocioDbContext _context

@{
    // Consultamos el estado de la tienda
    var config = await _context.ConfiguracionesTienda.FirstOrDefaultAsync(x => x.Id == 1);
    ViewData["Abierto"] = config?.EstaAbierto ?? true;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/x-icon" href="~/img/izas.ico" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Oswald:wght@600;700&display=swap"
          rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Usa el símbolo ~ para que ASP.NET resuelva la ruta desde wwwroot -->
    <!-- asp-append-version="true" evita que el navegador guarde en caché versiones viejas de tu CSS -->
    <link rel="stylesheet" href="~/css/home-estilos.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="~/css/iza-home.css"
          asp-append-version="true" />
    <link rel="stylesheet"
          href="~/css/iza-hero-patch.css"
          asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
</head>



<body class="iza-home">

    <!-- 1️⃣ PRELOADER -->
    @await Html.PartialAsync("_PreloaderPublico")
    
    <!-- TOP BAR DINÁMICA -->
    @await Html.PartialAsync("_TopbarPublica")

    <a href="https://wa.me/51921726629?text=Hola%20quiero%20cotizar%20tubos%20para%20cortinas"
       class="whatsapp-float"
       target="_blank"
       aria-label="WhatsApp">
        <i class="bi bi-whatsapp"></i>
    </a>

    <div class="video-tutorial-wrapper">
        <div id="videoMenu" class="video-menu-panel">
            <div class="video-menu-header">
                <i class="bi bi-play-circle-fill me-2"></i> Guía Visual E&E
            </div>
            <div class="video-menu-body">
                <div class="video-option">
                    <p>¿Cómo reservar en la web?</p>
                    @* 🔥 Pasamos el link directo como texto *@
                    <button onclick="verVideo('https://youtu.be/n6YDSwKCUt4')" class="btn-ver-video">
                        <i class="bi bi-play-fill"></i> Ver
                    </button>
                </div>
                <div class="video-option">
                    <p>Tips: Sala, Ducha o Vitrina</p>
                    <button onclick="verVideo('URL_VIDEO_2')" class="btn-ver-video">
                        <i class="bi bi-play-fill"></i> Ver
                    </button>
                </div>
                <div class="video-option border-0">
                    <p>Recomendaciones para tu hogar</p>
                    <button onclick="verVideo('URL_VIDEO_3')" class="btn-ver-video">
                        <i class="bi bi-play-fill"></i> Ver
                    </button>
                </div>
            </div>
        </div>

        <button type="button" id="btnVideoToggle" class="video-float-btn" title="Tutoriales">
            <i class="bi bi-youtube"></i>
        </button>
    </div>


    <!-- BOTÓN FLOTANTE DE RESERVA INTELIGENTE - MÓVIL -->
    <a href="@Url.Action("Consultar", "Reserva")"
       id="reservaFloatMobile"
       class="reserva-float-m d-flex align-items-center"
       title="Consultar Reserva">

        <div class="icon-box-m">
            <i class="bi bi-search"></i>
        </div>
        <span class="text-box-m">Consultar reserva</span>
    </a>
    
    @await Html.PartialAsync("_HeroPublico")
    @await Html.PartialAsync("_ProyectosCarrusel", Model)
    @await Html.PartialAsync("_ModalInteres")
    @await Html.PartialAsync("_ComoTrabajamos")
    @await Html.PartialAsync("_LogisticaDespacho")
    @await Html.PartialAsync("_FaqPublico")
    @await Html.PartialAsync("_CotizadorCategorias")

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <script>
        const swiper = new Swiper('.swiper', {
          loop: true,
          autoplay: { delay: 2500, disableOnInteraction: false },
          slidesPerView: 1, // 1 en móvil
          spaceBetween: 20,
          breakpoints: {
            992: { slidesPerView: 4, spaceBetween: 30 } // 4 en PC
          },
          pagination: { el: '.swiper-pagination', clickable: true },
        });
    </script>


    <div class="modal fade" id="modalBienvenida" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-4 shadow-lg text-center p-4">
                <div class="modal-body">
                    <i class="bi bi-emoji-smile text-success" style="font-size: 50px;"></i>
                    <h4 class="fw-bold mt-3">¡Bienvenido!</h4>
                    <p class="text-muted">@TempData["Bienvenida"]</p>
                </div>
            </div>
        </div>
    </div>

   

    @if (TempData["Despedida"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show position-fixed top-0 end-0 m-3" style="z-index: 9999;" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["Despedida"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>

        <script>
            // Opcional: Que el mensaje de despedida se oculte solo después de 3 segundos
            setTimeout(function() {
                var alert = document.querySelector('.alert');
                if(alert) alert.style.display = 'none';
            }, 3000);
        </script>
    }


    @await Html.PartialAsync("_BuzonSugerencias")
    <!-- FOOTER -->
    @await Html.PartialAsync("_FooterPublico")
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/home-scripts.js" asp-append-version="true"></script>
</body>
</html>
