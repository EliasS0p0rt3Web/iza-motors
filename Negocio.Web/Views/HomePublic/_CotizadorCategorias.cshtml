<!-- CATEGORÍAS: COTIZADOR INTELIGENTE -->
<section class="cotizador-section border-top" id="cotizar">
    <div class="container text-center">

        <h2 class="display-6 fw-800 text-dark mb-2">Cotizador Inteligente</h2>
        <p class="text-muted mb-5">Ingresa las medidas exactas de tu espacio y nuestro algoritmo calculará tu presupuesto al instante.</p>

        <div class="row g-3 justify-content-center">

            <div class="col-12 col-md-6 col-lg-3">
                <a asp-controller="Cotizacion" asp-action="TuboCortinas" class="cotizador-link">
                    <div class="cotizador-pro-card horizontal-mobile-card">

                        <div class="img-tech-container">
                            <img src="/img/home/icon-tub.webp" alt="Set de Cortina">
                        </div>

                        <div class="card-tech-info text-start">
                            <h5>Set de Cortina</h5>
                            <p>Kit completo: Tubo + Soportes + Terminales</p>
                        </div>

                        <div class="btn-tech-start">
                            <span class="d-none d-md-inline">Cotizar</span> <i class="bi bi-chevron-right"></i>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <a asp-controller="CotizacionPasamanos" asp-action="Index" class="cotizador-link">
                    <div class="cotizador-pro-card horizontal-mobile-card">

                        <div class="img-tech-container">
                            <img src="/img/home/icon-pasamanos.webp" alt="Sistema de Pasamanos">
                        </div>

                        <div class="card-tech-info text-start">
                            <h5>Pasamanos</h5>
                            <p>Kit de seguridad con soportes reforzados</p>
                        </div>

                        <div class="btn-tech-start">
                            <span class="d-none d-md-inline">Cotizar</span> <i class="bi bi-chevron-right"></i>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <a asp-controller="CotizacionRiel" asp-action="Index" class="cotizador-link">
                    <div class="cotizador-pro-card horizontal-mobile-card">

                        <div class="img-tech-container">
                            <img src="/img/home/icon-riel.webp" alt="Riel Hotelero">
                        </div>

                        <div class="card-tech-info text-start">
                            <h5>Riel Hotelero</h5>
                            <p>Sistema a pita armado listo para instalar</p>
                        </div>

                        <div class="btn-tech-start">
                            <span class="d-none d-md-inline">Cotizar</span> <i class="bi bi-chevron-right"></i>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <a asp-controller="CotizacionDucha" asp-action="Index" class="cotizador-link">
                    <div class="cotizador-pro-card horizontal-mobile-card">

                        <div class="img-tech-container">
                            <img src="/img/home/icon-ducha.webp" alt="Barra de Ducha">
                        </div>

                        <div class="card-tech-info text-start">
                            <h5>Barra de Ducha</h5>
                            <p>Set inoxidable de alta resistencia al agua</p>
                        </div>

                        <div class="btn-tech-start">
                            <span class="d-none d-md-inline">Cotizar</span> <i class="bi bi-chevron-right"></i>
                        </div>
                    </div>
                </a>
            </div>

        </div>
    </div>
</section>