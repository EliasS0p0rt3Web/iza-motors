@* 
   Cotización - Ducha y Toallera (Versión Premium Final)
*@

@{
    bool esClienteLogueado = Context.Session.GetInt32("USER_ID") != null;
    ViewData["Title"] = "Cotización - Accesorios de Baño";
    Layout = "_LayoutCotizacion";
}

<div id="zonaCotizacion">

    <!-- 1. HEADER REUTILIZABLE -->
    <div id="headerCotizacion" class="container-fluid px-0 mb-4">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <a href="javascript:void(0);" class="btn btn-outline-light back-button" onclick="UI.abrirModalSalir()">

                    @if (Context.Session.GetInt32("USER_ID") != null)
                    {
                        @* 👤 Si está logueado en su intranet de cliente *@
                        <span class="d-none d-md-inline">⬅ Volver a mi Intranet</span>
                        <span class="d-inline d-md-none">⬅</span>
                    }
                    else
                    {
                        @* 🕵️‍♂️ Si entró de forma anónima desde la web pública *@
                        <span class="d-none d-md-inline">⬅ Volver al inicio</span>
                        <span class="d-inline d-md-none">⬅</span>
                    }

                </a>
                <h2 class="m-0 fw-bold main-title">BAÑOS</h2>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-light fw-semibold material-badge" onclick="new bootstrap.Modal(document.getElementById('seccionModal')).show()">
                    <i class="bi bi-droplet me-1"></i> <span id="lblSeccion">DUCHA</span>
                </button>
                <button class="btn btn-outline-light fw-semibold material-badge" onclick="new bootstrap.Modal(document.getElementById('materialModal')).show()">
                    <i class="bi bi-layers me-1"></i> <span id="lblMaterial">ALUMINIO</span>
                </button>
            </div>
        </div>
    </div>

    <!-- 2. WIZARD COMPACTO -->
    <div class="wizard-progress mb-5">
        <div class="wizard-step active" data-step="1">
            <div class="step-circle">1</div>
            <div class="step-label">Tubo</div>
        </div>
        <div class="wizard-line"></div>
        <div class="wizard-step" data-step="2">
            <div class="step-circle">2</div>
            <div class="step-label">Medida</div>
        </div>
        <div class="wizard-line"></div>
        <div class="wizard-step" data-step="3">
            <div class="step-circle">3</div>
            <div class="step-label">Accesorios</div>
        </div>
        <div class="wizard-line"></div>
        <div class="wizard-step" data-step="4">
            <div class="step-circle">4</div>
            <div class="step-label">Resultado</div>
        </div>
    </div>

    <!-- 3. PASO 1: SELECCIÓN DE MODELO -->
    <div id="paso1" class="card mb-4 p-4 shadow-sm">
        <h5 class="mb-3">1️⃣ Selecciona el tubo</h5>
        <div class="row g-4 mb-4" id="contenedorTubos"></div>

        <!-- ⚓ BARRA FIJA INFERIOR EXCLUSIVA DEL PASO 1 (MUDACIÓN GLOBAL) -->
        <div id="barraStickyPaso1" class="sticky-action-container d-none">
            <div class="row m-0 justify-content-end">
                <div class="col-12 col-md-4 p-0" id="columnaBotonConfirmarMaster"></div>
            </div>
        </div>
    </div>

    <!-- 4. PASO 2: MEDIDAS (CONTROLES PREMIUM) -->
    <div id="pasoMedida" class="card mb-4 p-4 d-none shadow-sm">
        <h5 class="mb-4">2️⃣ Define la medida total</h5>

        <!-- Franja de ayuda (Hint) -->
        <div id="hintUsuario" class="hint-usuario d-none">
            <i class="bi bi-hand-index-thumb-fill me-2"></i> 👆🏻 ¡ingresa la medida de el tubo!
        </div>

        <div class="row g-4 justify-content-center align-items-center">
            <div class="col-6 col-md-4">
                <label class="d-block text-center small fw-bold text-muted text-uppercase mb-2" style="letter-spacing: 1px;">Metros</label>
                <div class="d-flex align-items-center justify-content-center gap-3">
                    <button type="button" class="medida-control-btn" onclick="window.iniciarCambioContinuo(event, window.cambiarMetro, -1)">−</button>
                    <input id="metrosInput" type="number" readonly class="medida-input-clean" value="1">
                    <button type="button" class="medida-control-btn" onclick="window.iniciarCambioContinuo(event, window.cambiarMetro, 1)">+</button>
                </div>
            </div>

            <div class="col-6 col-md-4">
                <label class="d-block text-center small fw-bold text-muted text-uppercase mb-2" style="letter-spacing: 1px;">Centímetros</label>
                <div class="d-flex align-items-center justify-content-center gap-3">
                    <button type="button" class="medida-control-btn" onclick="window.iniciarCambioContinuo(event, window.cambiarCm, -1)">−</button>
                    <input id="cmInput" type="number" readonly class="medida-input-clean" value="0">
                    <button type="button" class="medida-control-btn" onclick="window.iniciarCambioContinuo(event, window.cambiarCm, 1)">+</button>
                </div>
            </div>
        </div>

        <!-- Visualización del tubo interactivo con el Slider Maestro -->
        <div class="mt-5">
            <div class="tubo-visual-wrapper" id="progressBarContainer" style="cursor: pointer; position: relative;">
                <div id="tuboVisual" class="tubo-visual" style="width: 20%;"></div>
            </div>
            <div class="text-center mt-3">
                <div class="display-6 fw-bold text-dark">
                    <span id="lblMetros">1.00</span> <small class="text-muted">m</small>
                </div>
                <p class="text-muted small mt-2">Límite máximo de varilla: <strong>5.95 m</strong></p>
            </div>
        </div>

        <!-- Input Oculto e Interceptor Sticky para el Paso 2 -->
        <input type="hidden" id="largo" value="1.00">
        <div id="barraStickyMedidas" class="sticky-action-container d-none">
            <div class="row m-0 justify-content-end">
                <div class="col-12 col-md-3 p-0">
                    <button class="btn btn-success w-100 py-2.5 fw-bold text-uppercase shadow-sm" id="btnPasoMedida" style="border-radius: 12px; font-size: 0.95rem; letter-spacing: 0.5px;">
                        Siguiente: Accesorios <i class="bi bi-arrow-right-short ms-1"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 5. PASO 3: ACCESORIOS -->
    <div id="paso2" class="card mb-4 p-4 d-none">
        <h5 class="mb-3">3️⃣ Elige los soportes del tubo</h5>
        <div class="row g-3" id="contenedorAccesorios"></div>

        <!-- 🛒 BURBUJA FLOTANTE DEL CARRITO GLOBAL -->
        <button type="button" id="btnCarritoFlotante" class="btn-carrito-flotante d-none" onclick="window.Cotizacion.abrirModalCarritoAccesorios()">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16" style="margin-top: -2px;">
                <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
            </svg>
            <span id="badgeContadorAcc" class="badge bg-danger position-absolute top-0 start-100 translate-middle rounded-pill" style="font-size: 0.75rem; padding: 4px 7px;">0</span>
        </button>

        <!-- 📋 PANEL DESLIZABLE TRASLÚCIDO DESDE ABAJO -->
        <div id="panelCarritoAccesorios" class="carrito-sheet-panel">
            <div class="carrito-sheet-container shadow-lg">
                <div class="d-flex align-items-center justify-content-between bg-dark text-white px-4 py-3" style="border-radius: 24px 24px 0 0;">
                    <h5 class="m-0 fw-bold text-white d-flex align-items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#10b981" class="bi bi-list-check me-2" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M5 11.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5m-3 1a1 1 0 1 0 0-2 1 1 0 0 0 0 2m0 4a1 1 0 1 0 0-2 1 1 0 0 0 0 2m0 4a1 1 0 1 0 0-2 1 1 0 0 0 0 2" />
                        </svg>
                        Accesorios Incluidos
                    </h5>
                    <button type="button" class="btn text-white-50 p-1 fs-5 fw-bold" onclick="window.Cotizacion.cerrarPanelCarritoAccesorios()" style="line-height: 1;">✕</button>
                </div>
                <div class="p-4 bg-light" style="max-height: 380px; overflow-y: auto;">
                    <div id="listaAccesoriosModal" class="small text-muted text-center py-3">Ninguno</div>
                </div>
                <div class="p-3 bg-light border-top text-center" style="border-radius: 0 0 24px 24px;">
                    <button type="button" class="btn btn-secondary w-100 fw-bold py-2.5" style="border-radius: 14px;" onclick="window.Cotizacion.cerrarPanelCarritoAccesorios()">
                        Continuar editando
                    </button>
                </div>
            </div>
        </div>

        <!-- ⚓ BARRA FIJA INFERIOR EXCLUSIVA DEL PASO 3 (ACCESORIOS - FIJA EN PC Y MÓVIL) -->
        <div id="barraStickyAccesorios" class="sticky-action-container d-none">
            <div class="row m-0 justify-content-end">
                <div class="col-12 col-md-3 p-0">
                    <button class="btn btn-primary w-100 py-2.5 fw-bold text-uppercase shadow-sm" id="btnCalcular" style="border-radius: 12px; font-size: 0.95rem; letter-spacing: 0.5px; background: #2563eb; border: none;">
                        Ver cotización final <i class="bi bi-calculator ms-2"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>



<!-- ================= RESULTADO (TICKET ESTILO CORTINA) ================= -->
<div id="resultado" class="d-none" style="background: #171f2d; border-radius: 20px; padding: 2rem; max-width: 500px; margin: 0 auto; border: 1px solid #2d3748; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);">

    <!-- Encabezado -->
    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center bg-success text-white rounded-2 mb-2" style="width: 28px; height: 28px;">
            <i class="bi bi-check-lg"></i>
        </div>
        <h4 class="text-white m-0 fw-bold">Cotización Final</h4>
        <small style="color: #94a3b8;">E&E Aluminios - Baños</small>
    </div>

    <!-- Producto Principal -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="bg-white rounded-4 p-2 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 80px; height: 80px; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
            <img id="resTuboImg" src="/img/home/placeholder.png" class="img-fluid" style="max-height: 100%; object-fit: contain;">
        </div>
        <div class="flex-grow-1">
            <h5 id="resTuboDesc" class="text-white fw-bold m-0 text-uppercase mb-1" style="letter-spacing: 0.5px;"></h5>
            <span id="resTuboDim" class="badge fw-bold px-2 py-1 mb-2" style="background: #dbeafe; color: #2563eb; font-size: 0.7rem;"></span>
            <div id="resResumenTubo" class="small text-white-50 lh-sm"></div>
        </div>
    </div>

    <div style="border-top: 1px dashed #334155; margin: 1.5rem 0;"></div>

    <!-- Accesorios -->
    <h6 class="text-white mb-3" style="font-size: 0.95rem;">Accesorios</h6>
    <div id="resAccesorios" class="d-flex flex-column gap-2 mb-4"></div>

    <div class="d-flex justify-content-between align-items-center mb-4 px-3 py-2 rounded-4" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);">
        <div>
            <span class="text-white-50 small text-uppercase fw-bold" style="letter-spacing: 1px; font-size: 0.7rem;">¿Cuántos combos iguales?</span>
            <div class="text-white-50 small" style="font-size: 0.65rem;">Se multiplicará el tubo y todos sus accesorios.</div>
        </div>
        <div class="d-flex align-items-center gap-3 bg-dark rounded-pill px-2 py-1" style="border: 1px solid #334155;">
            <button type="button" class="btn btn-sm text-white fs-4 lh-1 p-0" style="width:30px;"
                    onclick="window.iniciarCambioContinuo(event, window.cambiarPiezasTicket, -1)">
                −
            </button>

            <input id="piezas" type="number" readonly value="1"
                   style="width: 35px; background: transparent; border: none; color: white; text-align: center; font-weight: 800; font-size: 1.2rem; outline: none;">

            <button type="button" class="btn btn-sm text-success fs-4 lh-1 p-0" style="width:30px;"
                    onclick="window.iniciarCambioContinuo(event, window.cambiarPiezasTicket, 1)">
                +
            </button>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center px-4 py-3 rounded-4" style="background-color: #10b981; box-shadow: 0 10px 15px -3px rgba(16,185,129,0.3);">
        <span class="text-white fw-semibold" style="font-size: 1.1rem;">TOTAL A PAGAR</span>
        <strong id="resTotal" class="text-white fs-2 fw-bolder"></strong>
    </div>

    <div class="mt-4 d-flex flex-column gap-2">
        <button id="btnReservar" class="btn fw-bolder py-3 rounded-3" style="background-color: #fbbf24; color: #000; font-size: 1.1rem;">
            📌 RESERVAR PEDIDO
        </button>
        <div class="d-flex gap-2 mt-2">
            <button class="btn btn-outline-light flex-fill py-2 rounded-3 text-white-50" style="border-color: #334155;" onclick="location.reload()">
                <i class="bi bi-arrow-repeat me-1"></i> Nueva
            </button>

            @if (esClienteLogueado)
            {
                @* 👤 Si es cliente de la intranet, el botón "Inicio" lo regresa a su panel privado *@
                <a asp-controller="Cliente" asp-action="WebPrincipal" class="btn btn-outline-light flex-fill py-2 rounded-3 text-white fw-bold" style="border-color: #0284c7 !important; background: rgba(2, 132, 199, 0.1);">
                    <i class="bi bi-sidebar-reversed me-1"></i> Mi Intranet
                </a>
            }
            else
            {
                @* 🕵️‍♂️ Si es un usuario anónimo o de la calle, lo manda al Home normal *@
                <a href="/" class="btn btn-outline-light flex-fill py-2 rounded-3 text-white-50" style="border-color: #334155;">
                    <i class="bi bi-arrow-left me-1"></i> Inicio
                </a>
            }
        </div>
    </div>
</div>

<!-- ================= MODALES PREMIUM ================= -->
<!-- MODAL SECCIÓN -->
<div class="modal fade" id="seccionModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
        <div class="modal-content material-modal-content">
            <div class="modal-header border-0 pb-0">
                <div class="text-center w-100 mt-3">
                    <div class="modal-pre-title">CONFIGURACIÓN INICIAL</div>
                    <h4 class="modal-title fw-800">¿Qué vas a instalar?</h4>
                </div>
            </div>
            <div class="modal-body p-4">
                <div class="d-grid gap-3">
                    <button class="material-select-card" onclick="seleccionarSeccion('DUCHA')">
                        <div class="card-icon-wrapper steel"><i class="bi bi-droplet-half"></i></div>
                        <div class="card-content">
                            <strong>TUBO DE DUCHA</strong>
                            <small>Para cortinas de baño estándar o en L.</small>
                        </div>
                        <div class="card-arrow"><i class="bi bi-chevron-right"></i></div>
                    </button>
                    <button class="material-select-card" onclick="seleccionarSeccion('TOALLERA')">
                        <div class="card-icon-wrapper alum"><i class="bi bi-dash-lg"></i></div>
                        <div class="card-content">
                            <strong>TOALLERA</strong>
                            <small>Soporte resistente para colgar toallas.</small>
                        </div>
                        <div class="card-arrow"><i class="bi bi-chevron-right"></i></div>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MODAL MATERIAL -->
<div class="modal fade" id="materialModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
        <div class="modal-content material-modal-content">
            <div class="modal-header border-0 pb-0">
                <div class="text-center w-100 mt-3">
                    <h4 class="modal-title fw-800">Selecciona el material</h4>
                </div>
            </div>
            <div class="modal-body p-4">
                <div class="d-grid gap-3">
                    <button class="material-select-card" onclick="seleccionarMaterial('ALUMINIO')">
                        <div class="card-icon-wrapper alum"><i class="bi bi-layers-half"></i></div>
                        <div class="card-content">
                            <strong>ALUMINIO</strong>
                            <small>Inoxidable, ligero y económico.</small>
                        </div>
                        <div class="card-arrow"><i class="bi bi-chevron-right"></i></div>
                    </button>
                    <button class="material-select-card" onclick="seleccionarMaterial('ACERO')">
                        <div class="card-icon-wrapper steel"><i class="bi bi-shield-shaded"></i></div>
                        <div class="card-content">
                            <strong>ACERO INOXIDABLE</strong>
                            <small>Máxima resistencia a la humedad.</small>
                        </div>
                        <div class="card-arrow"><i class="bi bi-chevron-right"></i></div>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- ================= MODAL DE CARGA ASEGURADO GLOBAL (UNIFICADO) ================= -->
<div class="modal fade" id="loadingModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4 border-0" style="border-radius: 20px;">
            <div class="modal-body">
                <div class="spinner-border text-success mb-3" role="status" style="width: 3.5rem; height: 3.5rem;"></div>
                <h5 class="fw-bold text-dark text-uppercase mb-1" style="letter-spacing: 0.5px;">Procesando Cotización</h5>
                <p class="text-muted small m-0">Estamos calculando los mejores precios para tu diseño...</p>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalSalir" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4 rounded-4 border-0">
            <h5 class="fw-bold">¿Deseas salir?</h5>
            <p class="text-muted">Se perderán los datos de tu cotización.</p>
            <div class="d-flex justify-content-center gap-2 mt-3">
                <button class="btn btn-light px-4 rounded-pill" data-bs-dismiss="modal">Seguir</button>

                @* 🧠 Bifurcación del botón de escape basada en la sesión del servidor *@
                @if (Context.Session.GetInt32("USER_ID") != null)
                {
                    @* 👤 Si es cliente logueado, lo regresas directo a su suite de la intranet *@
                    <a asp-controller="Cliente" asp-action="WebPrincipal" class="btn btn-danger px-4 rounded-pill fw-bold">
                        Sí, salir
                    </a>
                }
                else
                {
                    @* 🕵️‍♂️ Si es un usuario incógnito, lo mandas al Home público tradicional *@
                    <a href="/" class="btn btn-danger px-4 rounded-pill fw-bold">
                        Sí, salir
                    </a>
                }
            </div>
        </div>
    </div>
</div>
<!-- ================= SCRIPTS & ESTILOS ================= -->
<link rel="stylesheet" href="~/css/ui-base.css" />
<link rel="stylesheet" href="~/css/cotizacion-core.css" />
<link rel="stylesheet" href="~/css/cotizacion-ducha.css" asp-append-version="true" />

<script>
    const urlGetTubos = '@Url.Action("GetTubosDucha", "CotizacionDucha")';
    const urlGetAccesorios = '@Url.Action("GetAccesoriosDucha", "CotizacionDucha")';
    const urlCalcular = '@Url.Action("CalcularDucha", "CotizacionDucha")';
    const urlReservaCrear = '@Url.Action("Crear", "Reserva")';
</script>

<script src="~/js/ui-core.js" asp-append-version="true" defer></script>
<script src="~/js/cotizacion-core.js" asp-append-version="true" defer></script>
<script src="~/js/cotizacion-ducha.js" asp-append-version="true" defer></script>

<style>
    .medida-control-btn {
        user-select: none;
        -webkit-user-select: none;
    }

    @@media (max-width: 576px) {
        .main-title {
            font-size: 1.1rem;
        }

        .material-badge {
            font-size: 0.70rem;
            padding: 5px 10px;
        }
    }


    /* --- Estilo del Globo de Ayuda (Ancho Total y Alto) --- */
    .hint-usuario {
        position: absolute;
        left: 0;
        right: 0;
        width: auto;
        background: #10b981; /* Verde éxito */
        color: white;
        padding: 40px 20px; /* 🔥 Altura aumentada */
        border-radius: 15px;
        font-weight: 700;
        font-size: 1.2rem; /* Letra imponente */
        z-index: 100;
        text-align: center;
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.4);
        pointer-events: none;
        transform: none;
    }

        /* La flechita apuntando hacia ARRIBA */
        .hint-usuario::after {
            content: "";
            position: absolute;
            top: -10px; /* Se queda pegada arriba */
            left: 50%;
            transform: translateX(-50%);
            border-width: 0 10px 10px 10px;
            border-style: solid;
            border-color: transparent transparent #10b981 transparent;
        }
</style>