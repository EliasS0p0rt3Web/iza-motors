@model Negocio.Web.Models.ViewModels.CotizacionCortinaVm
@{
    bool esClienteLogueado = Context.Session.GetInt32("USER_ID") != null;
    Layout = "_LayoutCotizacion";
}

<style>
    :root {
        --color-primary: #22c55e;
        --color-bg-dark: #020617;
    }

    body {
        background: radial-gradient(circle at top, #0f172a, var(--color-bg-dark) 70%) !important;
        color: #e5e7eb;
    }

    /* Wizard Progress */
    .wizard-progress {
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        margin-bottom: 3rem;
    }

    .wizard-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        z-index: 2;
    }

    .step-circle {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: #1e293b;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        border: 2px solid rgba(255,255,255,0.1);
        transition: 0.3s;
    }

    .wizard-step.active .step-circle {
        background: var(--color-primary);
        color: white;
        box-shadow: 0 0 20px rgba(34,197,94,0.4);
    }

    .wizard-step.completed .step-circle {
        background: #064e3b;
        color: var(--color-primary);
        border-color: var(--color-primary);
    }

    /* Barra Visual */
    .tubo-visual-wrapper {
        background: #1e293b;
        border-radius: 50px;
        height: 24px;
        width: 100%;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .tubo-visual {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, #22c55e, #4ade80);
        transition: width 0.4s ease-out;
    }

    /* Resumen Card */
    .resumen-card {
        background: rgba(15, 23, 42, 0.8);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 24px;
        backdrop-filter: blur(10px);
    }

    .total-badge {
        background: var(--color-primary);
        font-size: 2.5rem;
        font-weight: 900;
        border-radius: 16px;
        padding: 1rem 2rem;
    }

    .detalle-item {
        border-bottom: 1px dashed rgba(255,255,255,0.1);
        padding: 10px 0;
    }

    /* =====================================================
           ESTILO MODAL DE RESERVA (AMBAR)
        ===================================================== */
    #reservaModal .modal-content {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    }

    #reservaModal .modal-header {
        background: linear-gradient(135deg,#ffc107 0%,#ff9800 100%);
        color: #000;
        border-bottom: none;
        padding: 1.5rem;
    }

    #reservaModal .modal-title {
        font-weight: 800;
        text-transform: uppercase;
    }

    #reservaModal .form-label {
        font-weight: 600;
        color: #495057;
        font-size: .9rem;
    }

    #reservaModal .form-control, #reservaModal .form-select {
        border-radius: 10px;
        padding: .7rem;
    }

    #btnConfirmarReserva {
        padding: .9rem;
        font-weight: 700;
        text-transform: uppercase;
        border-radius: 12px;
        border: none;
        background: #ffc107;
        transition: .2s;
    }

        #btnConfirmarReserva:hover:not(:disabled) {
            transform: translateY(-2px);
            background: #e0a800;
            box-shadow: 0 5px 15px rgba(0,0,0,.1);
        }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-800">Cotizador de Rieles</h2>

        @* 🧠 Bifurcación inteligente para el botón Salir *@
        @if (esClienteLogueado)
        {
            @* 👤 Si es cliente logueado, lo regresa a su panel de la intranet *@
            <a asp-controller="Cliente" asp-action="WebPrincipal" class="btn btn-outline-light rounded-pill px-4">
                ⬅ Volver a mi Intranet
            </a>
        }
        else
        {
            @* 🕵️‍♂️ Si es incógnito, va al inicio público tradicional *@
            <a href="/" class="btn btn-outline-light rounded-pill px-4">
                ⬅ Salir
            </a>
        }
    </div>

    <!-- Wizard Progress -->
    <div class="wizard-progress">
        <div class="wizard-step active" data-step="1"><div class="step-circle">1</div><div class="step-label mt-2 small">Instalación</div></div>
        <div class="wizard-step" data-step="2"><div class="step-circle">2</div><div class="step-label mt-2 small">Medidas</div></div>
        <div class="wizard-step" data-step="3"><div class="step-circle">3</div><div class="step-label mt-2 small">Resumen</div></div>
    </div>

    <!-- PASO 2: MEDIDAS -->
    <div id="pasoMedidas" class="d-none animate__animated animate__fadeIn">
        <div class="card p-4 border-0 shadow-lg text-dark" style="border-radius: 20px;">
            <h5 class="mb-4 fw-800 text-uppercase">2️⃣ Ingresa el largo del riel</h5>
            <div class="row g-4 align-items-center">
                <div class="col-6 col-md-3">
                    <label class="small fw-bold text-muted">METROS</label>
                    <input id="metrosInput" type="number" class="form-control form-control-lg text-center fw-800" value="1" min="1" max="6" oninput="CotizacionRiel.actualizarBarra()">
                </div>
                <div class="col-6 col-md-3">
                    <label class="small fw-bold text-muted">CENTÍMETROS</label>
                    <input id="cmInput" type="number" class="form-control form-control-lg text-center fw-800" value="0" min="0" max="99" oninput="CotizacionRiel.actualizarBarra()">
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <button class="btn btn-success w-100 py-3 fw-bold rounded-pill shadow" onclick="CotizacionRiel.generarCotizacion()">OBTENER COTIZACIÓN ⚡</button>
                </div>
            </div>
            <div class="mt-5 position-relative">
                <div class="text-end fw-bold text-success mb-2" id="lblTotalMedida">1.00 m</div>
                <div class="tubo-visual-wrapper"><div id="tuboVisual" class="tubo-visual" style="width: 16.6%;"></div></div>
            </div>
        </div>
    </div>

    <!-- PASO 3: RESUMEN FINAL -->
    <div id="pasoResumen" class="d-none animate__animated animate__zoomIn">
        <div class="resumen-card p-4 p-md-5">
            <div class="row g-5">
                <div class="col-md-7">
                    <h3 class="fw-900 mb-4 text-success text-uppercase">Resumen del Pedido</h3>

                    <!-- Detalles en negro -->
                    <div id="listaDetalles" class="text-dark"></div>

                    <!-- Caja de resumen con fondo blanco y texto negro -->
                    <div class="mt-4 p-3 bg-white rounded-4 text-center shadow-sm">
                        <div class="row">
                            <div class="col-4 border-end border-light-subtle">
                                <small class="d-block text-muted">MEDIDA</small>
                                <b id="resMedida" class="text-dark">-</b>
                            </div>
                            <div class="col-4 border-end border-light-subtle">
                                <small class="d-block text-muted">TIPO</small>
                                <b id="resTipo" class="text-dark">-</b>
                            </div>
                            <div class="col-4">
                                <small class="d-block text-muted">APERTURA</small>
                                <b id="resApertura" class="text-dark">-</b>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-5 text-center d-flex flex-column justify-content-center">
                    <span class="text-muted fw-bold mb-2">TOTAL ESTIMADO</span>
                    <div class="total-badge shadow-lg mb-4" id="resTotal">S/ 0.00</div>
                    <button class="btn btn-warning btn-lg fw-bold rounded-pill py-3 mb-2" onclick="CotizacionRiel.abrirModalReserva()">📌 RESERVAR PEDIDO</button>
                    <button class="btn btn-outline-light rounded-pill py-2" onclick="location.reload()">🔄 Nueva Cotización</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MODAL PASO 1 (INSTALACIÓN) -->
<div class="modal fade" id="modalInicial" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-4 text-dark" style="border-radius: 28px;">
            <div class="modal-body text-center">
                <h3 class="fw-900 mb-4">¿Cómo será la instalación?</h3>
                <div class="d-flex gap-3 mb-4">
                    <input type="radio" class="btn-check" name="lugarIns" id="ins_techo" value="TECHO" checked>
                    <label class="btn btn-outline-primary flex-fill py-4 fw-bold rounded-4" for="ins_techo"> EN TECHO</label>
                    <input type="radio" class="btn-check" name="lugarIns" id="ins_pared" value="PARED">
                    <label class="btn btn-outline-primary flex-fill py-4 fw-bold rounded-4" for="ins_pared"> EN PARED<br><small class="text-success">+ S/ 5.00</small></label>
                </div>
                <div class="mb-4 text-start bg-light p-3 rounded-4">
                    <label class="small fw-800 text-muted mb-2 d-block">APERTURA</label>
                    <select id="tipoApertura" class="form-select border-0 shadow-sm">
                        <option value="UN_LADO">Hacia un lado</option>
                        <option value="AMBOS">Al centro (Doble)</option>
                    </select>
                </div>
                <button class="btn btn-success w-100 py-3 fw-bold rounded-pill" onclick="CotizacionRiel.confirmarInstalacion()">SIGUIENTE PASO ➡</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL RESERVA (ESTILO AMBAR) -->
<div class="modal fade" id="reservaModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">✨ Finaliza tu Pedido</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-4 small">Estás a un paso de disfrutar. Por favor confirma tus detalles.</p>
                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-person me-2"></i>Nombre completo</label>
                    <input type="text" id="clienteNombre" class="form-control" placeholder="Ej. Juan Pérez" required oninput="CotizacionRiel.validarFormReserva()">
                </div>
                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-envelope me-2"></i>Correo electrónico <small class="text-muted">(Opcional)</small></label>
                    <input type="email" id="clienteCorreo" class="form-control" placeholder="ejemplo@correo.com">
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label"><i class="bi bi-telephone me-2"></i>Teléfono</label>
                        <input type="tel" id="clienteTelefono" class="form-control" placeholder="999999999" maxlength="9" required oninput="CotizacionRiel.validarFormReserva()">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label"><i class="bi bi-truck me-2"></i>Tipo de entrega</label>
                        <select id="clienteEntrega" class="form-select" onchange="CotizacionRiel.toggleEntrega(); CotizacionRiel.actualizarPrecioFinalReserva();">
                            <option value="RECOJO">Recojo en tienda</option>
                            <option value="DELIVERY">Delivery Casa</option>
                            <option value="ESTACION">Estación de Tren (S/ 3.00)</option>
                        </select>
                    </div>
                </div>
                <div id="grupoEstaciones" class="mb-3 d-none">
                    <label class="form-label">Selecciona la Estación</label>
                    <select id="estacionTren" class="form-select">
                        <option value="Bayanovar">Bayanovar</option>
                        <option value="Santa Rosa">Santa Rosa</option>
                        <option value="Grau">Grau</option>
                        <option value="Angamos">Angamos</option>
                    </select>
                </div>
                <div id="grupoDireccion" class="mb-3 d-none">
                    <label class="form-label">Dirección de entrega</label>
                    <input type="text" id="clienteDireccion" class="form-control" placeholder="Calle, número, distrito">
                </div>
                <div class="mb-3">
                    <label class="form-label">¿Para cuándo lo necesitas?</label>
                    <select id="tipoFecha" class="form-select" onchange="CotizacionRiel.toggleFecha()">
                        <option value="HOY">🚀 ¡Lo quiero para hoy!</option>
                        <option value="FECHA">📅 Programar otra fecha</option>
                    </select>
                </div>
                <div id="grupoFecha" class="mb-3 d-none">
                    <input type="date" id="clienteFecha" class="form-control" min="@DateTime.Now.ToString("yyyy-MM-dd")">
                </div>
            </div>
            <div class="modal-footer border-0">
                <button id="btnConfirmarReserva" class="btn btn-warning w-100 py-3" disabled onclick="CotizacionRiel.enviarReservaFinal()">CONFIRMAR MI RESERVA</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL DE CARGA -->
<div class="modal fade" id="loadingModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-warning" style="border-radius: 20px;">
            <div class="modal-body text-center p-5">
                <div class="spinner-border text-warning mb-3" style="width: 3.5rem; height: 3.5rem;"></div>
                <h4 class="fw-bold">Registrando y validando reserva...</h4>
                <p class="text-secondary">Estamos preparando tu pedido de vidriería, un momento por favor.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const CotizacionRiel = (function () {
            let rielId = null;
            let subtotalBase = 0;
            let instalacionGlobal = "TECHO";
            let aperturaGlobal = "UN_LADO";

            function init() {
                new bootstrap.Modal(document.getElementById('modalInicial')).show();
                prepararProductoBase();
            }

            async function prepararProductoBase() {
                const res = await fetch('@Url.Action("GetRieles", "CotizacionRiel")');
                const data = await res.json();
                const p = data.find(p => p.descripcion.toUpperCase().includes("RIEL DE CORTINA")) || data[0];
                if (p) rielId = p.idProducto;
            }

            function confirmarInstalacion() {
                instalacionGlobal = document.querySelector('input[name="lugarIns"]:checked').value;
                aperturaGlobal = document.getElementById('tipoApertura').value;
                bootstrap.Modal.getInstance(document.getElementById('modalInicial')).hide();
                document.getElementById('pasoMedidas').classList.remove('d-none');
                actualizarWizard(2);
            }

            function actualizarBarra() {
                const total = (parseFloat(document.getElementById('metrosInput').value) || 0) + ((parseFloat(document.getElementById('cmInput').value) || 0) / 100);
                document.getElementById('lblTotalMedida').innerText = total.toFixed(2) + " m";
                document.getElementById('tuboVisual').style.width = ((total / 6) * 100) + "%";
            }

            async function generarCotizacion() {
                const totalM = (parseFloat(document.getElementById('metrosInput').value) || 0) + ((parseFloat(document.getElementById('cmInput').value) || 0) / 100);
                const res = await fetch('@Url.Action("Calcular", "CotizacionRiel")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ IdProducto: rielId, Metros: totalM, Instalacion: instalacionGlobal, Apertura: aperturaGlobal })
                });
                const r = await res.json();
                subtotalBase = r.total;
                mostrarResumen(r, totalM);
            }

                    function mostrarResumen(r, m) {
            document.getElementById('resMedida').innerText = m.toFixed(2) + " m";
            document.getElementById('resTipo').innerText = instalacionGlobal;
            document.getElementById('resApertura').innerText = aperturaGlobal === "AMBOS" ? "Doble" : "Simple";
            document.getElementById('resTotal').innerText = "S/ " + r.total.toFixed(2);

            // Aquí forzamos el color blanco para el nombre del producto y el desglose
            document.getElementById('listaDetalles').innerHTML = `
                <div class="detalle-item d-flex justify-content-between text-white">
                    <span>Riel de Cortina</span>
                    <span>S/ ${r.subtotalRiel.toFixed(2)}</span>
                </div>
                ${r.costoExtraPared > 0 ? `
                <div class="detalle-item d-flex justify-content-between text-success fw-bold">
                    <span>Extra Pared</span>
                    <span>+ S/ ${r.costoExtraPared.toFixed(2)}</span>
                </div>` : ''}
            `;

            document.getElementById('pasoMedidas').classList.add('d-none');
            document.getElementById('pasoResumen').classList.remove('d-none');
            actualizarWizard(3);
        }

            function toggleEntrega() {
                const val = document.getElementById('clienteEntrega').value;
                document.getElementById('grupoDireccion').classList.toggle('d-none', val !== 'DELIVERY');
                document.getElementById('grupoEstaciones').classList.toggle('d-none', val !== 'ESTACION');
            }

            function toggleFecha() {
                document.getElementById('grupoFecha').classList.toggle('d-none', document.getElementById('tipoVenta')?.value !== 'FECHA');
                // Nota: Corregí el ID de tipoVenta vs tipoFecha del modal
                document.getElementById('grupoFecha').classList.toggle('d-none', document.getElementById('tipoFecha').value !== 'FECHA');
            }

            function actualizarPrecioFinalReserva() {
                const extra = document.getElementById('clienteEntrega').value === "ESTACION" ? 3 : 0;
                document.getElementById('btnConfirmarReserva').innerText = `CONFIRMAR MI RESERVA (S/ ${(subtotalBase + extra).toFixed(2)})`;
            }

            function validarFormReserva() {
                const n = document.getElementById('clienteNombre').value.trim();
                const t = document.getElementById('clienteTelefono').value.trim();
                document.getElementById('btnConfirmarReserva').disabled = !(n && t.length === 9);
            }

            async function enviarReservaFinal() {
                const modalCarga = new bootstrap.Modal(document.getElementById('loadingModal'));
                modalCarga.show();
                bootstrap.Modal.getInstance(document.getElementById('reservaModal')).hide();

                const extra = document.getElementById('clienteEntrega').value === "ESTACION" ? 3 : 0;
                const metros = (parseFloat(document.getElementById('metrosInput').value) || 0) + ((parseFloat(document.getElementById('cmInput').value) || 0) / 100);

                const payload = {
                    NombreCliente: document.getElementById('clienteNombre').value,
                    Telefono: document.getElementById('clienteTelefono').value,
                    Correo: document.getElementById('clienteCorreo').value,
                    TipoEntrega: document.getElementById('clienteEntrega').value,
                    DireccionEntrega: document.getElementById('clienteEntrega').value === "ESTACION" ? "Estación: " + document.getElementById('estacionTren').value : document.getElementById('clienteDireccion').value || "Tienda",
                    Metros: metros,
                    Instalacion: instalacionGlobal,
                    Total: subtotalBase + extra,
                    DetalleJson: JSON.stringify({ Producto: "Riel de Cortina", Medida: metros + "m", Instalacion: instalacionGlobal, Apertura: aperturaGlobal }),
                    FechaSolicitada: document.getElementById('clienteFecha').value || new Date().toISOString()
                };

                const res = await fetch('@Url.Action("Crear", "Reserva")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (res.ok || res.redirected) {
                    // Si el controlador hace un RedirectToAction, lo seguimos
                    if(res.redirected) window.location.href = res.url;
                    else location.href = "/";
                } else {
                    modalCarga.hide();
                    alert("Error al registrar reserva.");
                }
            }

            function actualizarWizard(n) {
                document.querySelectorAll('.wizard-step').forEach(s => {
                    const step = parseInt(s.dataset.step);
                    s.classList.toggle('active', step === n);
                    s.classList.toggle('completed', step < n);
                });
            }

            return { init, confirmarInstalacion, actualizarBarra, generarCotizacion, abrirModalReserva: () => { actualizarPrecioFinalReserva(); new bootstrap.Modal(document.getElementById('reservaModal')).show(); }, toggleEntrega, toggleFecha, actualizarPrecioFinalReserva, validarFormReserva, enviarReservaFinal };
        })();
        document.addEventListener('DOMContentLoaded', CotizacionRiel.init);
    </script>
}