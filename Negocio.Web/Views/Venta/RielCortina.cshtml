@model Negocio.Web.Models.ViewModels.RielCortinaViewModel

@{
    Layout = "_LayoutSistema";
    ViewData["Title"] = "Venta Riel de Cortina";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
    /* --- CONFIGURACIÓN BASE PRO --- */
    .riel-container {
        font-family: 'Inter', sans-serif;
        color: #0f172a;
        max-width: 98%;
        margin: 0 auto;
    }

    .fw-800 {
        font-weight: 800 !important;
    }

    /* --- TARJETAS DE CONTROL PREMIUM --- */
    .form-premium-card {
        background: #ffffff;
        border-radius: 24px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 10px 40px rgba(15, 23, 42, 0.02);
        padding: 1.75rem;
    }

    .panel-header-pro {
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 0.75rem;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-label-pro {
        font-size: 0.85rem;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 0.4rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* --- INPUTS MODERNOS --- */
    .input-pro {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 0.65rem 1rem;
        font-size: 0.95rem;
        color: #0f172a;
        font-weight: 600;
        background: #f8fafc;
        transition: all 0.3s ease;
    }

        .input-pro:focus {
            border-color: #0284c7; /* Tono celeste/azul premium para rieles */
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(2, 132, 199, 0.1);
            outline: none;
        }

    /* --- BOTONES DE CONTROL DE MEDIDA --- */
    .btn-quantity {
        border: 1px solid #e2e8f0;
        background: #ffffff;
        color: #0f172a;
        font-weight: 700;
        width: 50px;
        transition: all 0.2s ease;
    }

        .btn-quantity:hover {
            background: #f1f5f9;
            color: #0f172a;
        }

    /* --- ENLACES Y ACCIONES --- */
    .btn-save-pro {
        background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 100%);
        color: white !important;
        border: none;
        padding: 12px 24px;
        font-size: 1rem;
        font-weight: 700;
        border-radius: 12px;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px rgba(2, 132, 199, 0.25);
    }

        .btn-save-pro:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 25px rgba(2, 132, 199, 0.35);
        }

    .btn-clear-pro {
        border: 1px solid #e2e8f0;
        background: #ffffff;
        color: #475569 !important;
        padding: 10px 24px;
        font-size: 0.95rem;
        font-weight: 600;
        border-radius: 12px;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
    }

        .btn-clear-pro:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }
</style>

<div class="riel-container py-4">

    <div class="mb-4">
        
        <h3 class="fw-800 text-dark mb-0"> Venta de Riel de Cortina</h3>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <form asp-action="RielCortina" method="post" class="row g-4">
        @Html.AntiForgeryToken()

        <div class="col-lg-7">
            <div class="form-premium-card h-100">
                <div class="panel-header-pro">
                    📦 Datos de Configuración del Riel
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label-pro">Día</label>
                        <select asp-for="Dia" asp-items="Model.Dias" class="form-select input-pro w-100">
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-pro">Fecha</label>
                        <input asp-for="Fecha" type="date" class="form-control input-pro w-100" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label-pro">Metros Requeridos</label>
                    <div class="input-group">
                        <button type="button" class="btn btn-quantity rounded-start-3" id="btnMenos">
                            <i class="bi bi-dash-lg"></i>
                        </button>

                        <input asp-for="Metros" type="number" step="0.10" min="0"
                               class="form-control input-pro text-center border-start-0 border-end-0 rounded-0" id="metrosInput" />

                        <button type="button" class="btn btn-quantity rounded-end-3" id="btnMas">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label-pro">Tipo de Cruce</label>
                    <select asp-for="TipoCruce" asp-items="Model.TiposCruce" class="form-select input-pro w-100">
                    </select>
                </div>

                <div class="form-check form-switch mb-3 p-0 ps-5 fs-6">
                    <input asp-for="AccesorioAparte" class="form-check-input ms-5" type="checkbox" id="checkAccesorio">
                    <label class="form-check-label fw-bold text-dark ps-2">
                        Incluir accesorio aparte
                    </label>
                </div>

                <div id="bloqueAccesorio" style="display:none; background: #f8fafc; border-radius: 16px; padding: 1.25rem; border: 1px dashed #cbd5e1;">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label-pro">Tipo de Uñera</label>
                            <select asp-for="TipoUnera" asp-items="Model.TiposUnera" class="form-select input-pro w-100" style="background: #ffffff;">
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label-pro">Cantidad Uñeras Extra</label>
                            <input asp-for="CantidadUneraExtra" type="number" min="1" class="form-control input-pro w-100" style="background: #ffffff;" placeholder="Cantidad" />
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-lg-5">
            <div class="form-premium-card d-flex flex-column justify-content-between h-100">
                <div>
                    <div class="panel-header-pro">
                        💰 Liquidación de Caja
                    </div>

                    <div class="mb-4">
                        <label class="form-label-pro">Destino de Fondos</label>
                        <select asp-for="Destino" asp-items="Model.Destinos" class="form-select input-pro w-100">
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-pro">Total a Cobrar (S/)</label>
                        <div class="position-relative">
                            <input asp-for="Precio" class="form-control input-pro w-100 fs-5 fw-bold text-success ps-5" placeholder="0.00" style="background: #f0fdf4;" />
                            <span class="position-absolute top-50 start-0 translate-middle-y ms-3 fw-bold text-success fs-5">S/</span>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-3 pt-4">
                    <button type="submit" class="btn btn-save-pro btn-lg">
                        <i class="bi bi-check2-circle me-1"></i> Registrar Venta de Riel
                    </button>

                    <a asp-action="SeleccionTipoVenta" class="btn-clear-pro">
                        <i class="bi bi-arrow-left-short fs-5 align-middle"></i> Volver al Menú
                    </a>
                </div>

            </div>
        </div>
    </form>
</div>

<script>
    const metrosInput = document.getElementById("metrosInput");
    const btnMas = document.getElementById("btnMas");
    const btnMenos = document.getElementById("btnMenos");

    const checkAccesorio = document.getElementById("checkAccesorio");
    const bloqueAccesorio = document.getElementById("bloqueAccesorio");

    // 🔥 NUEVOS SELECTORES PARA CONTROL DE FECHAS AUTOMÁTICAS
    const fechaInput = document.querySelector('input[name="Fecha"]');
    const diaSelect = document.querySelector('select[name="Dia"]');

    // CONTROLES +/- DE METROS
    btnMas.addEventListener("click", () => {
        let valor = parseFloat(metrosInput.value) || 0;
        metrosInput.value = (valor + 0.10).toFixed(2);
    });

    btnMenos.addEventListener("click", () => {
        let valor = parseFloat(metrosInput.value) || 0;
        if (valor > 0) {
            metrosInput.value = Math.max(0, valor - 0.10).toFixed(2);
        }
    });

    // CONTROL APERTURA DINÁMICA ACCESORIOS
    checkAccesorio.addEventListener("change", () => {
        bloqueAccesorio.style.display = checkAccesorio.checked ? "block" : "none";
    });

    if (checkAccesorio.checked) {
        bloqueAccesorio.style.display = "block";
    }

    // ⚡ CONTROL SINCRONIZACIÓN FECHA -> DIA (Seguro contra saltos de zona horaria)
    if (fechaInput && diaSelect) {
        fechaInput.addEventListener("change", () => {
            const fecha = new Date(fechaInput.value + 'T00:00:00');
            if (isNaN(fecha)) return;

            const dias = ["DOMINGO","LUNES","MARTES","MIÉRCOLES","JUEVES","VIERNES","SÁBADO"];
            diaSelect.value = dias[fecha.getDay()];
        });
    }
</script>