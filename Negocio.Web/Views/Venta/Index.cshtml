@model Negocio.Web.Models.ViewModels.VentaIndexViewModel

@{
    Layout = "_LayoutSistema";
    ViewData["Title"] = "Ventas de Productos";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

<style>
    /* --- VARIABLES Y BASE --- */
    .venta-list-container {
        font-family: 'Inter', sans-serif;
        max-width: 98%;
        margin: 0 auto;
        padding-bottom: 120px; /* 🔥 Espacio de seguridad para que el calculador flotante no tape filas */
    }

    /* --- TARJETAS PREMIUM --- */
    .form-premium-card {
        background: #ffffff;
        border-radius: 24px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 10px 40px rgba(15, 23, 42, 0.03);
        padding: 1.5rem;
    }

    .form-label-pro {
        font-size: 0.85rem;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 0.4rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .input-pro {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 0.6rem 1rem;
        font-size: 0.95rem;
        color: #0f172a;
        font-weight: 600;
        transition: all 0.3s ease;
        background: #f8fafc;
    }

        .input-pro:focus {
            border-color: #0071e3;
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.1);
            outline: none;
        }

    /* --- BOTONES PREMIUM --- */
    .btn-new-pro {
        background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
        color: white !important;
        border: none;
        padding: 10px 24px;
        font-size: 0.95rem;
        font-weight: 800;
        border-radius: 12px;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px rgba(34, 197, 94, 0.25);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-new-pro:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 25px rgba(34, 197, 94, 0.35);
        }

    .btn-search-pro {
        background: #0f172a;
        color: white !important;
        border: none;
        padding: 11px 24px;
        font-size: 0.95rem;
        font-weight: 700;
        border-radius: 12px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.1);
    }

        .btn-search-pro:hover {
            background: #1e293b;
            transform: translateY(-1px);
        }

    /* --- TABLA PRO --- */
    .table-pro {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .table-pro thead th {
            background: #f8fafc;
            color: #64748b;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 1rem;
            border-bottom: 2px solid #e2e8f0;
            border-top: none;
        }

        .table-pro tbody td {
            padding: 1rem;
            vertical-align: middle;
            color: #334155;
            font-weight: 500;
            border-bottom: 1px solid #f1f5f9;
            transition: background 0.2s ease;
        }

        .table-pro tbody tr:hover td {
            background: #f8fafc;
        }

    .total-badge {
        background: #e0f2fe;
        color: #0369a1;
        padding: 4px 10px;
        border-radius: 8px;
        font-weight: 800;
        font-size: 0.95rem;
    }

    /* --- BOTONES DE ACCIÓN --- */
    .btn-action {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .btn-edit {
        background: #fef3c7;
        color: #d97706;
    }

        .btn-edit:hover {
            background: #fde68a;
            transform: scale(1.05);
        }

    .btn-delete {
        background: #fee2e2;
        color: #dc2626;
    }

        .btn-delete:hover {
            background: #fecaca;
            transform: scale(1.05);
        }

    /* --- FILTRO DESPLEGABLE MÓVIL --- */
    .btn-filter-trigger {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 0.75rem 1.2rem;
        font-size: 0.9rem;
        font-weight: 700;
        color: #334155;
        box-shadow: 0 4px 15px rgba(15, 23, 42, 0.02);
        transition: all 0.3s ease;
        text-align: left;
    }

        .btn-filter-trigger[aria-expanded="true"] .chevron-icon {
            transform: rotate(180deg);
        }

    .chevron-icon {
        transition: transform 0.3s ease;
        font-size: 0.8rem;
        color: #64748b;
    }

    @@media (min-width: 768px) {
        #filtrosVentasCollapse.collapse:not(.show)

    {
        display: block !important;
    }

    }

    /* =========================================
           ⚡ PANEL FLOTANTE DESPLEGABLE (TOTALES POR ÁREA)
        ========================================= */
    .wrapper-calculador-flotante {
        position: fixed;
        bottom: 85px;
        right: 25px;
        z-index: 1040;
    }

    .btn-calculador-float {
        background: #0f172a;
        color: white !important;
        border: none;
        padding: 12px 24px;
        font-size: 0.9rem;
        font-weight: 800;
        border-radius: 50px;
        box-shadow: 0 8px 25px rgba(15, 23, 42, 0.25);
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .btn-calculador-float:hover {
            transform: scale(1.05) translateY(-2px);
            background: #1e293b;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.35);
        }

    .summary-floating-card {
        position: absolute;
        bottom: 65px;
        right: 0;
        width: 320px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 24px;
        box-shadow: 0 15px 40px rgba(15, 23, 42, 0.15);
        padding: 1.25rem;
        display: none;
        overflow: hidden;
        animation: slideUpVenta 0.3s ease-out;
    }

        .summary-floating-card.active {
            display: block;
        }

    .floating-title {
        font-size: 0.8rem;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .category-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85rem;
        font-weight: 600;
        color: #475569;
        margin-bottom: 0.4rem;
    }

        .category-row span.badge-value {
            font-family: monospace;
            font-size: 0.9rem;
            color: #0f172a;
            font-weight: 700;
        }

    .final-total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 2px dashed #e2e8f0;
        margin-top: 0.75rem;
        padding-top: 0.75rem;
    }

        .final-total-row span.label {
            font-weight: 800;
            font-size: 0.9rem;
            color: #0f172a;
        }

        .final-total-row span.value {
            font-size: 1.2rem;
            font-weight: 800;
            color: #16a34a; /* Verde éxito para ingresos */
        }

    @@keyframes slideUpVenta {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 576px) {
        .summary-floating-card

    {
        width: calc(100vw - 50px);
        right: 0;
    }

    }
</style>

<div class="gasto-list-container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0" style="font-weight: 800;"> Ventas de Productos</h3>
        </div>

        @if (Context.Session.GetString("ROL") == "ADMINISTRADOR")
        {
            <a asp-controller="Venta" asp-action="SeleccionTipoVenta" class="btn-new-pro">
                <i class="bi bi-plus-lg"></i> Nueva Venta
            </a>
        }
    </div>

    <div class="mb-4">
        <button type="button" class="btn btn-filter-trigger d-md-none w-100 d-flex align-items-center mb-2"
                data-bs-toggle="collapse" data-bs-target="#filtrosVentasCollapse" aria-expanded="false">
            <span><i class="bi bi-funnel-fill text-primary me-2"></i> Filtrar Parámetros de Ventas</span>
            <i class="bi bi-chevron-down ms-auto chevron-icon"></i>
        </button>

        <div class="collapse" id="filtrosVentasCollapse">
            <form method="get" class="form-premium-card">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label-pro">Desde</label>
                        <input type="date" name="desde" class="form-control input-pro w-100"
                               value="@Model.Desde?.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-pro">Hasta</label>
                        <input type="date" name="hasta" class="form-control input-pro w-100"
                               value="@Model.Hasta?.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-pro">Área</label>
                        <select name="area" class="form-select input-pro w-100">
                            @foreach (var a in Model.Areas)
                            {
                                <option value="@a.Value" selected="@(a.Value == Model.Area)">@a.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label-pro">Destino</label>
                        <select name="destino" class="form-select input-pro w-100">
                            @foreach (var d in Model.Destinos)
                            {
                                <option value="@d.Value" selected="@(d.Value == Model.Destino)">@d.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-12 mt-3">
                        <button type="submit" class="btn btn-search-pro w-100">
                            <i class="bi bi-search me-2"></i> Filtrar Catálogo
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="form-premium-card p-0 overflow-hidden shadow-sm">
        <div class="table-responsive">
            <table class="table-pro text-nowrap">
                <thead class="text-center">
                    <tr>
                        <th>Fecha</th>
                        <th>Área</th>
                        <th class="text-start">Producto</th>
                        <th>Dimensiones</th>
                        <th>Cantidad</th>
                        <th>Unidad</th>
                        <th class="text-end">Subtotal</th>
                        <th>Destino</th>
                        <th style="width:110px;">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Ventas.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-2 d-block mb-2 text-light"></i>
                                No hay ventas registradas
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var v in Model.Ventas)
                        {
                            // 🔥 Inyectamos la data en las filas para que Javascript lea los montos e identifique el área
                            <tr class="venta-data-row" data-area="@v.Area.ToUpper()" data-precio="@v.Precio.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                <td class="text-center">@v.Fecha.ToShortDateString()</td>
                                <td class="text-center fw-bold">@v.Area</td>
                                <td class="text-start">@v.Producto</td>
                                <td class="text-center">@v.Dimensiones</td>
                                <td class="text-center fw-bold">@v.Cantidad</td>
                                <td class="text-center text-secondary small">@v.Unidad</td>
                                <td class="text-end"><span class="total-badge">S/ @v.Precio.ToString("N2")</span></td>
                                <td class="text-center"><span class="badge bg-light text-dark border px-2 py-1">@v.Destino</span></td>

                                <td class="text-center">
                                    <a asp-controller="Venta" asp-action="Editar" asp-route-id="@v.IdVenta" class="btn-action btn-edit" title="Editar">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <button class="btn-action btn-delete ms-1" onclick="confirmarEliminar(@v.IdVenta)" title="Eliminar">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<div class="wrapper-calculador-flotante">

    <div id="cardCalculadorVentas" class="summary-floating-card">
        <div class="floating-title d-flex align-items-center gap-1">
            <i class="bi bi-calculator text-success"></i> Ingresos del Filtro
        </div>

        <div class="category-row">
            <span>• ALUMINIO:</span>
            <span class="badge-value" id="valTotalAluminio">S/ 0.00</span>
        </div>
        <div class="category-row">
            <span>• ACCESORIOS:</span>
            <span class="badge-value" id="valTotalAccesorios">S/ 0.00</span>
        </div>
        <div class="category-row">
            <span>• ARC:</span>
            <span class="badge-value" id="valTotalARC">S/ 0.00</span>
        </div>

        <div class="final-total-row">
            <span class="label">TOTAL VENTAS</span>
            <span class="value" id="totalFinalVentasFlotante">S/ 0.00</span>
        </div>
    </div>

    <button type="button" id="btnCalculadorVentasToggle" class="btn-calculador-float">
        <i class="bi bi-calculator-fill"></i> Calculador
    </button>
</div>

<div class="modal fade modal-pro" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content shadow-lg">
            <div class="modal-body text-center pt-5 pb-4 px-4">
                <div class="mb-3 text-danger">
                    <i class="bi bi-exclamation-octagon-fill" style="font-size: 3.5rem;"></i>
                </div>
                <h5 class="fw-bold mb-2">¿Eliminar venta?</h5>
                <p class="text-muted small mb-0">
                    Esta acción es irreversible.<br />
                    <span class="text-warning fw-bold">⚠️ El stock será devuelto automáticamente.</span>
                </p>
            </div>
            <div class="modal-footer justify-content-center pb-4 pt-0">
                <form asp-controller="Venta" asp-action="Eliminar" method="post" class="d-flex gap-2 w-100 px-3">
                    <input type="hidden" name="id" id="ventaEliminarId" />
                    <button type="button" class="btn btn-light fw-bold flex-fill" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger fw-bold flex-fill shadow-sm">Sí, eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const btnCalculador = document.getElementById("btnCalculadorVentasToggle");
    const cardCalculador = document.getElementById("cardCalculadorVentas");

    function confirmarEliminar(idVenta) {
        document.getElementById("ventaEliminarId").value = idVenta;
        new bootstrap.Modal(document.getElementById("modalEliminar")).show();
    }

    // ⚡ LÓGICA DE DETECCIÓN CLIC APERTURA BURBUJA
    if (btnCalculador && cardCalculador) {
        btnCalculador.addEventListener("click", (e) => {
            e.stopPropagation();
            cardCalculador.classList.toggle("active");
        });

        document.addEventListener("click", (e) => {
            if (!cardCalculador.contains(e.target) && e.target !== btnCalculador) {
                cardCalculador.classList.remove("active");
            }
        });
    }

    // ⚡ MOTOR DE SUMATORIAS EN VIVO POR ÁREA (ALUMINIO, ACCESORIOS, ARC)
    function calcularTotalesPorArea() {
        let totalAluminio = 0;
        let totalAccesorios = 0;
        let totalARC = 0;
        let totalGeneral = 0;

        // Escaneamos las filas cargadas en la tabla
        document.querySelectorAll(".venta-data-row").forEach(row => {
            let area = row.dataset.area;
            let precio = parseFloat(row.dataset.precio) || 0;

            totalGeneral += precio;

            if (area.includes("ALUMINIO")) {
                totalAluminio += precio;
            } else if (area.includes("ACCESORIO")) {
                totalAccesorios += precio;
            } else if (area.includes("ARC")) {
                totalARC += precio;
            }
        });

        // Inyectamos las sumas en los campos correspondientes de la burbuja
        document.getElementById("valTotalAluminio").innerText = "S/ " + totalAluminio.toFixed(2);
        document.getElementById("valTotalAccesorios").innerText = "S/ " + totalAccesorios.toFixed(2);
        document.getElementById("valTotalARC").innerText = "S/ " + totalARC.toFixed(2);
        document.getElementById("totalFinalVentasFlotante").innerText = "S/ " + totalGeneral.toFixed(2);
    }

    // Corre de forma automática al renderizarse la página
    document.addEventListener("DOMContentLoaded", calcularTotalesPorArea);
</script>