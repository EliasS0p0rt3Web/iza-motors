@model Negocio.Web.Models.ViewModels.RegistrarVentaViewModel

@{
    Layout = "_LayoutSistema";
    ViewData["Title"] = "Registrar Venta";

    bool esEdicion = Model.IdVenta.HasValue;
}

<style>
    :root {
        --iza-rojo: #c8102e;
        --iza-rojo-oscuro: #99152a;
        --iza-rojo-claro: #fff1f3;
        --iza-blanco: #ffffff;
        --iza-fondo: #f8fafc;
        --iza-borde: #e2e8f0;
        --iza-texto: #172033;
        --iza-gris: #64748b;
    }

    .venta-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1rem 5rem;
    }

    .venta-title {
        color: var(--iza-texto);
        font-weight: 800;
        margin-bottom: 0.35rem;
    }

    .venta-subtitle {
        color: var(--iza-gris);
        margin-bottom: 0;
    }

    .venta-card {
        background: var(--iza-blanco);
        border: 1px solid var(--iza-borde);
        border-radius: 18px;
        box-shadow: 0 8px 25px rgba(23, 32, 51, 0.06);
    }

    .form-label {
        color: var(--iza-texto);
        font-size: 0.88rem;
        font-weight: 700;
    }

    .form-control,
    .form-select {
        min-height: 46px;
        border: 1px solid var(--iza-borde);
        border-radius: 11px;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--iza-rojo);
            box-shadow: 0 0 0 0.2rem rgba(200, 16, 46, 0.12);
        }

    .input-group-text {
        color: var(--iza-rojo);
        background: var(--iza-rojo-claro);
        border-color: var(--iza-borde);
    }

    .btn-iza {
        color: var(--iza-blanco);
        background: var(--iza-rojo);
        border: none;
        border-radius: 11px;
        padding: 0.75rem 1.4rem;
        font-weight: 700;
    }

        .btn-iza:hover {
            color: var(--iza-blanco);
            background: var(--iza-rojo-oscuro);
        }

    .btn-cancelar {
        border-radius: 11px;
        padding: 0.75rem 1.4rem;
        font-weight: 700;
    }
</style>

<div class="venta-container">

    <!-- ENCABEZADO -->
    <div class="mb-4">
        <h2 class="venta-title">
            @(esEdicion ? "Editar venta" : "Registrar venta")
        </h2>

        <p class="venta-subtitle">
            Selecciona una categoría y el producto que saldrá del inventario.
        </p>
    </div>

    <!-- ERRORES -->
    @if (!ViewData.ModelState.IsValid)
    {
        @Html.ValidationSummary(
        false,
        "",
        new { @class = "alert alert-danger" }
        )
        }

    <!-- MENSAJE DE ÉXITO -->
    @if (TempData["Success"] != null)
    {
        <div id="mensajeExito"
             class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <form asp-action="@(esEdicion ? "Editar" : "Registrar")"
          method="post"
          id="formVenta">

        @Html.AntiForgeryToken()

        @if (esEdicion)
        {
            <input type="hidden"
                   asp-for="IdVenta" />
        }

        <input type="hidden"
               asp-for="IdProducto"
               id="idProductoHidden" />

        <div class="venta-card">
            <div class="card-body p-4">

                <div class="row g-3">

                    <!-- FECHA -->
                    <div class="col-md-6">
                        <label asp-for="Fecha"
                               class="form-label">
                            Fecha
                        </label>

                        <input asp-for="Fecha"
                               type="date"
                               class="form-control"
                               id="fechaInput" />

                        <span asp-validation-for="Fecha"
                              class="text-danger small">
                        </span>
                    </div>

                    <!-- DÍA -->
                    <div class="col-md-6">
                        <label asp-for="Dia"
                               class="form-label">
                            Día
                        </label>

                        <select asp-for="Dia"
                                asp-items="Model.Dias"
                                class="form-select"
                                id="diaSelect">
                        </select>
                    </div>

                    <!-- CATEGORÍA DINÁMICA -->
                    <div class="col-md-6">
                        <label asp-for="Area"
                               class="form-label">
                            Categoría
                        </label>

                        <select asp-for="Area"
                                asp-items="Model.Areas"
                                class="form-select"
                                id="areaSelect">

                            <option value="">
                                -- Seleccione una categoría --
                            </option>
                        </select>

                        <span asp-validation-for="Area"
                              class="text-danger small">
                        </span>
                    </div>

                    <!-- PRODUCTO DINÁMICO -->
                    <div class="col-md-6">
                        <label class="form-label">
                            Producto
                        </label>

                        <select id="productoSelect"
                                class="form-select"
                                disabled>

                            <option value="">
                                -- Primero seleccione una categoría --
                            </option>
                        </select>
                    </div>

                    <!-- CANTIDAD -->
                    <div class="col-md-6">
                        <label asp-for="Cantidad"
                               class="form-label">
                            Cantidad
                        </label>

                        <input asp-for="Cantidad"
                               type="number"
                               min="1"
                               step="1"
                               class="form-control"
                               id="cantidadInput" />

                        <span asp-validation-for="Cantidad"
                              class="text-danger small">
                        </span>
                    </div>

                    <!-- UNIDAD -->
                    <div class="col-md-6">
                        <label asp-for="Unidad"
                               class="form-label">
                            Unidad
                        </label>

                        <input asp-for="Unidad"
                               class="form-control"
                               id="unidadInput"
                               readonly
                               placeholder="Se completará automáticamente" />
                    </div>

                    <!-- DESTINO -->
                    <div class="col-md-6">
                        <label asp-for="Destino"
                               class="form-label">
                            Destino
                        </label>

                        <select asp-for="Destino"
                                asp-items="Model.Destinos"
                                class="form-select">
                        </select>

                        <span asp-validation-for="Destino"
                              class="text-danger small">
                        </span>
                    </div>

                    <!-- SUBTOTAL -->
                    <div class="col-md-6">
                        <label asp-for="Precio"
                               class="form-label">
                            Subtotal
                        </label>

                        <div class="input-group">
                            <span class="input-group-text">
                                S/
                            </span>

                            <input asp-for="Precio"
                                   type="number"
                                   min="0"
                                   step="0.01"
                                   class="form-control"
                                   placeholder="0.00" />
                        </div>

                        <span asp-validation-for="Precio"
                              class="text-danger small">
                        </span>
                    </div>

                    <!-- ACTUALIZAR STOCK -->
                    <div class="col-12">
                        <div class="form-check mt-2">

                            <input asp-for="ActualizarStock"
                                   class="form-check-input"
                                   checked />

                            <label asp-for="ActualizarStock"
                                   class="form-check-label">
                                Descontar automáticamente del inventario
                            </label>

                        </div>
                    </div>

                </div>

                <!-- BOTONES -->
                <div class="d-flex flex-column flex-sm-row gap-2 mt-4">

                    <button type="submit"
                            class="btn btn-iza">

                        <i class="bi bi-check-circle me-1"></i>

                        @(esEdicion
                                                ? "Guardar cambios"
                                                : "Registrar venta")
                    </button>

                    <a asp-controller="Venta"
                       asp-action="Index"
                       class="btn btn-outline-secondary btn-cancelar">

                        Cancelar
                    </a>

                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {

    <script>
        const esEdicion =
            @esEdicion.ToString().ToLower();

        const areaInicial =
            @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                        Model.Area ?? ""
                )
                );

    const descripcionInicial =
        @Html.Raw(
                        System.Text.Json.JsonSerializer.Serialize(
                                Model.Descripcion ?? ""
                        )
                );

    const unidadInicial =
        @Html.Raw(
                        System.Text.Json.JsonSerializer.Serialize(
                                Model.Unidad ?? ""
                        )
                );

    const idProductoInicial =
        @(
                        Model.IdProducto.HasValue
                                ? Model.IdProducto.Value
                                : 0
                );

        const areaSelect =
            document.getElementById("areaSelect");

        const productoSelect =
            document.getElementById("productoSelect");

        const idProductoHidden =
            document.getElementById("idProductoHidden");

        const unidadInput =
            document.getElementById("unidadInput");

        const fechaInput =
            document.getElementById("fechaInput");

        const diaSelect =
            document.getElementById("diaSelect");

        const formulario =
            document.getElementById("formVenta");

        /*
         * Carga los productos pertenecientes
         * a la categoría seleccionada.
         */
        async function cargarProductos(
            area,
            productoSeleccionado = ""
        ) {
            productoSelect.disabled = true;

            productoSelect.innerHTML =
                `<option value="">Cargando productos...</option>`;

            idProductoHidden.value = "";
            unidadInput.value = "";

            if (!area) {
                productoSelect.innerHTML =
                    `<option value="">
                        -- Primero seleccione una categoría --
                    </option>`;

                return;
            }

            try {
                const respuesta = await fetch(
                    `/Venta/ObtenerProductosPorArea` +
                    `?area=${encodeURIComponent(area)}`
                );

                if (!respuesta.ok) {
                    throw new Error(
                        "No se pudieron obtener los productos."
                    );
                }

                const productos = await respuesta.json();

                productoSelect.innerHTML =
                    `<option value="">
                        -- Seleccione un producto --
                    </option>`;

                productos.forEach(producto => {
                    const opcion =
                        document.createElement("option");

                    opcion.value =
                        producto.descripcion;

                    opcion.textContent =
                        producto.descripcion;

                    if (
                        productoSeleccionado &&
                        producto.descripcion === productoSeleccionado
                    ) {
                        opcion.selected = true;
                    }

                    productoSelect.appendChild(opcion);
                });

                productoSelect.disabled = false;

                if (productoSeleccionado) {
                    await seleccionarProducto();
                }
            }
            catch (error) {
                console.error(error);

                productoSelect.innerHTML =
                    `<option value="">
                        No se pudieron cargar los productos
                    </option>`;
            }
        }

        /*
         * Obtiene cualquier dimensión registrada
         * para el producto. La dimensión no se muestra
         * en el formulario, pero se utiliza para encontrar
         * el registro correcto.
         */
        async function obtenerDimension(
            area,
            descripcion
        ) {
            const respuesta = await fetch(
                `/Venta/ObtenerDimensiones` +
                `?area=${encodeURIComponent(area)}` +
                `&descripcion=${encodeURIComponent(descripcion)}`
            );

            if (!respuesta.ok) {
                return "";
            }

            const dimensiones = await respuesta.json();

            if (
                Array.isArray(dimensiones) &&
                dimensiones.length > 0
            ) {
                return dimensiones[0];
            }

            return "";
        }

        /*
         * Obtiene el identificador y la unidad
         * del producto seleccionado.
         */
        async function seleccionarProducto() {
            const area =
                areaSelect.value;

            const descripcion =
                productoSelect.value;

            idProductoHidden.value = "";
            unidadInput.value = "";

            if (!area || !descripcion) {
                return;
            }

            productoSelect.disabled = true;

            try {
                const dimension =
                    await obtenerDimension(
                        area,
                        descripcion
                    );

                const respuesta = await fetch(
                    `/Venta/ObtenerProductoFinal` +
                    `?area=${encodeURIComponent(area)}` +
                    `&descripcion=${encodeURIComponent(descripcion)}` +
                    `&dimensiones=${encodeURIComponent(dimension)}`
                );

                if (!respuesta.ok) {
                    throw new Error(
                        "No se pudo encontrar el producto."
                    );
                }

                const producto = await respuesta.json();

                idProductoHidden.value =
                    producto.idProducto;

                unidadInput.value =
                    producto.unidad ?? "";
            }
            catch (error) {
                console.error(error);

                alert(
                    "No se pudo seleccionar el producto."
                );
            }
            finally {
                productoSelect.disabled = false;
            }
        }

        /*
         * Completa automáticamente el día
         * según la fecha seleccionada.
         */
        function actualizarDia() {
            if (!fechaInput.value) {
                return;
            }

            const fecha =
                new Date(
                    fechaInput.value + "T00:00:00"
                );

            const dias = [
                "DOMINGO",
                "LUNES",
                "MARTES",
                "MIÉRCOLES",
                "JUEVES",
                "VIERNES",
                "SÁBADO"
            ];

            diaSelect.value =
                dias[fecha.getDay()];
        }

        areaSelect.addEventListener(
            "change",
            async function () {
                await cargarProductos(
                    areaSelect.value
                );
            }
        );

        productoSelect.addEventListener(
            "change",
            seleccionarProducto
        );

        fechaInput.addEventListener(
            "change",
            actualizarDia
        );

        formulario.addEventListener(
            "submit",
            function (evento) {
                if (!areaSelect.value) {
                    evento.preventDefault();

                    alert(
                        "Selecciona una categoría."
                    );

                    return;
                }

                if (!idProductoHidden.value) {
                    evento.preventDefault();

                    alert(
                        "Selecciona un producto antes de guardar."
                    );
                }
            }
        );

        /*
         * Precarga los valores cuando se edita
         * o cuando el formulario vuelve con errores.
         */
        document.addEventListener(
            "DOMContentLoaded",
            async function () {
                actualizarDia();

                if (areaInicial) {
                    areaSelect.value =
                        areaInicial;

                    await cargarProductos(
                        areaInicial,
                        descripcionInicial
                    );
                }

                if (
                    esEdicion &&
                    idProductoInicial > 0
                ) {
                    idProductoHidden.value =
                        idProductoInicial;

                    unidadInput.value =
                        unidadInicial;
                }
            }
        );

        /*
         * Oculta el mensaje de éxito.
         */
        setTimeout(() => {
            const mensaje =
                document.getElementById(
                    "mensajeExito"
                );

            if (mensaje) {
                mensaje.style.transition =
                    "opacity 0.4s ease";

                mensaje.style.opacity = "0";

                setTimeout(
                    () => mensaje.remove(),
                    400
                );
            }
        }, 2500);
    </script>
}