@{
    ViewData["Title"] = "Panel de Inicio";
    Layout = "_LayoutSistema";

    var rol = Context.Session.GetString("ROL");
    var usuario =
        Context.Session.GetString("USER_NAME")
        ?? Context.Session.GetString("USER")
        ?? "Usuario";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap"
      rel="stylesheet">

<style>
    .dashboard-container {
        font-family: 'Inter', sans-serif;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem 5rem;
    }

    .dashboard-title {
        font-weight: 800;
        color: #0f172a;
    }

    .dashboard-subtitle {
        color: #64748b;
        font-size: 0.95rem;
    }

    .section-title {
        color: #475569;
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-bottom: 1rem;
    }

    .action-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 1.4rem;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 1rem;
        height: 100%;
        box-shadow: 0 6px 20px rgba(15, 23, 42, 0.05);
        transition: all 0.25s ease;
    }

        .action-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 28px rgba(15, 23, 42, 0.10);
            border-color: #cbd5e1;
        }

    .action-icon {
        width: 55px;
        height: 55px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-size: 1.6rem;
        flex-shrink: 0;
    }

    .action-card h5 {
        color: #0f172a;
        font-size: 1rem;
        font-weight: 800;
        margin-bottom: 0.25rem;
    }

    .action-card p {
        color: #64748b;
        font-size: 0.82rem;
        margin: 0;
    }

    .icon-blue {
        background: linear-gradient(135deg, #2563eb, #3b82f6);
    }

    .icon-green {
        background: linear-gradient(135deg, #16a34a, #22c55e);
    }

    .icon-orange {
        background: linear-gradient(135deg, #f59e0b, #fbbf24);
    }

    .icon-purple {
        background: linear-gradient(135deg, #7c3aed, #8b5cf6);
    }
</style>

<div class="dashboard-container">

    <!-- ENCABEZADO -->
    <div class="mb-5">
        <h2 class="dashboard-title mb-1">
            Bienvenido, @usuario
        </h2>

        <p class="dashboard-subtitle mb-0">
            Panel de gestión del sistema web Iza Motors.
        </p>
    </div>

    <!-- ACCESOS PRINCIPALES -->
    <h5 class="section-title">
        <i class="bi bi-grid-fill me-2"></i>
        Accesos principales
    </h5>

    <div class="row g-3">

        @if (rol == "ADMINISTRADOR")
        {
            <!-- VENTA DE REPUESTOS -->
            <div class="col-12 col-md-6 col-lg-3">
                <a asp-controller="Venta"
                   asp-action="Registrar"
                   class="action-card">

                    <div class="action-icon icon-blue">
                        <i class="bi bi-cart-plus-fill"></i>
                    </div>

                    <div>
                        <h5>Nueva venta</h5>
                        <p>Registrar una venta de repuestos.</p>
                    </div>
                </a>
            </div>

            <!-- INVENTARIO -->
            <div class="col-12 col-md-6 col-lg-3">
                <a asp-controller="Stock"
                   asp-action="Index"
                   class="action-card">

                    <div class="action-icon icon-green">
                        <i class="bi bi-box-seam-fill"></i>
                    </div>

                    <div>
                        <h5>Inventario</h5>
                        <p>Consultar el stock disponible.</p>
                    </div>
                </a>
            </div>

            <!-- CITAS -->
            <div class="col-12 col-md-6 col-lg-3">
                <a asp-controller="Reserva"
                   asp-action="Admin"
                   class="action-card">

                    <div class="action-icon icon-orange">
                        <i class="bi bi-calendar-check-fill"></i>
                    </div>

                    <div>
                        <h5>Citas</h5>
                        <p>Revisar las citas registradas.</p>
                    </div>
                </a>
            </div>

            <!-- CLIENTES -->
            <div class="col-12 col-md-6 col-lg-3">
                <a asp-controller="Cliente"
                   asp-action="Index"
                   class="action-card">

                    <div class="action-icon icon-purple">
                        <i class="bi bi-people-fill"></i>
                    </div>

                    <div>
                        <h5>Clientes</h5>
                        <p>Consultar clientes registrados.</p>
                    </div>
                </a>
            </div>
        }
        else if (rol == "JEFE")
        {
            <!-- CITAS PARA JEFE -->
            <div class="col-12 col-md-6">
                <a asp-controller="Reserva"
                   asp-action="Admin"
                   class="action-card">

                    <div class="action-icon icon-orange">
                        <i class="bi bi-calendar-check-fill"></i>
                    </div>

                    <div>
                        <h5>Citas programadas</h5>
                        <p>Consultar las atenciones del taller.</p>
                    </div>
                </a>
            </div>

            <!-- STOCK PARA JEFE -->
            <div class="col-12 col-md-6">
                <a asp-controller="Stock"
                   asp-action="Index"
                   class="action-card">

                    <div class="action-icon icon-green">
                        <i class="bi bi-box-seam-fill"></i>
                    </div>

                    <div>
                        <h5>Stock de repuestos</h5>
                        <p>Verificar la disponibilidad del inventario.</p>
                    </div>
                </a>
            </div>
        }

    </div>

</div>